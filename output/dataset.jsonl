"{\"instruction\":\"Bu TypeScript kodundaki hatayi bul ve duzelt:\\n```typescript\\nfunction asenkron(): Promise<string> {\\n    return new Promise((resolve) => {\\n        setTimeout(() => {\\n            resolve('Tamam');\\n        }, 1000);\\n    });\\n}\\n\\nfunction main() {\\n    const sonuc = asenkron();\\n    console.log(sonuc);  // Promise\\n}\\n```\",\"response\":\"function asenkron(): Promise<string> {\\n    return new Promise((resolve) => {\\n        setTimeout(() => {\\n            resolve('Tamam');\\n        }, 1000);\\n    });\\n}\\n\\nasync function main() {\\n    const sonuc = await asenkron();\\n    console.log(sonuc);  // 'Tamam'\\n}\\n\\nmain();\",\"language\":\"typescript\",\"category\":\"bug_fix\",\"type\":\"manual\",\"format\":\"bug_fix\"}"
"{\"instruction\":\"Bu TypeScript kodundaki hatayi bul ve duzelt:\\n```typescript\\nconst sayilar: number[] = [1, 2, 3];\\nconst kareler: number[] = sayilar.map(s => s * s);\\nconsole.log(kareler.join(', '));\\n\\nconst yeni: number[] = [...sayilar, ...[4, 5]];\\nconsole.log(yeni.join(', '));  // tamam aslinda\\n\\n// Problem:\\nconst metin: string[] = ['a', 'b'];\\nconst karisik = [...sayilar, ...metin];  // number | string[]\\n```\",\"response\":\"const sayilar: number[] = [1, 2, 3];\\nconst kareler: number[] = sayilar.map(s => s * s);\\nconsole.log(kareler.join(', '));\\n\\nconst yeni: number[] = sayilar.concat([4, 5]);\\nconsole.log(yeni.join(', '));\\n\\nconst metin: string[] = ['a', 'b'];\\nconst karisik: (number | string)[] = [...sayilar, ...metin];\\nconsole.log(karisik);\",\"language\":\"typescript\",\"category\":\"bug_fix\",\"type\":\"manual\",\"format\":\"bug_fix\"}"
"{\"instruction\":\"Bu TypeScript kodundaki hatayi bul ve duzelt:\\n```typescript\\ntype Koordinat = {\\n    x: number;\\n    y: number;\\n};\\n\\nfunction toplam(k: Koordinat): number {\\n    return k.x + k.y;\\n}\\n\\ntype Koordinat3D = Koordinat & {\\n    z: number;\\n};\\n\\nconst nokta: Koordinat3D = { x: 1, y: 2, z: 3 };\\nconsole.log(toplam(nokta));\\n```\",\"response\":\"type Koordinat = {\\n    x: number;\\n    y: number;\\n};\\n\\ntype Koordinat3D = Koordinat & {\\n    z: number;\\n};\\n\\nfunction toplam2D(k: Koordinat): number {\\n    return k.x + k.y;\\n}\\n\\nfunction toplam3D(k: Koordinat3D): number {\\n    return k.x + k.y + k.z;\\n}\\n\\nconst nokta: Koordinat3D = { x: 1, y: 2, z: 3 };\\nconsole.log(toplam2D(nokta));\\nconsole.log(toplam3D(nokta));\",\"language\":\"typescript\",\"category\":\"bug_fix\",\"type\":\"manual\",\"format\":\"bug_fix\"}"
"{\"instruction\":\"Bu TypeScript kodundaki hatayi bul ve duzelt:\\n```typescript\\nfunction parseJson(metin: string): any {\\n    return JSON.parse(metin);\\n}\\n\\nconst veri = parseJson('{\\\"isim\\\": \\\"Ali\\\"}');\\nconsole.log(veri.isim.length);\\n```\",\"response\":\"interface Veri {\\n    isim?: string;\\n}\\n\\nfunction parseJson(metin: string): Veri | null {\\n    try {\\n        const obj = JSON.parse(metin);\\n        if (typeof obj === 'object' && obj !== null) {\\n            return obj as Veri;\\n        }\\n        return null;\\n    } catch {\\n        return null;\\n    }\\n}\\n\\nconst veri = parseJson('{\\\"isim\\\": \\\"Ali\\\"}');\\nif (veri?.isim) {\\n    console.log(veri.isim.length);\\n}\",\"language\":\"typescript\",\"category\":\"bug_fix\",\"type\":\"manual\",\"format\":\"bug_fix\"}"
"{\"instruction\":\"Bu TypeScript kodundaki hatayi bul ve duzelt:\\n```typescript\\nimport { Component } from '@angular/core';\\n\\n@Component({\\n    selector: 'app-root',\\n    template: '<h1>{{ title }}</h1>'\\n})\\nexport class AppComponent {\\n    private title: string = 'Merhaba';\\n    \\n    getTitle(): string {\\n        return this.title;\\n    }\\n}\\n\\nconst app = new AppComponent();\\nconsole.log(app.title);  // private erisim hatasi\\n```\",\"response\":\"import { Component } from '@angular/core';\\n\\n@Component({\\n    selector: 'app-root',\\n    template: '<h1>{{ title }}</h1>'\\n})\\nexport class AppComponent {\\n    title: string = 'Merhaba';\\n    \\n    getTitle(): string {\\n        return this.title;\\n    }\\n}\\n\\nconst app = new AppComponent();\\nconsole.log(app.title);\",\"language\":\"typescript\",\"category\":\"bug_fix\",\"type\":\"manual\",\"format\":\"bug_fix\"}"
"{\"instruction\":\"Bu TypeScript kodundaki hatayi bul ve duzelt:\\n```typescript\\nfunction delay(ms: number): Promise<void> {\\n    return new Promise(resolve => setTimeout(resolve, ms));\\n}\\n\\nasync function siraliCalistir(fonksiyonlar: (() => Promise<void>)[]) {\\n    for (const f of fonksiyonlar) {\\n        f();  // await unutuldu\\n    }\\n}\\n```\",\"response\":\"function delay(ms: number): Promise<void> {\\n    return new Promise(resolve => setTimeout(resolve, ms));\\n}\\n\\nasync function siraliCalistir(fonksiyonlar: (() => Promise<void>)[]) {\\n    for (const f of fonksiyonlar) {\\n        await f();\\n    }\\n}\",\"language\":\"typescript\",\"category\":\"bug_fix\",\"type\":\"manual\",\"format\":\"bug_fix\"}"
