"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef mat_add(A,B):\\n    n=len(A); m=len(A[0])\\n    return [[A[i][j]+B[i][j] for j in range(m)] for i in range(n)]\",\"response\":\"def test_mat_add():\\n    assert mat_add([[1,2],[3,4]],[[5,6],[7,8]])==[[6,8],[10,12]]\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
