"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef unflatten_dict(d,sep='.'):\\n    result={}\\n    for k,v in d.items():\\n        parts=k.split(sep); cur=result\\n        for p in parts[:-1]:\\n            if p not in cur: cur[p]={}\\n            cur=cur[p]\\n        cur[parts[-1]]=v\\n    return result\",\"response\":\"def test_unflatten():\\n    r=unflatten_dict({'a.b':1,'a.c':2,'d':3})\\nassert r=={'a':{'b':1,'c':2},'d':3}\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
