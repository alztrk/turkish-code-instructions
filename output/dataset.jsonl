"{\"instruction\":\"std::thread ile thread.\",\"response\":\"#include<thread>\\n#include<iostream>\\nvoid f(int n){std::cout<<n;}\\nint main(){\\n  std::thread t(f,42);\\n  t.join();\\n  return 0;\\n}\",\"language\":\"cpp\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"std::mutex ile senkronizasyon.\",\"response\":\"#include<mutex>\\n#include<iostream>\\n#include<thread>\\nint s=0;std::mutex m;\\nvoid a(){for(int i=0;i<1000;i++){std::lock_guard<std::mutex> l(m);s++;}}\\nint main(){\\n  std::thread t1(a),t2(a);\\n  t1.join();t2.join();\\n  std::cout<<s;\\n  return 0;\\n}\",\"language\":\"cpp\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"std::chrono ile zaman olcumu.\",\"response\":\"#include<chrono>\\n#include<iostream>\\nint main(){\\n  auto basla=std::chrono::high_resolution_clock::now();\\n  volatile int s=0;for(int i=0;i<100000;i++)s+=i;\\n  auto bitis=std::chrono::high_resolution_clock::now();\\n  std::cout<<std::chrono::duration_cast<std::chrono::microseconds>(bitis-basla).count()<<\\\"us\\\";\\n  return 0;\\n}\",\"language\":\"cpp\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
