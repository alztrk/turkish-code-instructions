"{\"instruction\":\"JSON Veritabani Yoneticisi uygulamasi yap. Veri ekleme, silme, listeleme ve arama ozellikleri olsun. JSON tabanli CRUD islemleri yapan veritabani yoneticisi uygulamasi.\",\"response\":\"import * as fs from \\\"fs\\\";\\nimport * as readline from \\\"readline\\\";\\nconst dosya = \\\"json_veritabani_yoneticisi.json\\\";\\nlet veriler: string[] = [];\\nfunction yukle(): void {\\n    try { veriler = JSON.parse(fs.readFileSync(dosya, \\\"utf8\\\")); } catch { veriler = []; }\\n}\\nfunction kaydet(): void { fs.writeFileSync(dosya, JSON.stringify(veriler, null, 2)); }\\nconst rl = readline.createInterface({ input: process.stdin, output: process.stdout });\\nfunction sor(q: string): Promise<string> {\\n    return new Promise(resolve => rl.question(q, resolve));\\n}\\nasync function menu() {\\n    while (true) {\\n        const s = await sor(\\\"\\\\\\\\n1:Ekle 2:Listele 3:Sil 4:Cikis: \\\");\\n        if (s === \\\"4\\\") break;\\n        else if (s === \\\"1\\\") { const d = await sor(\\\"Deger: \\\"); veriler.push(d); kaydet(); console.log(\\\"Eklendi.\\\"); }\\n        else if (s === \\\"2\\\") { veriler.forEach((v, i) => console.log(i+1 + \\\".\\\", v)); }\\n        else if (s === \\\"3\\\") { const idx = parseInt(await sor(\\\"Index: \\\")) - 1; if(idx>=0 && idx<veriler.length) { veriler.splice(idx,1); kaydet(); console.log(\\\"Silindi.\\\"); } }\\n    }\\n    rl.close();\\n}\\nyukle(); console.log(\\\"JSON Veritabani Yoneticisi uygulamasi baslatildi.\\\"); menu();\",\"language\":\"typescript\",\"category\":\"project\",\"type\":\"manual\",\"format\":\"project\"}"
