"{\"instruction\":\"Selection sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def selection_sort(arr):\\n    for i in range(len(arr)):\\n        min_idx = i\\n        for j in range(i + 1, len(arr)):\\n            if arr[j] < arr[min_idx]: min_idx = j\\n        arr[i], arr[min_idx] = arr[min_idx], arr[i]\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Selection sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function selectionSort(arr) {\\n    for (let i = 0; i < arr.length; i++) { let minIdx = i; for (let j = i + 1; j < arr.length; j++) { if (arr[j] < arr[minIdx]) minIdx = j; } [arr[i], arr[minIdx]] = [arr[minIdx], arr[i]]; }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Selection sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func SelectionSort(arr []int) []int {\\n    for i := 0; i < len(arr); i++ { minIdx := i; for j := i + 1; j < len(arr); j++ { if arr[j] < arr[minIdx] { minIdx = j } }; arr[i], arr[minIdx] = arr[minIdx], arr[i] }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bubble sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def bubble_sort(arr):\\n    n = len(arr)\\n    for i in range(n):\\n        swapped = False\\n        for j in range(0, n - i - 1):\\n            if arr[j] > arr[j + 1]: arr[j], arr[j + 1] = arr[j + 1], arr[j]; swapped = True\\n        if not swapped: break\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bubble sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function bubbleSort(arr) {\\n    const n = arr.length;\\n    for (let i = 0; i < n; i++) { let swapped = false; for (let j = 0; j < n - i - 1; j++) { if (arr[j] > arr[j + 1]) { [arr[j], arr[j + 1]] = [arr[j + 1], arr[j]]; swapped = true; } } if (!swapped) break; }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bubble sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static void bubbleSort(int[] arr) {\\n    int n = arr.length;\\n    for (int i = 0; i < n; i++) { boolean swapped = false; for (int j = 0; j < n - i - 1; j++) { if (arr[j] > arr[j + 1]) { int t = arr[j]; arr[j] = arr[j + 1]; arr[j + 1] = t; swapped = true; } } if (!swapped) break; }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Heap sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def heap_sort(arr):\\n    def heapify(arr, n, i):\\n        largest = i; l = 2 * i + 1; r = 2 * i + 2\\n        if l < n and arr[l] > arr[largest]: largest = l\\n        if r < n and arr[r] > arr[largest]: largest = r\\n        if largest != i: arr[i], arr[largest] = arr[largest], arr[i]; heapify(arr, n, largest)\\n    n = len(arr)\\n    for i in range(n // 2 - 1, -1, -1): heapify(arr, n, i)\\n    for i in range(n - 1, 0, -1): arr[0], arr[i] = arr[i], arr[0]; heapify(arr, i, 0)\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Heap sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function heapSort(arr) {\\n    function heapify(arr, n, i) { let largest = i, l = 2 * i + 1, r = 2 * i + 2; if (l < n && arr[l] > arr[largest]) largest = l; if (r < n && arr[r] > arr[largest]) largest = r; if (largest !== i) { [arr[i], arr[largest]] = [arr[largest], arr[i]]; heapify(arr, n, largest); } }\\n    const n = arr.length;\\n    for (let i = Math.floor(n / 2) - 1; i >= 0; i--) heapify(arr, n, i);\\n    for (let i = n - 1; i > 0; i--) { [arr[0], arr[i]] = [arr[i], arr[0]]; heapify(arr, i, 0); }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Heap sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func HeapSort(arr []int) []int {\\n    heapify := func(arr []int, n, i int) { largest := i; l := 2*i + 1; r := 2*i + 2; if l < n && arr[l] > arr[largest] { largest = l }; if r < n && arr[r] > arr[largest] { largest = r }; if largest != i { arr[i], arr[largest] = arr[largest], arr[i]; heapify(arr, n, largest) } }\\n    n := len(arr)\\n    for i := n/2 - 1; i >= 0; i-- { heapify(arr, n, i) }\\n    for i := n - 1; i > 0; i-- { arr[0], arr[i] = arr[i], arr[0]; heapify(arr, i, 0) }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Counting sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def counting_sort(arr):\\n    if not arr: return arr\\n    max_val = max(arr); count = [0] * (max_val + 1)\\n    for num in arr: count[num] += 1\\n    for i in range(1, len(count)): count[i] += count[i - 1]\\n    output = [0] * len(arr)\\n    for num in reversed(arr): output[count[num] - 1] = num; count[num] -= 1\\n    return output\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Counting sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function countingSort(arr) {\\n    if (!arr.length) return arr;\\n    const max = Math.max(...arr); const count = new Array(max + 1).fill(0);\\n    arr.forEach(n => count[n]++);\\n    for (let i = 1; i < count.length; i++) count[i] += count[i - 1];\\n    const output = new Array(arr.length);\\n    for (let i = arr.length - 1; i >= 0; i--) { output[count[arr[i]] - 1] = arr[i]; count[arr[i]]--; }\\n    return output;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Counting sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static int[] countingSort(int[] arr) {\\n    if (arr.length == 0) return arr;\\n    int max = Arrays.stream(arr).max().getAsInt(); int[] count = new int[max + 1];\\n    for (int n : arr) count[n]++;\\n    for (int i = 1; i < count.length; i++) count[i] += count[i - 1];\\n    int[] output = new int[arr.length];\\n    for (int i = arr.length - 1; i >= 0; i--) { output[count[arr[i]] - 1] = arr[i]; count[arr[i]]--; }\\n    return output;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Radix sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def radix_sort(arr):\\n    if not arr: return arr\\n    max_val = max(arr); exp = 1\\n    while max_val // exp > 0:\\n        n = len(arr); output = [0] * n; count = [0] * 10\\n        for num in arr: count[(num // exp) % 10] += 1\\n        for i in range(1, 10): count[i] += count[i - 1]\\n        for num in reversed(arr):\\n            digit = (num // exp) % 10\\n            output[count[digit] - 1] = num; count[digit] -= 1\\n        arr = output; exp *= 10\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Radix sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function radixSort(arr) {\\n    if (!arr.length) return arr;\\n    const max = Math.max(...arr);\\n    for (let exp = 1; Math.floor(max / exp) > 0; exp *= 10) {\\n        const output = new Array(arr.length); const count = new Array(10).fill(0);\\n        for (const num of arr) count[Math.floor(num / exp) % 10]++;\\n        for (let i = 1; i < 10; i++) count[i] += count[i - 1];\\n        for (let i = arr.length - 1; i >= 0; i--) { const d = Math.floor(arr[i] / exp) % 10; output[count[d] - 1] = arr[i]; count[d]--; }\\n        arr = output;\\n    }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Radix sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func RadixSort(arr []int) []int {\\n    if len(arr) == 0 { return arr }\\n    maxVal := arr[0]; for _, v := range arr { if v > maxVal { maxVal = v } }\\n    for exp := 1; maxVal/exp > 0; exp *= 10 {\\n        output := make([]int, len(arr)); count := make([]int, 10)\\n        for _, num := range arr { count[(num/exp)%10]++ }\\n        for i := 1; i < 10; i++ { count[i] += count[i-1] }\\n        for i := len(arr) - 1; i >= 0; i-- { d := (arr[i] / exp) % 10; output[count[d]-1] = arr[i]; count[d]-- }\\n        arr = output\\n    }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Shell sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def shell_sort(arr):\\n    n = len(arr); gap = n // 2\\n    while gap > 0:\\n        for i in range(gap, n):\\n            temp = arr[i]; j = i\\n            while j >= gap and arr[j - gap] > temp: arr[j] = arr[j - gap]; j -= gap\\n            arr[j] = temp\\n        gap //= 2\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Shell sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function shellSort(arr) {\\n    const n = arr.length;\\n    for (let gap = Math.floor(n / 2); gap > 0; gap = Math.floor(gap / 2)) {\\n        for (let i = gap; i < n; i++) { const temp = arr[i]; let j = i; while (j >= gap && arr[j - gap] > temp) { arr[j] = arr[j - gap]; j -= gap; } arr[j] = temp; }\\n    }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Shell sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func ShellSort(arr []int) []int {\\n    n := len(arr)\\n    for gap := n / 2; gap > 0; gap /= 2 {\\n        for i := gap; i < n; i++ { temp := arr[i]; j := i; for j >= gap && arr[j-gap] > temp { arr[j] = arr[j-gap]; j -= gap }; arr[j] = temp }\\n    }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tim sort algoritmasini (insertion + merge) uygulayan fonksiyon yaz\",\"response\":\"def tim_sort(arr):\\n    RUN = 32; n = len(arr)\\n    for i in range(0, n, RUN):\\n        for j in range(min(i + RUN, n) - i): key = arr[i + j]; k = i + j - 1; while k >= i and arr[k] > key: arr[k + 1] = arr[k]; k -= 1; arr[k + 1] = key\\n    size = RUN\\n    while size < n:\\n        for left in range(0, n, 2 * size):\\n            mid = left + size; right = min(left + 2 * size, n)\\n            if mid < right:\\n                left_arr = arr[left:mid]; right_arr = arr[mid:right]; i = j = 0; k = left\\n                while i < len(left_arr) and j < len(right_arr):\\n                    if left_arr[i] <= right_arr[j]: arr[k] = left_arr[i]; i += 1\\n                    else: arr[k] = right_arr[j]; j += 1\\n                    k += 1\\n                while i < len(left_arr): arr[k] = left_arr[i]; i += 1; k += 1\\n                while j < len(right_arr): arr[k] = right_arr[j]; j += 1; k += 1\\n        size *= 2\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tim sort algoritmasini (insertion + merge) uygulayan fonksiyon yaz\",\"response\":\"function timSort(arr) {\\n    const RUN = 32; const n = arr.length;\\n    for (let i = 0; i < n; i += RUN) for (let j = i + 1; j < Math.min(i + RUN, n); j++) { const key = arr[j]; let k = j - 1; while (k >= i && arr[k] > key) { arr[k + 1] = arr[k]; k--; } arr[k + 1] = key; }\\n    for (let size = RUN; size < n; size *= 2) {\\n        for (let left = 0; left < n; left += 2 * size) {\\n            const mid = left + size, right = Math.min(left + 2 * size, n);\\n            if (mid < right) { const L = arr.slice(left, mid), R = arr.slice(mid, right); let i = 0, j = 0, k = left; while (i < L.length && j < R.length) arr[k++] = L[i] <= R[j] ? L[i++] : R[j++]; while (i < L.length) arr[k++] = L[i++]; while (j < R.length) arr[k++] = R[j++]; }\\n        }\\n    }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tim sort algoritmasini (insertion + merge) uygulayan fonksiyon yaz\",\"response\":\"public static void timSort(int[] arr) {\\n    int RUN = 32, n = arr.length;\\n    for (int i = 0; i < n; i += RUN) for (int j = i + 1; j < Math.min(i + RUN, n); j++) { int key = arr[j]; int k = j - 1; while (k >= i && arr[k] > key) { arr[k + 1] = arr[k]; k--; } arr[k + 1] = key; }\\n    for (int size = RUN; size < n; size *= 2) {\\n        for (int left = 0; left < n; left += 2 * size) {\\n            int mid = left + size, right = Math.min(left + 2 * size, n);\\n            if (mid < right) { int[] L = Arrays.copyOfRange(arr, left, mid), R = Arrays.copyOfRange(arr, mid, right); int i = 0, j = 0, k = left; while (i < L.length && j < R.length) arr[k++] = L[i] <= R[j] ? L[i++] : R[j++]; while (i < L.length) arr[k++] = L[i++]; while (j < R.length) arr[k++] = R[j++]; }\\n        }\\n    }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bucket sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def bucket_sort(arr):\\n    if not arr: return arr\\n    n = len(arr); max_val = max(arr); buckets = [[] for _ in range(n)]\\n    for num in arr:\\n        idx = int(num * n / (max_val + 1))\\n        buckets[idx].append(num)\\n    for bucket in buckets: bucket.sort()\\n    return [num for bucket in buckets for num in bucket]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bucket sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function bucketSort(arr) {\\n    if (!arr.length) return arr;\\n    const n = arr.length, max = Math.max(...arr), buckets = Array.from({length: n}, () => []);\\n    arr.forEach(v => buckets[Math.floor(v * n / (max + 1))].push(v));\\n    buckets.forEach(b => b.sort((a, b) => a - b));\\n    return buckets.flat();\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bucket sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func BucketSort(arr []float64) []float64 {\\n    if len(arr) == 0 { return arr }\\n    n := len(arr); maxVal := arr[0]; for _, v := range arr { if v > maxVal { maxVal = v } }\\n    buckets := make([][]float64, n)\\n    for _, v := range arr { idx := int(v * float64(n) / (maxVal + 1)); buckets[idx] = append(buckets[idx], v) }\\n    var result []float64\\n    for _, b := range buckets { sort.Float64s(b); result = append(result, b...) }\\n    return result\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cocktail shaker sort (cift yonlu bubble sort) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def cocktail_sort(arr):\\n    n = len(arr); start = 0; end = n - 1; swapped = True\\n    while swapped:\\n        swapped = False\\n        for i in range(start, end):\\n            if arr[i] > arr[i + 1]: arr[i], arr[i + 1] = arr[i + 1], arr[i]; swapped = True\\n        if not swapped: break\\n        swapped = False; end -= 1\\n        for i in range(end - 1, start - 1, -1):\\n            if arr[i] > arr[i + 1]: arr[i], arr[i + 1] = arr[i + 1], arr[i]; swapped = True\\n        start += 1\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cocktail shaker sort (cift yonlu bubble sort) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function cocktailSort(arr) {\\n    let n = arr.length, start = 0, end = n - 1, swapped = true;\\n    while (swapped) {\\n        swapped = false;\\n        for (let i = start; i < end; i++) { if (arr[i] > arr[i + 1]) { [arr[i], arr[i + 1]] = [arr[i + 1], arr[i]]; swapped = true; } }\\n        if (!swapped) break; swapped = false; end--;\\n        for (let i = end - 1; i >= start; i--) { if (arr[i] > arr[i + 1]) { [arr[i], arr[i + 1]] = [arr[i + 1], arr[i]]; swapped = true; } }\\n        start++;\\n    }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cocktail shaker sort (cift yonlu bubble sort) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func CocktailSort(arr []int) []int {\\n    n := len(arr); start, end := 0, n-1; swapped := true\\n    for swapped {\\n        swapped = false\\n        for i := start; i < end; i++ { if arr[i] > arr[i+1] { arr[i], arr[i+1] = arr[i+1], arr[i]; swapped = true } }\\n        if !swapped { break }; swapped = false; end--\\n        for i := end - 1; i >= start; i-- { if arr[i] > arr[i+1] { arr[i], arr[i+1] = arr[i+1], arr[i]; swapped = true } }\\n        start++\\n    }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Gnome sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def gnome_sort(arr):\\n    i = 0\\n    while i < len(arr):\\n        if i == 0 or arr[i] >= arr[i - 1]: i += 1\\n        else: arr[i], arr[i - 1] = arr[i - 1], arr[i]; i -= 1\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Gnome sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function gnomeSort(arr) {\\n    let i = 0;\\n    while (i < arr.length) { if (i === 0 || arr[i] >= arr[i - 1]) i++; else { [arr[i], arr[i - 1]] = [arr[i - 1], arr[i]]; i--; } }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Gnome sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func GnomeSort(arr []int) []int {\\n    i := 0\\n    for i < len(arr) { if i == 0 || arr[i] >= arr[i-1] { i++ } else { arr[i], arr[i-1] = arr[i-1], arr[i]; i-- } }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Odd-even sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def odd_even_sort(arr):\\n    n = len(arr); sorted = False\\n    while not sorted:\\n        sorted = True\\n        for i in range(1, n - 1, 2):\\n            if arr[i] > arr[i + 1]: arr[i], arr[i + 1] = arr[i + 1], arr[i]; sorted = False\\n        for i in range(0, n - 1, 2):\\n            if arr[i] > arr[i + 1]: arr[i], arr[i + 1] = arr[i + 1], arr[i]; sorted = False\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Odd-even sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function oddEvenSort(arr) {\\n    const n = arr.length; let sorted = false;\\n    while (!sorted) {\\n        sorted = true;\\n        for (let i = 1; i < n - 1; i += 2) { if (arr[i] > arr[i + 1]) { [arr[i], arr[i + 1]] = [arr[i + 1], arr[i]]; sorted = false; } }\\n        for (let i = 0; i < n - 1; i += 2) { if (arr[i] > arr[i + 1]) { [arr[i], arr[i + 1]] = [arr[i + 1], arr[i]]; sorted = false; } }\\n    }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Odd-even sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func OddEvenSort(arr []int) []int {\\n    n := len(arr); sorted := false\\n    for !sorted {\\n        sorted = true\\n        for i := 1; i < n-1; i += 2 { if arr[i] > arr[i+1] { arr[i], arr[i+1] = arr[i+1], arr[i]; sorted = false } }\\n        for i := 0; i < n-1; i += 2 { if arr[i] > arr[i+1] { arr[i], arr[i+1] = arr[i+1], arr[i]; sorted = false } }\\n    }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Comb sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def comb_sort(arr):\\n    n = len(arr); gap = n; shrink = 1.3; sorted = False\\n    while not sorted:\\n        gap = int(gap / shrink)\\n        if gap <= 1: gap = 1; sorted = True\\n        for i in range(n - gap):\\n            if arr[i] > arr[i + gap]: arr[i], arr[i + gap] = arr[i + gap], arr[i]; sorted = False\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Comb sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function combSort(arr) {\\n    const n = arr.length; let gap = n; const shrink = 1.3; let sorted = false;\\n    while (!sorted) { gap = Math.floor(gap / shrink); if (gap <= 1) { gap = 1; sorted = true; } for (let i = 0; i < n - gap; i++) { if (arr[i] > arr[i + gap]) { [arr[i], arr[i + gap]] = [arr[i + gap], arr[i]]; sorted = false; } } }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Comb sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func CombSort(arr []int) []int {\\n    n := len(arr); gap := n; shrink := 1.3; sorted := false\\n    for !sorted { gap = int(float64(gap) / shrink); if gap <= 1 { gap = 1; sorted = true }; for i := 0; i < n-gap; i++ { if arr[i] > arr[i+gap] { arr[i], arr[i+gap] = arr[i+gap], arr[i]; sorted = false } } }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Pigeonhole sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def pigeonhole_sort(arr):\\n    if not arr: return arr\\n    min_val, max_val = min(arr), max(arr)\\n    holes = [[] for _ in range(max_val - min_val + 1)]\\n    for num in arr: holes[num - min_val].append(num)\\n    i = 0\\n    for hole in holes:\\n        for num in hole: arr[i] = num; i += 1\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Pigeonhole sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function pigeonholeSort(arr) {\\n    if (!arr.length) return arr;\\n    const min = Math.min(...arr), max = Math.max(...arr);\\n    const holes = Array.from({length: max - min + 1}, () => []);\\n    arr.forEach(v => holes[v - min].push(v));\\n    let i = 0;\\n    holes.forEach(hole => hole.forEach(v => { arr[i++] = v; }));\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Pigeonhole sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func PigeonholeSort(arr []int) []int {\\n    if len(arr) == 0 { return arr }\\n    minVal, maxVal := arr[0], arr[0]\\n    for _, v := range arr { if v < minVal { minVal = v }; if v > maxVal { maxVal = v } }\\n    holes := make([][]int, maxVal-minVal+1)\\n    for _, v := range arr { holes[v-minVal] = append(holes[v-minVal], v) }\\n    i := 0\\n    for _, hole := range holes { for _, v := range hole { arr[i] = v; i++ } }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cycle sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def cycle_sort(arr):\\n    n = len(arr)\\n    for start in range(n - 1):\\n        item = arr[start]; pos = start\\n        for i in range(start + 1, n):\\n            if arr[i] < item: pos += 1\\n        if pos == start: continue\\n        while item == arr[pos]: pos += 1\\n        arr[pos], item = item, arr[pos]\\n        while pos != start:\\n            pos = start\\n            for i in range(start + 1, n):\\n                if arr[i] < item: pos += 1\\n            while item == arr[pos]: pos += 1\\n            arr[pos], item = item, arr[pos]\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cycle sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function cycleSort(arr) {\\n    const n = arr.length;\\n    for (let start = 0; start < n - 1; start++) {\\n        let item = arr[start], pos = start;\\n        for (let i = start + 1; i < n; i++) if (arr[i] < item) pos++;\\n        if (pos === start) continue;\\n        while (item === arr[pos]) pos++;\\n        [arr[pos], item] = [item, arr[pos]];\\n        while (pos !== start) {\\n            pos = start;\\n            for (let i = start + 1; i < n; i++) if (arr[i] < item) pos++;\\n            while (item === arr[pos]) pos++;\\n            [arr[pos], item] = [item, arr[pos]];\\n        }\\n    }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cycle sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func CycleSort(arr []int) []int {\\n    n := len(arr)\\n    for start := 0; start < n-1; start++ {\\n        item := arr[start]; pos := start\\n        for i := start + 1; i < n; i++ { if arr[i] < item { pos++ } }\\n        if pos == start { continue }\\n        for item == arr[pos] { pos++ }\\n        arr[pos], item = item, arr[pos]\\n        for pos != start {\\n            pos = start\\n            for i := start + 1; i < n; i++ { if arr[i] < item { pos++ } }\\n            for item == arr[pos] { pos++ }\\n            arr[pos], item = item, arr[pos]\\n        }\\n    }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Stooge sort (komedi siralamasi) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def stooge_sort(arr, l=0, r=None):\\n    if r is None: r = len(arr) - 1\\n    if arr[l] > arr[r]: arr[l], arr[r] = arr[r], arr[l]\\n    if r - l + 1 > 2:\\n        t = (r - l + 1) // 3\\n        stooge_sort(arr, l, r - t)\\n        stooge_sort(arr, l + t, r)\\n        stooge_sort(arr, l, r - t)\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Stooge sort (komedi siralamasi) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function stoogeSort(arr, l = 0, r = arr.length - 1) {\\n    if (arr[l] > arr[r]) [arr[l], arr[r]] = [arr[r], arr[l]];\\n    if (r - l + 1 > 2) { const t = Math.floor((r - l + 1) / 3); stoogeSort(arr, l, r - t); stoogeSort(arr, l + t, r); stoogeSort(arr, l, r - t); }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Stooge sort (komedi siralamasi) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func StoogeSort(arr []int, l, r int) []int {\\n    if l >= r { r = len(arr) - 1 }\\n    if arr[l] > arr[r] { arr[l], arr[r] = arr[r], arr[l] }\\n    if r-l+1 > 2 { t := (r - l + 1) / 3; StoogeSort(arr, l, r-t); StoogeSort(arr, l+t, r); StoogeSort(arr, l, r-t) }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bogo sort (rassal siralama) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import random\\ndef bogo_sort(arr):\\n    def is_sorted(arr): return all(arr[i] <= arr[i + 1] for i in range(len(arr) - 1))\\n    while not is_sorted(arr): random.shuffle(arr)\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bogo sort (rassal siralama) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function bogoSort(arr) {\\n    function isSorted(arr) { for (let i = 0; i < arr.length - 1; i++) if (arr[i] > arr[i + 1]) return false; return true; }\\n    while (!isSorted(arr)) { for (let i = arr.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [arr[i], arr[j]] = [arr[j], arr[i]]; } }\\n    return arr;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bogo sort (rassal siralama) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func BogoSort(arr []int) []int {\\n    isSorted := func(a []int) bool { for i := 0; i < len(a)-1; i++ { if a[i] > a[i+1] { return false } }; return true }\\n    for !isSorted(arr) { rand.Shuffle(len(arr), func(i, j int) { arr[i], arr[j] = arr[j], arr[i] }) }\\n    return arr\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dijkstra algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import heapq\\ndef dijkstra(graph, start):\\n    dist = {node: float('inf') for node in graph}; dist[start] = 0\\n    pq = [(0, start)]\\n    while pq:\\n        d, node = heapq.heappop(pq)\\n        if d > dist[node]: continue\\n        for neighbor, weight in graph[node]:\\n            nd = d + weight\\n            if nd < dist[neighbor]: dist[neighbor] = nd; heapq.heappush(pq, (nd, neighbor))\\n    return dist\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dijkstra algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function dijkstra(graph, start) {\\n    const dist = {}; const pq = [[0, start]];\\n    for (const node in graph) dist[node] = Infinity;\\n    dist[start] = 0;\\n    while (pq.length) {\\n        pq.sort((a, b) => a[0] - b[0]);\\n        const [d, node] = pq.shift();\\n        if (d > dist[node]) continue;\\n        for (const [neighbor, weight] of graph[node]) { const nd = d + weight; if (nd < dist[neighbor]) { dist[neighbor] = nd; pq.push([nd, neighbor]); } }\\n    }\\n    return dist;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dijkstra algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static Map<Integer, Integer> dijkstra(Map<Integer, List<int[]>> graph, int start) {\\n    Map<Integer, Integer> dist = new HashMap<>(); PriorityQueue<int[]> pq = new PriorityQueue<>(Comparator.comparingInt(a -> a[1]));\\n    for (int node : graph.keySet()) dist.put(node, Integer.MAX_VALUE);\\n    dist.put(start, 0); pq.offer(new int[]{start, 0});\\n    while (!pq.isEmpty()) {\\n        int[] cur = pq.poll(); int node = cur[0], d = cur[1];\\n        if (d > dist.get(node)) continue;\\n        for (int[] edge : graph.get(node)) { int nd = d + edge[1]; if (nd < dist.get(edge[0])) { dist.put(edge[0], nd); pq.offer(new int[]{edge[0], nd}); } }\\n    }\\n    return dist;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dijkstra algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func Dijkstra(graph map[int][][2]int, start int) map[int]int {\\n    dist := make(map[int]int); pq := &minHeap{{start, 0}}; heap.Init(pq)\\n    for node := range graph { dist[node] = 1 << 31 }; dist[start] = 0\\n    for pq.Len() > 0 {\\n        cur := heap.Pop(pq).([2]int); node, d := cur[0], cur[1]\\n        if d > dist[node] { continue }\\n        for _, edge := range graph[node] { nd := d + edge[1]; if nd < dist[edge[0]] { dist[edge[0]] = nd; heap.Push(pq, [2]int{edge[0], nd}) } }\\n    }\\n    return dist\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bellman-Ford algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def bellman_ford(edges, n, start):\\n    dist = [float('inf')] * n; dist[start] = 0\\n    for _ in range(n - 1):\\n        for u, v, w in edges:\\n            if dist[u] != float('inf') and dist[u] + w < dist[v]: dist[v] = dist[u] + w\\n    for u, v, w in edges:\\n        if dist[u] != float('inf') and dist[u] + w < dist[v]: return None  # Negative cycle\\n    return dist\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bellman-Ford algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function bellmanFord(edges, n, start) {\\n    const dist = new Array(n).fill(Infinity); dist[start] = 0;\\n    for (let i = 0; i < n - 1; i++) { for (const [u, v, w] of edges) { if (dist[u] !== Infinity && dist[u] + w < dist[v]) dist[v] = dist[u] + w; } }\\n    for (const [u, v, w] of edges) { if (dist[u] !== Infinity && dist[u] + w < dist[v]) return null; }\\n    return dist;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bellman-Ford algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static int[] bellmanFord(int[][] edges, int n, int start) {\\n    int[] dist = new int[n]; Arrays.fill(dist, Integer.MAX_VALUE); dist[start] = 0;\\n    for (int i = 0; i < n - 1; i++) { for (int[] e : edges) { if (dist[e[0]] != Integer.MAX_VALUE && dist[e[0]] + e[2] < dist[e[1]]) dist[e[1]] = dist[e[0]] + e[2]; } }\\n    for (int[] e : edges) { if (dist[e[0]] != Integer.MAX_VALUE && dist[e[0]] + e[2] < dist[e[1]]) return null; }\\n    return dist;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bellman-Ford algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func BellmanFord(edges [][3]int, n, start int) []int {\\n    dist := make([]int, n); for i := range dist { dist[i] = 1 << 31 }; dist[start] = 0\\n    for i := 0; i < n-1; i++ { for _, e := range edges { if dist[e[0]] != 1<<31 && dist[e[0]]+e[2] < dist[e[1]] { dist[e[1]] = dist[e[0]] + e[2] } } }\\n    for _, e := range edges { if dist[e[0]] != 1<<31 && dist[e[0]]+e[2] < dist[e[1]] { return nil } }\\n    return dist\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Floyd-Warshall algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def floyd_warshall(graph):\\n    n = len(graph); dist = [row[:] for row in graph]\\n    for k in range(n):\\n        for i in range(n):\\n            for j in range(n):\\n                if dist[i][k] + dist[k][j] < dist[i][j]: dist[i][j] = dist[i][k] + dist[k][j]\\n    return dist\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Floyd-Warshall algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function floydWarshall(graph) {\\n    const n = graph.length; const dist = graph.map(row => [...row]);\\n    for (let k = 0; k < n; k++) { for (let i = 0; i < n; i++) { for (let j = 0; j < n; j++) { if (dist[i][k] + dist[k][j] < dist[i][j]) dist[i][j] = dist[i][k] + dist[k][j]; } } }\\n    return dist;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Floyd-Warshall algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static int[][] floydWarshall(int[][] graph) {\\n    int n = graph.length; int[][] dist = new int[n][n];\\n    for (int i = 0; i < n; i++) System.arraycopy(graph[i], 0, dist[i], 0, n);\\n    for (int k = 0; k < n; k++) for (int i = 0; i < n; i++) for (int j = 0; j < n; j++) if (dist[i][k] + dist[k][j] < dist[i][j]) dist[i][j] = dist[i][k] + dist[k][j];\\n    return dist;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Prim algoritmasini (minimum spanning tree) uygulayan fonksiyon yaz\",\"response\":\"import heapq\\ndef prim(graph, start):\\n    mst = []; visited = {start}; edges = []\\n    for neighbor, weight in graph[start]: heapq.heappush(edges, (weight, start, neighbor))\\n    while edges:\\n        weight, u, v = heapq.heappop(edges)\\n        if v in visited: continue\\n        visited.add(v); mst.append((u, v, weight))\\n        for neighbor, w in graph[v]:\\n            if neighbor not in visited: heapq.heappush(edges, (w, v, neighbor))\\n    return mst\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Prim algoritmasini (minimum spanning tree) uygulayan fonksiyon yaz\",\"response\":\"function prim(graph, start) {\\n    const mst = []; const visited = new Set([start]); const edges = [];\\n    for (const [neighbor, weight] of graph[start]) edges.push([weight, start, neighbor]);\\n    while (edges.length) {\\n        edges.sort((a, b) => a[0] - b[0]);\\n        const [weight, u, v] = edges.shift();\\n        if (visited.has(v)) continue;\\n        visited.add(v); mst.push([u, v, weight]);\\n        for (const [neighbor, w] of graph[v]) { if (!visited.has(neighbor)) edges.push([w, v, neighbor]); }\\n    }\\n    return mst;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Prim algoritmasini (minimum spanning tree) uygulayan fonksiyon yaz\",\"response\":\"public static List<int[]> prim(List<int[]>[] graph, int start) {\\n    List<int[]> mst = new ArrayList<>(); Set<Integer> visited = new HashSet<>(); visited.add(start);\\n    PriorityQueue<int[]> pq = new PriorityQueue<>(Comparator.comparingInt(a -> a[0]));\\n    for (int[] edge : graph[start]) pq.offer(new int[]{edge[1], start, edge[0]});\\n    while (!pq.isEmpty()) {\\n        int[] cur = pq.poll(); int weight = cur[0], u = cur[1], v = cur[2];\\n        if (visited.contains(v)) continue;\\n        visited.add(v); mst.add(new int[]{u, v, weight});\\n        for (int[] edge : graph[v]) { if (!visited.contains(edge[0])) pq.offer(new int[]{edge[1], v, edge[0]}); }\\n    }\\n    return mst;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Prim algoritmasini (minimum spanning tree) uygulayan fonksiyon yaz\",\"response\":\"func Prim(graph map[int][][2]int, start int) [][3]int {\\n    var mst [][3]int; visited := map[int]bool{start: true}; edges := &edgeHeap{}; heap.Init(edges)\\n    for _, e := range graph[start] { heap.Push(edges, [3]int{e[1], start, e[0]}) }\\n    for edges.Len() > 0 {\\n        e := heap.Pop(edges).([3]int); w, u, v := e[0], e[1], e[2]\\n        if visited[v] { continue }; visited[v] = true; mst = append(mst, [3]int{u, v, w})\\n        for _, ne := range graph[v] { if !visited[ne[0]] { heap.Push(edges, [3]int{ne[1], v, ne[0]}) } }\\n    }\\n    return mst\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kruskal algoritmasini (minimum spanning tree) uygulayan fonksiyon yaz\",\"response\":\"def kruskal(edges, n):\\n    parent = list(range(n))\\n    def find(x):\\n        while parent[x] != x: parent[x] = parent[parent[x]]; x = parent[x]\\n        return x\\n    def union(x, y): parent[find(x)] = find(y)\\n    mst = []; edges.sort(key=lambda e: e[2])\\n    for u, v, w in edges:\\n        if find(u) != find(v): union(u, v); mst.append((u, v, w))\\n    return mst\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kruskal algoritmasini (minimum spanning tree) uygulayan fonksiyon yaz\",\"response\":\"function kruskal(edges, n) {\\n    const parent = Array.from({length: n}, (_, i) => i);\\n    function find(x) { while (parent[x] !== x) { parent[x] = parent[parent[x]]; x = parent[x]; } return x; }\\n    function union(x, y) { parent[find(x)] = find(y); }\\n    const mst = []; edges.sort((a, b) => a[2] - b[2]);\\n    for (const [u, v, w] of edges) { if (find(u) !== find(v)) { union(u, v); mst.push([u, v, w]); } }\\n    return mst;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kruskal algoritmasini (minimum spanning tree) uygulayan fonksiyon yaz\",\"response\":\"public static List<int[]> kruskal(int[][] edges, int n) {\\n    int[] parent = new int[n]; for (int i = 0; i < n; i++) parent[i] = i;\\n    Arrays.sort(edges, Comparator.comparingInt(a -> a[2]));\\n    List<int[]> mst = new ArrayList<>();\\n    for (int[] e : edges) { int pu = find(parent, e[0]), pv = find(parent, e[1]); if (pu != pv) { parent[pu] = pv; mst.add(e); } }\\n    return mst;\\n}\\nprivate static int find(int[] parent, int x) { while (parent[x] != x) { parent[x] = parent[parent[x]]; x = parent[x]; } return x; }\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kruskal algoritmasini (minimum spanning tree) uygulayan fonksiyon yaz\",\"response\":\"func Kruskal(edges [][3]int, n int) [][3]int {\\n    parent := make([]int, n); for i := range parent { parent[i] = i }\\n    var find func(int) int\\n    find = func(x int) int { if parent[x] != x { parent[x] = find(parent[x]) }; return parent[x] }\\n    union := func(x, y int) { parent[find(x)] = find(y) }\\n    sort.Slice(edges, func(i, j int) bool { return edges[i][2] < edges[j][2] })\\n    var mst [][3]int\\n    for _, e := range edges { if find(e[0]) != find(e[1]) { union(e[0], e[1]); mst = append(mst, e) } }\\n    return mst\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Topolojik siralama (topological sort) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"from collections import deque\\ndef topological_sort(graph):\\n    n = len(graph); in_degree = [0] * n\\n    for u in range(n):\\n        for v in graph[u]: in_degree[v] += 1\\n    q = deque([i for i in range(n) if in_degree[i] == 0])\\n    result = []\\n    while q:\\n        u = q.popleft(); result.append(u)\\n        for v in graph[u]:\\n            in_degree[v] -= 1\\n            if in_degree[v] == 0: q.append(v)\\n    return result if len(result) == n else None\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Topolojik siralama (topological sort) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function topologicalSort(graph) {\\n    const n = graph.length; const inDegree = new Array(n).fill(0);\\n    for (let u = 0; u < n; u++) for (const v of graph[u]) inDegree[v]++;\\n    const q = []; for (let i = 0; i < n; i++) if (inDegree[i] === 0) q.push(i);\\n    const result = [];\\n    while (q.length) { const u = q.shift(); result.push(u); for (const v of graph[u]) { inDegree[v]--; if (inDegree[v] === 0) q.push(v); } }\\n    return result.length === n ? result : null;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Topolojik siralama (topological sort) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static List<Integer> topologicalSort(List<Integer>[] graph) {\\n    int n = graph.length; int[] inDegree = new int[n];\\n    for (int u = 0; u < n; u++) for (int v : graph[u]) inDegree[v]++;\\n    Queue<Integer> q = new LinkedList<>(); for (int i = 0; i < n; i++) if (inDegree[i] == 0) q.offer(i);\\n    List<Integer> result = new ArrayList<>();\\n    while (!q.isEmpty()) { int u = q.poll(); result.add(u); for (int v : graph[u]) { inDegree[v]--; if (inDegree[v] == 0) q.offer(v); } }\\n    return result.size() == n ? result : null;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Topolojik siralama (topological sort) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func TopologicalSort(graph [][]int) []int {\\n    n := len(graph); inDegree := make([]int, n)\\n    for u := 0; u < n; u++ { for _, v := range graph[u] { inDegree[v]++ } }\\n    q := make([]int, 0)\\n    for i := 0; i < n; i++ { if inDegree[i] == 0 { q = append(q, i) } }\\n    var result []int\\n    for len(q) > 0 { u := q[0]; q = q[1:]; result = append(result, u); for _, v := range graph[u] { inDegree[v]--; if inDegree[v] == 0 { q = append(q, v) } } }\\n    if len(result) != n { return nil }; return result\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kosaraju algoritmasini (guclu bagli bilesen) uygulayan fonksiyon yaz\",\"response\":\"def kosaraju(graph):\\n    n = len(graph); visited = [False] * n; order = []\\n    def dfs(u):\\n        visited[u] = True\\n        for v in graph[u]:\\n            if not visited[v]: dfs(v)\\n        order.append(u)\\n    for i in range(n):\\n        if not visited[i]: dfs(i)\\n    rev_graph = [[] for _ in range(n)]\\n    for u in range(n):\\n        for v in graph[u]: rev_graph[v].append(u)\\n    visited = [False] * n; sccs = []\\n    def rdfs(u, comp):\\n        visited[u] = True; comp.append(u)\\n        for v in rev_graph[u]:\\n            if not visited[v]: rdfs(v, comp)\\n    for u in reversed(order):\\n        if not visited[u]:\\n            comp = []; rdfs(u, comp); sccs.append(comp)\\n    return sccs\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kosaraju algoritmasini (guclu bagli bilesen) uygulayan fonksiyon yaz\",\"response\":\"function kosaraju(graph) {\\n    const n = graph.length; const visited = new Array(n).fill(false); const order = [];\\n    function dfs(u) { visited[u] = true; for (const v of graph[u]) { if (!visited[v]) dfs(v); } order.push(u); }\\n    for (let i = 0; i < n; i++) { if (!visited[i]) dfs(i); }\\n    const revGraph = Array.from({length: n}, () => []);\\n    for (let u = 0; u < n; u++) for (const v of graph[u]) revGraph[v].push(u);\\n    visited.fill(false); const sccs = [];\\n    function rdfs(u, comp) { visited[u] = true; comp.push(u); for (const v of revGraph[u]) { if (!visited[v]) rdfs(v, comp); } }\\n    for (let i = n - 1; i >= 0; i--) { const u = order[i]; if (!visited[u]) { const comp = []; rdfs(u, comp); sccs.push(comp); } }\\n    return sccs;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kosaraju algoritmasini (guclu bagli bilesen) uygulayan fonksiyon yaz\",\"response\":\"public static List<List<Integer>> kosaraju(List<Integer>[] graph) {\\n    int n = graph.length; boolean[] visited = new boolean[n]; List<Integer> order = new ArrayList<>();\\n    for (int i = 0; i < n; i++) if (!visited[i]) { Deque<Integer> stack = new ArrayDeque<>(); stack.push(i); while (!stack.isEmpty()) { int u = stack.pop(); if (visited[u]) { order.add(u); continue; } visited[u] = true; stack.push(u); for (int v : graph[u]) if (!visited[v]) stack.push(v); } }\\n    List<Integer>[] revGraph = new List[n]; for (int i = 0; i < n; i++) revGraph[i] = new ArrayList<>();\\n    for (int u = 0; u < n; u++) for (int v : graph[u]) revGraph[v].add(u);\\n    Arrays.fill(visited, false); List<List<Integer>> sccs = new ArrayList<>();\\n    for (int i = n - 1; i >= 0; i--) { int u = order.get(i); if (!visited[u]) { List<Integer> comp = new ArrayList<>(); Deque<Integer> stack = new ArrayDeque<>(); stack.push(u); while (!stack.isEmpty()) { int x = stack.pop(); if (visited[x]) continue; visited[x] = true; comp.add(x); for (int v : revGraph[x]) if (!visited[v]) stack.push(v); } sccs.add(comp); } }\\n    return sccs;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kosaraju algoritmasini (guclu bagli bilesen) uygulayan fonksiyon yaz\",\"response\":\"func Kosaraju(graph [][]int) [][]int {\\n    n := len(graph); visited := make([]bool, n); var order []int\\n    var dfs func(int)\\n    dfs = func(u int) { visited[u] = true; for _, v := range graph[u] { if !visited[v] { dfs(v) } }; order = append(order, u) }\\n    for i := 0; i < n; i++ { if !visited[i] { dfs(i) } }\\n    revGraph := make([][]int, n)\\n    for u := 0; u < n; u++ { for _, v := range graph[u] { revGraph[v] = append(revGraph[v], u) } }\\n    visited = make([]bool, n); var sccs [][]int\\n    var rdfs func(int, *[]int)\\n    rdfs = func(u int, comp *[]int) { visited[u] = true; *comp = append(*comp, u); for _, v := range revGraph[u] { if !visited[v] { rdfs(v, comp) } } }\\n    for i := n - 1; i >= 0; i-- { u := order[i]; if !visited[u] { comp := make([]int, 0); rdfs(u, &comp); sccs = append(sccs, comp) } }\\n    return sccs\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
