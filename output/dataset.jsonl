"{\"instruction\":\"SELF JOIN ile calisan-yonetici.\",\"response\":\"SELECT c.ad AS calisan,y.ad AS yonetici FROM calisan c JOIN calisan y ON c.yonetici_id=y.id;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
