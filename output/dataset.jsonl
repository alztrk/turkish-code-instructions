"{\"instruction\":\"bytes.Buffer ile tampon.\",\"response\":\"package main\\nimport(\\\"bytes\\\";\\\"fmt\\\")\\nfunc main(){\\n  var b bytes.Buffer\\n  b.WriteString(\\\"Merhaba \\\")\\n  b.Write([]byte(\\\"Dunya\\\"))\\n  fmt.Println(b.String())\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
