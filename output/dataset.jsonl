"{\"instruction\":\"fold expression ile parametre paketi (17+).\",\"response\":\"#include<iostream>\\ntemplate<typename...Args>\\nauto topla(Args...args){return(args+...);}\\nint main(){std::cout<<topla(1,2,3,4,5);return 0;}\",\"language\":\"cpp\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Binary search algoritmasi.\",\"response\":\"def binary_search(arr,t):\\n  l,r=0,len(arr)-1\\n  while l<=r:\\n    m=(l+r)//2\\n    if arr[m]==t:return m\\n    elif arr[m]<t:l=m+1\\n    else:r=m-1\\n  return-1\\nprint(binary_search([1,2,3,4,5],3))\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"BFS ile graf dolasimi.\",\"response\":\"from collections import deque\\ndef bfs(g,bas):\\n  z=set([bas]);q=deque([bas])\\n  while q:\\n    n=q.popleft();print(n)\\n    for k in g[n]:\\n      if k not in z:z.add(k);q.append(k)\\ng={0:[1,2],1:[2],2:[0,3],3:[3]}\\nbfs(g,2)\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"DFS ile graf dolasimi.\",\"response\":\"def dfs(g,bas,z=None):\\n  if z is None:z=set()\\n  z.add(bas);print(bas)\\n  for k in g[bas]:\\n    if k not in z:dfs(g,k,z)\\ng={0:[1,2],1:[2],2:[0,3],3:[3]}\\ndfs(g,2)\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Dijkstra ile en kisa yol.\",\"response\":\"import heapq\\ndef dijkstra(g,bas):\\n  m={n:float('inf')for n in g};m[bas]=0\\n  pq=[(0,bas)]\\n  while pq:\\n    d,n=heapq.heappop(pq)\\n    if d>m[n]:continue\\n    for k,v in g[n].items():\\n      nd=d+v\\n      if nd<m[k]:m[k]=nd;heapq.heappush(pq,(nd,k))\\n  return m\\ng={'A':{'B':1,'C':4},'B':{'C':2,'D':5},'C':{'D':1},'D':{}}\\nprint(dijkstra(g,'A'))\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Dynamic programming ile Fibonacci.\",\"response\":\"def fib_dp(n):\\n  if n<2:return n\\n  dp=[0]*(n+1);dp[1]=1\\n  for i in range(2,n+1):dp[i]=dp[i-1]+dp[i-2]\\n  return dp[n]\\nprint(fib_dp(100))\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Longest Common Subsequence.\",\"response\":\"def lcs(a,b):\\n  m,n=len(a),len(b)\\n  dp=[[0]*(n+1)for _ in range(m+1)]\\n  for i in range(1,m+1):\\n    for j in range(1,n+1):\\n      if a[i-1]==b[j-1]:dp[i][j]=1+dp[i-1][j-1]\\n      else:dp[i][j]=max(dp[i-1][j],dp[i][j-1])\\n  return dp[m][n]\\nprint(lcs('ABCDGH','AEDFHR'))\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"KnapSack 0-1 DP ile.\",\"response\":\"def knapsack(W,wt,val,n):\\n  dp=[[0]*(W+1)for _ in range(n+1)]\\n  for i in range(1,n+1):\\n    for w in range(1,W+1):\\n      if wt[i-1]<=w:dp[i][w]=max(val[i-1]+dp[i-1][w-wt[i-1]],dp[i-1][w])\\n      else:dp[i][w]=dp[i-1][w]\\n  return dp[n][W]\\nval=[60,100,120];wt=[10,20,30];W=50\\nprint(knapsack(W,wt,val,len(val)))\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Insertion sort.\",\"response\":\"def insertion_sort(arr):\\n  for i in range(1,len(arr)):\\n    key=arr[i];j=i-1\\n    while j>=0 and arr[j]>key:arr[j+1]=arr[j];j-=1\\n    arr[j+1]=key\\n  return arr\\nprint(insertion_sort([12,11,13,5,6]))\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Selection sort.\",\"response\":\"def selection_sort(arr):\\n  for i in range(len(arr)):\\n    m=i\\n    for j in range(i+1,len(arr)):\\n      if arr[j]<arr[m]:m=j\\n    arr[i],arr[m]=arr[m],arr[i]\\n  return arr\\nprint(selection_sort([64,25,12,22,11]))\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Bubble sort.\",\"response\":\"def bubble_sort(arr):\\n  n=len(arr)\\n  for i in range(n):\\n    for j in range(0,n-i-1):\\n      if arr[j]>arr[j+1]:arr[j],arr[j+1]=arr[j+1],arr[j]\\n  return arr\\nprint(bubble_sort([64,34,25,12,22,11,90]))\",\"language\":\"algorithms\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"match ile pattern matching.\",\"response\":\"fn main(){\\n  let x=3;\\n  match x{\\n    1=>println!(\\\"Bir\\\"),\\n    2|3=>println!(\\\"Iki veya Uc\\\"),\\n    _=>println!(\\\"Diger\\\")\\n  }\\n}\",\"language\":\"rust\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
