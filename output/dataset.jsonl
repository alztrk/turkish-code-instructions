"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef permute(arr):\\n    if len(arr)<=1: return [arr]\\n    r=[]\\n    for i,e in enumerate(arr):\\n        for p in permute(arr[:i]+arr[i+1:]):\\n            r.append([e]+p)\\n    return r\",\"response\":\"def test_permute():\\n    assert len(permute([1,2,3]))==6\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
