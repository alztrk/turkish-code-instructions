"{\"instruction\":\"Bir sifrenin guclugunu kontrol eden fonksiyon yaz\",\"response\":\"def sifre_guclugu(s):\\n    import re\\n    puan = 0\\n    if len(s) >= 8: puan += 1\\n    if re.search(r'[a-z]', s): puan += 1\\n    if re.search(r'[A-Z]', s): puan += 1\\n    if re.search(r'\\\\d', s): puan += 1\\n    if re.search(r'[^\\\\w]', s): puan += 1\\n    return puan\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
