"{\"instruction\":\"Class constructor ile basit bir model olustur ve nesne uret.\",\"response\":\"class Ogrenci {\\n  ad: string;\\n  numara: number;\\n\\n  constructor(ad: string, numara: number) {\\n    this.ad = ad;\\n    this.numara = numara;\\n  }\\n\\n  tanit(): void {\\n    console.log(`Ben ${this.ad}, numaram ${this.numara}`);\\n  }\\n}\\n\\nconst ogrenci = new Ogrenci(\\\"Ayse\\\", 123);\\nogrenci.tanit();\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"public ve private erisim belirtecleri olan bir class yaz.\",\"response\":\"class Hesap {\\n  public sahip: string;\\n  private bakiye: number;\\n\\n  constructor(sahip: string, bakiye: number) {\\n    this.sahip = sahip;\\n    this.bakiye = bakiye;\\n  }\\n\\n  public paraYatir(miktar: number): void {\\n    this.bakiye += miktar;\\n  }\\n\\n  public bakiyeGoster(): string {\\n    return `${this.sahip} bakiyesi: ${this.bakiye}`;\\n  }\\n}\\n\\nconst hesap = new Hesap(\\\"Ali\\\", 1000);\\nhesap.paraYatir(500);\\nconsole.log(hesap.bakiyeGoster());\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
