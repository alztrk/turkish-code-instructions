"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\npublic class ArrayUtils { public static int[] bubble(int[] a){int n=a.length;for(int i=0;i<n;i++)for(int j=0;j<n-i-1;j++)if(a[j]>a[j+1]){int t=a[j];a[j]=a[j+1];a[j+1]=t;}return a;} }\",\"response\":\"import org.junit.*;\\nimport static org.junit.Assert.*;\\npublic class BubbleTest {\\n    @Test\\n    public void testBubble() {\\n        assertArrayEquals(new int[]{1,1,3,4,5},ArrayUtils.bubble(new int[]{3,1,4,1,5}));\\n    }\\n}\",\"language\":\"java\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\npublic class ArrayUtils { public static int[] mergeSort(int[] a){if(a.length<=1)return a;int m=a.length/2;return merge(mergeSort(java.util.Arrays.copyOfRange(a,0,m)),mergeSort(java.util.Arrays.copyOfRange(a,m,a.length)));}private static int[] merge(int[] l,int[] r){int[] res=new int[l.length+r.length];int i=0,j=0,k=0;while(i<l.length&&j<r.length)res[k++]=l[i]<=r[j]?l[i++]:r[j++];while(i<l.length)res[k++]=l[i++];while(j<r.length)res[k++]=r[j++];return res;} }\",\"response\":\"import org.junit.*;\\nimport static org.junit.Assert.*;\\npublic class MergeTest {\\n    @Test\\n    public void testMerge() {\\n        assertArrayEquals(new int[]{3,9,10,27,38,43,82},ArrayUtils.mergeSort(new int[]{38,27,43,3,9,82,10}));\\n    }\\n}\",\"language\":\"java\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\npublic class ArrayUtils { public static int binSearch(int[] a,int t){int l=0,r=a.length-1;while(l<=r){int m=(l+r)/2;if(a[m]==t)return m;if(a[m]<t)l=m+1;else r=m-1;}return-1;} }\",\"response\":\"import org.junit.*;\\nimport static org.junit.Assert.*;\\npublic class BinSearchTest {\\n    @Test\\n    public void testBinSearch() {\\n        assertEquals(2,ArrayUtils.binSearch(new int[]{1,3,5,7,9},5));\\n        assertEquals(-1,ArrayUtils.binSearch(new int[]{1,3,5,7,9},2));\\n    }\\n}\",\"language\":\"java\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
