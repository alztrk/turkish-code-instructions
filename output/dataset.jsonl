"{\"instruction\":\"Bir dizideki en büyük sayıyı bulan fonksiyon yaz.\",\"response\":\"function enBuyukBul(dizi) {\\n  let enBuyuk = dizi[0];\\n  for (let index = 1; index < dizi.length; index++) {\\n    if (dizi[index] > enBuyuk) {\\n      enBuyuk = dizi[index];\\n    }\\n  }\\n  return enBuyuk;\\n}\\n\\nlet sayilar = [4, 12, 7, 25, 9];\\nconsole.log(enBuyukBul(sayilar));\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir kelimenin tersini döndüren fonksiyon yaz.\",\"response\":\"function tersCevir(kelime) {\\n  let sonuc = \\\"\\\";\\n  for (let index = kelime.length - 1; index >= 0; index--) {\\n    sonuc += kelime[index];\\n  }\\n  return sonuc;\\n}\\n\\nlet girdi = \\\"merhaba\\\";\\nlet cikti = tersCevir(girdi);\\nconsole.log(cikti);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir dizideki çift sayıları filtreleyen fonksiyon yaz.\",\"response\":\"function ciftleriFiltrele(dizi) {\\n  return dizi.filter(function(sayi) {\\n    return sayi % 2 === 0;\\n  });\\n}\\n\\nlet sayilar = [1, 2, 3, 4, 5, 6];\\nlet ciftSayilar = ciftleriFiltrele(sayilar);\\nconsole.log(ciftSayilar);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
