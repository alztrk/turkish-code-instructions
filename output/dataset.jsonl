"{\"instruction\":\"Hatirlatici uygulamasi yap. Veri ekleme, silme, listeleme ve arama ozellikleri olsun. Hatirlatici uygulamasi.\",\"response\":\"import json, os, sys\\nclass Hatirlatici:\\n    def __init__(self):\\n        self.veriler = []\\n        self.dosya = \\\"hatirlatici.json\\\"\\n    def yukle(self):\\n        if os.path.exists(self.dosya):\\n            with open(self.dosya, \\\"r\\\", encoding=\\\"utf-8\\\") as f: self.veriler = json.load(f)\\n    def kaydet(self):\\n        with open(self.dosya, \\\"w\\\", encoding=\\\"utf-8\\\") as f: json.dump(self.veriler, f, indent=2, ensure_ascii=False)\\n    def ekle(self, deger):\\n        self.veriler.append(deger); self.kaydet(); print(f\\\"Eklendi: {deger}\\\")\\n    def listele(self):\\n        for i, v in enumerate(self.veriler, 1): print(f\\\"{i}. {v}\\\")\\n    def ara(self, kelime):\\n        sonuc = [v for v in self.veriler if kelime.lower() in str(v).lower()]\\n        print(f\\\"{len(sonuc)} sonuc:\\\"); [print(f\\\"  - {s}\\\") for s in sonuc]\\n    def sil(self, index):\\n        if 0 <= index < len(self.veriler):\\n            silinen = self.veriler.pop(index); self.kaydet(); print(f\\\"Silindi: {silinen}\\\")\\n    def menu(self):\\n        self.yukle()\\n        while True:\\n            s = input(\\\"\\\\\\\\n1:Ekle 2:Listele 3:Ara 4:Sil 5:Cikis: \\\")\\n            if s == \\\"5\\\": break\\n            elif s == \\\"1\\\": self.ekle(input(\\\"Deger: \\\"))\\n            elif s == \\\"2\\\": self.listele()\\n            elif s == \\\"3\\\": self.ara(input(\\\"Kelime: \\\"))\\n            elif s == \\\"4\\\": self.sil(int(input(\\\"Index: \\\")) - 1)\\nif __name__ == \\\"__main__\\\":\\n    app = Hatirlatici()\\n    app.menu()\",\"language\":\"python\",\"category\":\"project\",\"type\":\"manual\",\"format\":\"project\"}"
"{\"instruction\":\"JSON Veritabani Yoneticisi uygulamasi yap. Veri ekleme, silme, listeleme ve arama ozellikleri olsun. JSON tabanli CRUD islemleri yapan veritabani yoneticisi uygulamasi.\",\"response\":\"const fs = require(\\\"fs\\\");\\nconst readline = require(\\\"readline\\\");\\nconst rl = readline.createInterface({ input: process.stdin, output: process.stdout });\\nconst dosya = \\\"json_veritabani_yoneticisi.json\\\";\\nlet veriler = [];\\nfunction yukle() {\\n    try { veriler = JSON.parse(fs.readFileSync(dosya, \\\"utf8\\\")); } catch(e) { veriler = []; }\\n}\\nfunction kaydet() { fs.writeFileSync(dosya, JSON.stringify(veriler, null, 2)); }\\nfunction ekle(deger) { veriler.push(deger); kaydet(); console.log(\\\"Eklendi:\\\", deger); menu(); }\\nfunction listele() { veriler.forEach((v, i) => console.log(i+1 + \\\".\\\", v)); menu(); }\\nfunction ara(kelime) {\\n    const sonuc = veriler.filter(v => v.toLowerCase().includes(kelime.toLowerCase()));\\n    console.log(sonuc.length + \\\" sonuc:\\\"); sonuc.forEach(s => console.log(\\\"  -\\\", s)); menu();\\n}\\nfunction sil(idx) {\\n    if (idx >= 0 && idx < veriler.length) {\\n        const silinen = veriler.splice(idx, 1); kaydet(); console.log(\\\"Silindi:\\\", silinen[0]);\\n    } else console.log(\\\"Gecersiz index\\\"); menu();\\n}\\nfunction menu() {\\n    rl.question(\\\"\\\\\\\\n1:Ekle 2:Listele 3:Ara 4:Sil 5:Cikis: \\\", secim => {\\n        if (secim === \\\"5\\\") return rl.close();\\n        else if (secim === \\\"1\\\") rl.question(\\\"Deger: \\\", d => { ekle(d); });\\n        else if (secim === \\\"2\\\") listele();\\n        else if (secim === \\\"3\\\") rl.question(\\\"Kelime: \\\", k => { ara(k); });\\n        else if (secim === \\\"4\\\") rl.question(\\\"Index: \\\", i => { sil(parseInt(i)-1); });\\n        else menu();\\n    });\\n}\\nyukle();\\nconsole.log(\\\"JSON Veritabani Yoneticisi uygulamasi baslatildi.\\\");\\nmenu();\",\"language\":\"javascript\",\"category\":\"project\",\"type\":\"manual\",\"format\":\"project\"}"
"{\"instruction\":\"Markdown Editor uygulamasi yap. Veri ekleme, silme, listeleme ve arama ozellikleri olsun. Markdown metnini HTML'e donusturen editor uygulamasi.\",\"response\":\"const fs = require(\\\"fs\\\");\\nconst readline = require(\\\"readline\\\");\\nconst rl = readline.createInterface({ input: process.stdin, output: process.stdout });\\nconst dosya = \\\"markdown_editor.json\\\";\\nlet veriler = [];\\nfunction yukle() {\\n    try { veriler = JSON.parse(fs.readFileSync(dosya, \\\"utf8\\\")); } catch(e) { veriler = []; }\\n}\\nfunction kaydet() { fs.writeFileSync(dosya, JSON.stringify(veriler, null, 2)); }\\nfunction ekle(deger) { veriler.push(deger); kaydet(); console.log(\\\"Eklendi:\\\", deger); menu(); }\\nfunction listele() { veriler.forEach((v, i) => console.log(i+1 + \\\".\\\", v)); menu(); }\\nfunction ara(kelime) {\\n    const sonuc = veriler.filter(v => v.toLowerCase().includes(kelime.toLowerCase()));\\n    console.log(sonuc.length + \\\" sonuc:\\\"); sonuc.forEach(s => console.log(\\\"  -\\\", s)); menu();\\n}\\nfunction sil(idx) {\\n    if (idx >= 0 && idx < veriler.length) {\\n        const silinen = veriler.splice(idx, 1); kaydet(); console.log(\\\"Silindi:\\\", silinen[0]);\\n    } else console.log(\\\"Gecersiz index\\\"); menu();\\n}\\nfunction menu() {\\n    rl.question(\\\"\\\\\\\\n1:Ekle 2:Listele 3:Ara 4:Sil 5:Cikis: \\\", secim => {\\n        if (secim === \\\"5\\\") return rl.close();\\n        else if (secim === \\\"1\\\") rl.question(\\\"Deger: \\\", d => { ekle(d); });\\n        else if (secim === \\\"2\\\") listele();\\n        else if (secim === \\\"3\\\") rl.question(\\\"Kelime: \\\", k => { ara(k); });\\n        else if (secim === \\\"4\\\") rl.question(\\\"Index: \\\", i => { sil(parseInt(i)-1); });\\n        else menu();\\n    });\\n}\\nyukle();\\nconsole.log(\\\"Markdown Editor uygulamasi baslatildi.\\\");\\nmenu();\",\"language\":\"javascript\",\"category\":\"project\",\"type\":\"manual\",\"format\":\"project\"}"
