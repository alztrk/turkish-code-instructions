"{\"instruction\":\"byte ve rune kullanarak string icindeki karakterleri say.\",\"response\":\"package main\\nimport (\\\"fmt\\\"; \\\"unicode/utf8\\\")\\nfunc main() {\\n  metin := \\\"Merhaba Dunya\\\"\\n  fmt.Println(\\\"Byte:\\\", len(metin))\\n  fmt.Println(\\\"Rune:\\\", utf8.RuneCountInString(metin))\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"strconv ile stringi inte ve inti stringe cevir.\",\"response\":\"package main\\nimport (\\\"fmt\\\"; \\\"strconv\\\")\\nfunc main() {\\n  sayi, _ := strconv.Atoi(\\\"42\\\")\\n  fmt.Printf(\\\"int: %d\\\\n\\\", sayi)\\n  fmt.Println(\\\"str:\\\", strconv.Itoa(sayi))\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"strings.Split ile metni bol, Join ile birlestir.\",\"response\":\"package main\\nimport (\\\"fmt\\\"; \\\"strings\\\")\\nfunc main() {\\n  fmt.Println(strings.Join(strings.Split(\\\"elma,armut,muz\\\", \\\",\\\"), \\\" - \\\"))\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"strings.Contains, Replace, Trim ile metin manipulasyonu.\",\"response\":\"package main\\nimport (\\\"fmt\\\"; \\\"strings\\\")\\nfunc main() {\\n  m := \\\"  Merhaba Dunya  \\\"\\n  fmt.Println(strings.Contains(m, \\\"Dunya\\\"))\\n  fmt.Println(strings.Replace(m, \\\"Dunya\\\", \\\"Go\\\", 1))\\n  fmt.Println(strings.TrimSpace(m))\\n  fmt.Println(strings.ToUpper(m))\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"time.Now ile simdiki zamani al ve formatla.\",\"response\":\"package main\\nimport (\\\"fmt\\\"; \\\"time\\\")\\nfunc main() {\\n  fmt.Println(time.Now().Format(\\\"02-01-2006 15:04:05\\\"))\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"sort.Ints ile integer sliceini sirala.\",\"response\":\"package main\\nimport (\\\"fmt\\\"; \\\"sort\\\")\\nfunc main() {\\n  s := []int{42, 13, 7, 99, 25}\\n  sort.Ints(s)\\n  fmt.Println(s)\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"encoding/json ile structi JSONa cevir.\",\"response\":\"package main\\nimport (\\\"encoding/json\\\"; \\\"fmt\\\")\\ntype K struct {\\n  Ad  string ` + \\\"`json:\\\"ad\\\"`\\\" + `\\n  Yas int    ` + \\\"`json:\\\"yas\\\"`\\\" + `\\n}\\nfunc main() {\\n  k := K{Ad: \\\"Ali\\\", Yas: 25}\\n  j, _ := json.Marshal(k)\\n  fmt.Println(string(j))\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"os.File ile dosyaya yaz ve oku.\",\"response\":\"package main\\nimport (\\\"fmt\\\"; \\\"os\\\")\\nfunc main() {\\n  os.WriteFile(\\\"ornek.txt\\\", []byte(\\\"Merhaba Go!\\\\n\\\"), 0644)\\n  v, _ := os.ReadFile(\\\"ornek.txt\\\")\\n  fmt.Print(string(v))\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
