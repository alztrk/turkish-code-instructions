"{\"instruction\":\"fmt.Sprintf ile formatli string olustur.\",\"response\":\"package main\\nimport \\\"fmt\\\"\\nfunc main() {\\n  mesaj := fmt.Sprintf(\\\"Ben %s, %d yasindayim.\\\", \\\"Ali\\\", 25)\\n  fmt.Println(mesaj)\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"log paketi ile hata mesaji logla.\",\"response\":\"package main\\nimport (\\\"log\\\"; \\\"os\\\")\\nfunc main() {\\n  log.SetOutput(os.Stdout)\\n  log.SetPrefix(\\\"[APP] \\\")\\n  log.Println(\\\"Basladi\\\")\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"flag paketi ile CLI argumani olarak isim al.\",\"response\":\"package main\\nimport (\\\"flag\\\"; \\\"fmt\\\")\\nfunc main() {\\n  isim := flag.String(\\\"isim\\\", \\\"Dunya\\\", \\\"adiniz\\\")\\n  flag.Parse()\\n  fmt.Println(\\\"Merhaba\\\", *isim)\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"errors.Is ile hata kontrolu yap.\",\"response\":\"package main\\nimport (\\\"errors\\\"; \\\"fmt\\\")\\nvar ErrBul = errors.New(\\\"bulunamadi\\\")\\nfunc ara(d string) error {\\n  if d == \\\"\\\" { return fmt.Errorf(\\\"%w\\\", ErrBul) }\\n  return nil\\n}\\nfunc main() {\\n  if errors.Is(ara(\\\"\\\"), ErrBul) { fmt.Println(\\\"Hata alindi\\\") }\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"errors.As ile hata tipini kontrol et.\",\"response\":\"package main\\nimport (\\\"errors\\\"; \\\"fmt\\\")\\ntype DH struct{ Alan string }\\nfunc (e *DH) Error() string { return e.Alan }\\nfunc main() {\\n  err := fmt.Errorf(\\\"hata: %w\\\", &DH{Alan: \\\"email\\\"})\\n  var dh *DH\\n  if errors.As(err, &dh) { fmt.Println(\\\"Alan:\\\", dh.Alan) }\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"time.Since ile islemin suresini olc.\",\"response\":\"package main\\nimport (\\\"fmt\\\"; \\\"time\\\")\\nfunc main() {\\n  basla := time.Now()\\n  time.Sleep(200 * time.Millisecond)\\n  fmt.Println(\\\"Gecen:\\\", time.Since(basla))\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Map icinde anahtar var mi kontrol et (comma ok).\",\"response\":\"package main\\nimport \\\"fmt\\\"\\nfunc main() {\\n  y := map[string]int{\\\"Ali\\\": 25, \\\"Ayse\\\": 30}\\n  if v, ok := y[\\\"Ali\\\"]; ok { fmt.Println(v) }\\n  if _, ok := y[\\\"Veli\\\"]; !ok { fmt.Println(\\\"Veli yok\\\") }\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"defer ile dosyayi kapatma garanti altina al.\",\"response\":\"package main\\nimport (\\\"bufio\\\"; \\\"fmt\\\"; \\\"os\\\")\\nfunc main() {\\n  f, _ := os.Open(\\\"main.go\\\")\\n  defer f.Close()\\n  s := bufio.NewScanner(f)\\n  for s.Scan() { fmt.Println(s.Text()); break }\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"make ile slice olustur ve eleman ekle.\",\"response\":\"package main\\nimport \\\"fmt\\\"\\nfunc main() {\\n  s := make([]int, 3, 10)\\n  s[0]=10; s[1]=20; s[2]=30\\n  fmt.Println(s, len(s), cap(s))\\n  s = append(s, 40)\\n  fmt.Println(s)\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Bir slice icinde sayi ara ve indexini bul.\",\"response\":\"package main\\nimport \\\"fmt\\\"\\nfunc main() {\\n  s := []int{10,20,30,40,50}\\n  for i, v := range s { if v == 30 { fmt.Println(\\\"Index:\\\", i); break } }\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Fonksiyondan birden fazla deger dondur.\",\"response\":\"package main\\nimport \\\"fmt\\\"\\nfunc bolme(a,b int) (int, int) { return a/b, a%b }\\nfunc main() {\\n  bolum, kalan := bolme(17, 5)\\n  fmt.Printf(\\\"Bolum: %d, Kalan: %d\\\\n\\\", bolum, kalan)\\n}\",\"language\":\"go\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"COALESCE ile NULL degerleri varsayilan degerle degistir.\",\"response\":\"SELECT ad, COALESCE(email, 'belirtilmemis@email.com') AS email FROM kullanicis;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"NULLIF ile 0 bolme hatasini onle.\",\"response\":\"SELECT urun_adi, fiyat, 100.0 / NULLIF(fiyat, 0) AS oran FROM urunler;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"CAST ile sutunu farkli veri tipine cevir.\",\"response\":\"SELECT urun_id, CAST(fiyat AS DECIMAL(10,2)) AS ondalikli, CAST(tarih AS DATE) AS gun FROM satislar;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"CONCAT SUBSTRING LENGTH ile metin islemleri.\",\"response\":\"SELECT CONCAT(ad,' ',soyad) AS tam_ad, SUBSTRING(email,1,5) AS email_basi, LENGTH(telefon) AS tel_uzunluk FROM kullanicis;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"TRIM UPPER LOWER ile metin temizleme.\",\"response\":\"SELECT TRIM('  Merhaba  ') AS temiz, UPPER('merhaba') AS buyuk, LOWER('MERHABA') AS kucuk;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"DATE_FORMAT ile tarihi ozel formatta goster (MySQL).\",\"response\":\"SELECT siparis_tarihi, DATE_FORMAT(siparis_tarihi, '%d-%m-%Y') AS formatli FROM siparisler;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"EXTRACT ile tarihten yil ay gun al.\",\"response\":\"SELECT siparis_tarihi, EXTRACT(YEAR FROM siparis_tarihi) AS yil, EXTRACT(MONTH FROM siparis_tarihi) AS ay FROM siparisler;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"DATEDIFF ile iki tarih arasindaki gun farkini hesapla.\",\"response\":\"SELECT siparis_tarihi, teslimat_tarihi, DATEDIFF(teslimat_tarihi, siparis_tarihi) AS sure FROM siparisler;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"CASE ile urunleri fiyat araligina gore kategorilendir.\",\"response\":\"SELECT urun_adi, fiyat, CASE WHEN fiyat<50 THEN 'Ucuz' WHEN fiyat BETWEEN 50 AND 200 THEN 'Orta' ELSE 'Pahali' END AS kategori FROM urunler;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"UNION ve UNION ALL farkini goster.\",\"response\":\"SELECT sehir FROM musteri UNION SELECT sehir FROM tedarikci;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"EXISTS ile alt sorguda kayit var mi kontrol et.\",\"response\":\"SELECT m.* FROM musteri m WHERE EXISTS (SELECT 1 FROM siparis s WHERE s.musteri_id=m.musteri_id AND s.tutar>1000);\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"NOT EXISTS ile siparis vermemis musterileri bul.\",\"response\":\"SELECT ad, soyad FROM musteri m WHERE NOT EXISTS (SELECT 1 FROM siparis s WHERE s.musteri_id=m.musteri_id);\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"IN alt sorgusu ile belirli kategorileri getir.\",\"response\":\"SELECT urun_adi, fiyat FROM urunler WHERE kategori_id IN (SELECT kategori_id FROM kategoriler WHERE aktif=1);\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Correlated subquery ile son siparisi bul.\",\"response\":\"SELECT m.musteri_id, m.ad, (SELECT MAX(siparis_tarihi) FROM siparis s WHERE s.musteri_id=m.musteri_id) AS son FROM musteri m;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"INSERT...SELECT ile verileri baska tabloya ekle.\",\"response\":\"INSERT INTO arsiv_siparis SELECT siparis_id, musteri_id, tutar, siparis_tarihi FROM siparis WHERE siparis_tarihi<'2024-01-01';\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"MERGE UPSERT ile kayit varsa guncelle yoksa ekle.\",\"response\":\"INSERT INTO kullanicis (kullanici_id, ad, email) VALUES (1, 'Ali', 'a@o.c') ON CONFLICT (kullanici_id) DO UPDATE SET ad=EXCLUDED.ad;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"TRUNCATE ve DELETE farkini goster.\",\"response\":\"DELETE FROM gecici WHERE kayit_tarihi<'2024-01-01';\\nTRUNCATE TABLE gecici_kullanicis;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"ANY ve ALL ile karsilastirma yap.\",\"response\":\"SELECT urun_adi, fiyat FROM urunler WHERE fiyat > ANY (SELECT fiyat FROM urunler WHERE kategori_id=2);\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"WHERE IN ile listeye gore filtrele.\",\"response\":\"SELECT ad, email, sehir FROM kullanicis WHERE sehir IN ('Istanbul', 'Ankara', 'Izmir');\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"GROUP BY ile sehir bazinda sayi ORDER BY ile sirala.\",\"response\":\"SELECT sehir, COUNT(*) AS sayi FROM musteri GROUP BY sehir ORDER BY sayi DESC;\",\"language\":\"sql\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
