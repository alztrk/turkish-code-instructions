"{\"instruction\":\"fan-out pattern.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"sync\\\")\\nfunc main(){\\n  jobs:=make(chan int,5);var wg sync.WaitGroup\\n  for w:=1;w<=3;w++{wg.Add(1);go func(id int){defer wg.Done();for j:=range jobs{fmt.Println(id,j)}}(w)}\\n  for j:=1;j<=5;j++{jobs<-j};close(jobs);wg.Wait()\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"worker pool ornegi.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"sync\\\";\\\"time\\\")\\nfunc w(id int,j<-chan int,r chan<- int){\\n  for x:=range j{time.Sleep(time.Second);r<-x*2}\\n}\\nfunc main(){\\n  j:=make(chan int,5);r:=make(chan int,5)\\n  for i:=1;i<=3;i++{go w(i,j,r)}\\n  for i:=1;i<=5;i++{j<-i};close(j)\\n  for i:=1;i<=5;i++{fmt.Println(<-r)}\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
