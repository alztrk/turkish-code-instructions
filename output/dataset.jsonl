"{\"instruction\":\"Bir listedeki ogeleri Stream ile Set'e cevir.\",\"response\":\"import java.util.*;\\nimport java.util.stream.*;\\nList<String> liste = Arrays.asList(\\\"elma\\\",\\\"armut\\\",\\\"elma\\\",\\\"muz\\\",\\\"armut\\\");\\nSet<String> set = liste.stream().collect(Collectors.toSet());\\nSystem.out.println(set);\",\"language\":\"java\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Listedeki sayilarin karelerini alip 50'den buyuk olanlari Map'e cevir.\",\"response\":\"import java.util.*;\\nimport java.util.stream.*;\\nList<Integer> sayilar = Arrays.asList(5,6,7,8,9,10);\\nMap<Integer,Integer> kareMap = sayilar.stream().filter(s -> s*s > 50).collect(Collectors.toMap(s -> s, s -> s*s));\\nSystem.out.println(kareMap);\",\"language\":\"java\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
