"{\"instruction\":\"Veri Dogrulama Araci uygulamasi yap. Veri ekleme, silme, listeleme ve arama ozellikleri olsun. E-posta, telefon, URL gibi verileri dogrulayan uygulama.\",\"response\":\"const fs = require(\\\"fs\\\");\\nconst readline = require(\\\"readline\\\");\\nconst rl = readline.createInterface({ input: process.stdin, output: process.stdout });\\nconst dosya = \\\"veri_dogrulama_araci.json\\\";\\nlet veriler = [];\\nfunction yukle() {\\n    try { veriler = JSON.parse(fs.readFileSync(dosya, \\\"utf8\\\")); } catch(e) { veriler = []; }\\n}\\nfunction kaydet() { fs.writeFileSync(dosya, JSON.stringify(veriler, null, 2)); }\\nfunction ekle(deger) { veriler.push(deger); kaydet(); console.log(\\\"Eklendi:\\\", deger); menu(); }\\nfunction listele() { veriler.forEach((v, i) => console.log(i+1 + \\\".\\\", v)); menu(); }\\nfunction ara(kelime) {\\n    const sonuc = veriler.filter(v => v.toLowerCase().includes(kelime.toLowerCase()));\\n    console.log(sonuc.length + \\\" sonuc:\\\"); sonuc.forEach(s => console.log(\\\"  -\\\", s)); menu();\\n}\\nfunction sil(idx) {\\n    if (idx >= 0 && idx < veriler.length) {\\n        const silinen = veriler.splice(idx, 1); kaydet(); console.log(\\\"Silindi:\\\", silinen[0]);\\n    } else console.log(\\\"Gecersiz index\\\"); menu();\\n}\\nfunction menu() {\\n    rl.question(\\\"\\\\\\\\n1:Ekle 2:Listele 3:Ara 4:Sil 5:Cikis: \\\", secim => {\\n        if (secim === \\\"5\\\") return rl.close();\\n        else if (secim === \\\"1\\\") rl.question(\\\"Deger: \\\", d => { ekle(d); });\\n        else if (secim === \\\"2\\\") listele();\\n        else if (secim === \\\"3\\\") rl.question(\\\"Kelime: \\\", k => { ara(k); });\\n        else if (secim === \\\"4\\\") rl.question(\\\"Index: \\\", i => { sil(parseInt(i)-1); });\\n        else menu();\\n    });\\n}\\nyukle();\\nconsole.log(\\\"Veri Dogrulama Araci uygulamasi baslatildi.\\\");\\nmenu();\",\"language\":\"javascript\",\"category\":\"project\",\"type\":\"manual\",\"format\":\"project\"}"
