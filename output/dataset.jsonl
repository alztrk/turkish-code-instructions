"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef lev(a,b):\\n    m,n=len(a),len(b); dp=[[0]*(n+1) for _ in range(m+1)]\\n    for i in range(m+1): dp[i][0]=i\\n    for j in range(n+1): dp[0][j]=j\\n    for i in range(1,m+1):\\n        for j in range(1,n+1):\\n            if a[i-1]==b[j-1]: dp[i][j]=dp[i-1][j-1]\\n            else: dp[i][j]=1+min(dp[i-1][j],dp[i][j-1],dp[i-1][j-1])\\n    return dp[m][n]\",\"response\":\"def test_levenshtein():\\n    assert lev('kitten','sitting')==3\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
