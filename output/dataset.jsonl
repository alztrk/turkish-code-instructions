"{\"instruction\":\"SVD (Singular Value Decomposition) matris ayrismasi uygulayan fonksiyon yaz\",\"response\":\"public static void svdDecomposition(double[][] A) {\\n    Jama.SingularValueDecomposition svd = new Jama.SingularValueDecomposition(new Jama.Matrix(A));\\n    double[][] U = svd.getU().getArray();\\n    double[] S = svd.getSingularValues();\\n    double[][] Vt = svd.getV().transpose().getArray();\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"KD- agaci (KD-tree) veri yapisini uygulayan sinif yaz\",\"response\":\"class KDTreeNode:\\n    def __init__(self, point, left=None, right=None):\\n        self.point = point; self.left = left; self.right = right\\nclass KDTree:\\n    def __init__(self, points):\\n        self.k = len(points[0]) if points else 0\\n        self.root = self._build(points, 0)\\n    def _build(self, points, depth):\\n        if not points: return None\\n        axis = depth % self.k\\n        points.sort(key=lambda p: p[axis])\\n        mid = len(points) // 2\\n        return KDTreeNode(points[mid], self._build(points[:mid], depth+1), self._build(points[mid+1:], depth+1))\\n    def nearest(self, point, node=None, depth=0, best=None, best_dist=float('inf')):\\n        if node is None: node = self.root\\n        if node is None: return best, best_dist\\n        axis = depth % self.k\\n        dist = sum((point[i] - node.point[i])**2 for i in range(self.k))\\n        if dist < best_dist: best, best_dist = node.point, dist\\n        diff = point[axis] - node.point[axis]\\n        first, second = (node.left, node.right) if diff <= 0 else (node.right, node.left)\\n        best, best_dist = self.nearest(point, first, depth+1, best, best_dist)\\n        if diff**2 < best_dist:\\n            best, best_dist = self.nearest(point, second, depth+1, best, best_dist)\\n        return best, best_dist\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"KD- agaci (KD-tree) veri yapisini uygulayan sinif yaz\",\"response\":\"class KDTreeNode { constructor(point, left = null, right = null) { this.point = point; this.left = left; this.right = right; } }\\nclass KDTree {\\n    constructor(points) { this.k = points[0] ? points[0].length : 0; this.root = this.build(points, 0); }\\n    build(points, depth) {\\n        if (!points.length) return null;\\n        const axis = depth % this.k;\\n        points.sort((a, b) => a[axis] - b[axis]);\\n        const mid = Math.floor(points.length / 2);\\n        return new KDTreeNode(points[mid], this.build(points.slice(0, mid), depth + 1), this.build(points.slice(mid + 1), depth + 1));\\n    }\\n    nearest(point, node = this.root, depth = 0, best = null, bestDist = Infinity) {\\n        if (!node) return [best, bestDist];\\n        const axis = depth % this.k;\\n        const dist = point.reduce((s, v, i) => s + (v - node.point[i]) ** 2, 0);\\n        if (dist < bestDist) { best = node.point; bestDist = dist; }\\n        const diff = point[axis] - node.point[axis];\\n        const [first, second] = diff <= 0 ? [node.left, node.right] : [node.right, node.left];\\n        [best, bestDist] = this.nearest(point, first, depth + 1, best, bestDist);\\n        if (diff * diff < bestDist) [best, bestDist] = this.nearest(point, second, depth + 1, best, bestDist);\\n        return [best, bestDist];\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"KD- agaci (KD-tree) veri yapisini uygulayan sinif yaz\",\"response\":\"public class KDTree {\\n    private class Node { double[] point; Node left, right; Node(double[] p) { point = p; } }\\n    private Node root; private int k;\\n    public KDTree(double[][] points) { k = points[0].length; root = build(points, 0); }\\n    private Node build(double[][] points, int depth) {\\n        if (points.length == 0) return null;\\n        int axis = depth % k;\\n        Arrays.sort(points, Comparator.comparingDouble(p -> p[axis]));\\n        int mid = points.length / 2;\\n        Node node = new Node(points[mid]);\\n        node.left = build(Arrays.copyOfRange(points, 0, mid), depth + 1);\\n        node.right = build(Arrays.copyOfRange(points, mid + 1, points.length), depth + 1);\\n        return node;\\n    }\\n    public double[] nearest(double[] point) { return nearest(point, root, 0, null, Double.MAX_VALUE)[0]; }\\n    private Object[] nearest(double[] point, Node node, int depth, double[] best, double bestDist) {\\n        if (node == null) return new Object[]{best, bestDist};\\n        int axis = depth % k;\\n        double dist = 0; for (int i = 0; i < k; i++) dist += Math.pow(point[i] - node.point[i], 2);\\n        if (dist < bestDist) { best = node.point; bestDist = dist; }\\n        double diff = point[axis] - node.point[axis];\\n        Node first = diff <= 0 ? node.left : node.right;\\n        Node second = diff <= 0 ? node.right : node.left;\\n        var r = nearest(point, first, depth + 1, best, bestDist); best = (double[]) r[0]; bestDist = (double) r[1];\\n        if (diff * diff < bestDist) { r = nearest(point, second, depth + 1, best, bestDist); best = (double[]) r[0]; bestDist = (double) r[1]; }\\n        return new Object[]{best, bestDist};\\n    }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
