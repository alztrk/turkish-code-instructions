"{\"instruction\":\"time.NewTicker ile periyodik.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"time\\\")\\nfunc main(){\\n  t:=time.NewTicker(500*time.Millisecond)\\n  done:=make(chan bool)\\n  go func(){for i:=0;i<3;i++{fmt.Println(<-t.C)};done<-true}()\\n  <-done;t.Stop()\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"time.AfterFunc ile gecikmeli.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"time\\\")\\nfunc main(){\\n  fmt.Println(\\\"Basladi\\\")\\n  time.AfterFunc(time.Second,func(){fmt.Println(\\\"1sn\\\")})\\n  time.Sleep(2e9)\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"time.Parse ile string to time.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"time\\\")\\nfunc main(){\\n  t,_:=time.Parse(\\\"02/01/2006 15:04:05\\\",\\\"23/06/2025 14:30:00\\\")\\n  fmt.Println(t.Format(time.RFC3339))\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
