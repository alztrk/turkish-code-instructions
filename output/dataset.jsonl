"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef valid_isbn(isbn):\\n    d=isbn.replace('-','').replace(' ','')\\n    if len(d)!=10: return False\\n    t=0\\n    for i,ch in enumerate(d):\\n        if ch=='X' and i==9: t+=10*(10-i)\\n        elif ch.isdigit(): t+=int(ch)*(10-i)\\n        else: return False\\n    return t%11==0\",\"response\":\"def test_isbn():\\n    assert valid_isbn('0-306-40615-2')==True\\n    assert valid_isbn('0306406152')==True\\n    assert valid_isbn('1234567890')==False\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nfrom collections import Counter\\ndef first_non_rep(s):\\n    c=Counter(s)\\n    for ch in s:\\n        if c[ch]==1: return ch\\n    return None\",\"response\":\"def test_fnr():\\n    assert first_non_rep('leetcode')=='l'\\n    assert first_non_rep('aabbcc')==None\\n    assert first_non_rep('')==None\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
