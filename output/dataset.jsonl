"{\"instruction\":\"Bir tablodaki veriyi pivot yapan fonksiyon yaz\",\"response\":\"def pivot_islemi(data, satir, sutun, deger):\\n    s = {}\\n    for r in data:\\n        ri, si = r[satir], r[sutun]\\n        s.setdefault(ri, {})[si] = r[deger]\\n    return s\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
