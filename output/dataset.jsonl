"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/login\\\",methods=[\\\"POST\\\"])\\\\ndef login():\\\\n    u=authenticate(request.form[\\\"u\\\"],request.form[\\\"p\\\"])\\\\n    session[\\\"user\\\"]=u\\\\n    return \\\"ok\\\"\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\n@app.route(\\\"/login\\\",methods=[\\\"POST\\\"])\\\\ndef login():\\\\n    u=authenticate(request.form[\\\"u\\\"],request.form[\\\"p\\\"])\\\\n    session.clear()\\\\n    session[\\\"user\\\"]=u\\\\n    return \\\"ok\\\"\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/login\\\",(r,s)=>{const u=users.find(x=>x.u===r.body.u&&x.p===r.body.p);r.session.user=u;s.redirect(\\\"/\\\")})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.post(\\\"/login\\\",(r,s)=>{const u=users.find(x=>x.u===r.body.u);if(!u||!bcrypt.compareSync(r.body.p,u.p))return s.status(401).send(\\\"no\\\");r.session.regenerate(()=>{r.session.userId=u.id;s.redirect(\\\"/\\\")})})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```java\\n@PostMapping(\\\"/login\\\")String login(@RequestParam String u,@RequestParam String p,HttpSession s){User user=userService.auth(u,p);s.setAttribute(\\\"user\\\",user);return\\\"redirect:/\\\"}\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```java\\n@PostMapping(\\\"/login\\\")String login(@RequestParam String u,@RequestParam String p,HttpServletRequest r){User user=userService.auth(u,p);HttpSession s=r.getSession(false);if(s!=null)s.invalidate();s=r.getSession(true);s.setAttribute(\\\"user\\\",user);return\\\"redirect:/\\\"}\\n```\",\"language\":\"java\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```go\\nfunc login(w http.ResponseWriter,r*http.Request){u:=auth(r.FormValue(\\\"u\\\"),r.FormValue(\\\"p\\\"));s,_:=store.Get(r,\\\"s\\\");s.Values[\\\"u\\\"]=u;s.Save(r,w);http.Redirect(w,r,\\\"/\\\",302)}\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```go\\nfunc login(w http.ResponseWriter,r*http.Request){u:=auth(r.FormValue(\\\"u\\\"),r.FormValue(\\\"p\\\"));s,_:=store.New(r,\\\"s\\\");s.Values[\\\"u\\\"]=u;s.Save(r,w);http.Redirect(w,r,\\\"/\\\",302)}\\n```\",\"language\":\"go\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/login\\\",(r,s)=>{db.get(\\\"SELECT * FROM users WHERE username=?\\\",[r.body.u],(e,u)=>{if(u&&u.password===r.body.p){r.session.u=u.id;s.redirect(\\\"/d\\\")}else{s.send(\\\"no\\\")}})})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.post(\\\"/login\\\",(r,s)=>{db.get(\\\"SELECT * FROM users WHERE username=?\\\",[r.body.u],async(e,u)=>{if(u&&await bcrypt.compare(r.body.p,u.p)){r.session.u=u.id;s.redirect(\\\"/d\\\")}else{s.status(401).send(\\\"no\\\")}})})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\ndef login():\\\\n    if request.form[\\\"u\\\"]==\\\"admin\\\"and request.form[\\\"p\\\"]==\\\"admin123\\\":\\\\n        session[\\\"admin\\\"]=True\\\\n        return redirect(\\\"/admin\\\")\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\ndef login():\\\\n    u=db.execute(\\\"SELECT * FROM users WHERE username=?\\\",(request.form[\\\"u\\\"],)).fetchone()\\\\n    if u and bcrypt.checkpw(request.form[\\\"p\\\"].encode(),u[\\\"p\\\"]):\\\\n        session[\\\"uid\\\"]=u[\\\"id\\\"]\\\\n        session[\\\"is_admin\\\"]=u[\\\"is_admin\\\"]\\\\n        return redirect(\\\"/admin\\\" if u[\\\"is_admin\\\"]else \\\"/\\\")\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/reset\\\")\\\\ndef reset():\\\\n    t=token()\\\\n    l=f\\\"https://{request.host}/reset/{t}\\\"\\\\n    send_email(l)\\\\n    return \\\"ok\\\"\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\n@app.route(\\\"/reset\\\")\\\\ndef reset():\\\\n    t=token()\\\\n    h=request.headers.get(\\\"Host\\\",\\\"\\\")\\\\n    if h not in [\\\"x.com\\\",\\\"www.x.com\\\"]:h=\\\"x.com\\\"\\\\n    l=f\\\"https://{h}/reset/{t}\\\"\\\\n    send_email(l)\\\\n    return \\\"ok\\\"\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/reset\\\",(r,s)=>{const t=crypto.randomBytes(20).toString('hex');sendEmail(r.body.e,`http://${r.headers.host}/reset/${t}`);s.send('ok')})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.post(\\\"/reset\\\",(r,s)=>{const t=crypto.randomBytes(20).toString('hex');const h=r.headers.host;if(!['x.com','www.x.com'].includes(h))return s.status(400).send('no');sendEmail(r.body.e,`https://${h}/reset/${t}`);s.send('ok')})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```go\\nfunc reset(w http.ResponseWriter,r*http.Request){t:=genToken();l:=fmt.Sprintf(\\\"http://%s/reset/%s\\\",r.Host,t);sendEmail(r.FormValue(\\\"e\\\"),l);w.Write([]byte(\\\"ok\\\"))}\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```go\\nfunc reset(w http.ResponseWriter,r*http.Request){t:=genToken();h:=r.Host;if h!=\\\"x.com\\\"&&h!=\\\"www.x.com\\\"{h=\\\"x.com\\\"}l:=fmt.Sprintf(\\\"https://%s/reset/%s\\\",h,t);sendEmail(r.FormValue(\\\"e\\\"),l);w.Write([]byte(\\\"ok\\\"))}\\n```\",\"language\":\"go\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/\\\")\\\\ndef i():return render_template(\\\"i.html\\\")\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\n@app.after_request\\\\ndef h(r):r.headers[\\\"X-Frame-Options\\\"]=\\\"DENY\\\";return r\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.get(\\\"/\\\",(r,s)=>s.send('<h1>Merhaba</h1>'))\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.use((r,s,n)=>{s.setHeader('X-Frame-Options','DENY');n()});app.get(\\\"/\\\",(r,s)=>s.send('<h1>Merhaba</h1>'))\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```go\\nfunc main(){http.HandleFunc(\\\"/\\\",func(w http.ResponseWriter,r*http.Request){w.Write([]byte(\\\"<h1>Site</h1>\\\"))});http.ListenAndServe(\\\":8080\\\",nil)}\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```go\\nfunc click(n http.Handler)http.Handler{return http.HandlerFunc(func(w http.ResponseWriter,r*http.Request){w.Header().Set(\\\"X-Frame-Options\\\",\\\"DENY\\\");n.ServeHTTP(w,r)})}\\\\nfunc main(){m:=http.NewServeMux();m.Handle(\\\"/\\\",click(http.HandlerFunc(func(w http.ResponseWriter,r*http.Request){w.Write([]byte(\\\"<h1>Site</h1>\\\"))})));http.ListenAndServe(\\\":8080\\\",m)}\\n```\",\"language\":\"go\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/login\\\",async(r,s)=>{const{u,p}=r.body;const user=await db.collection('users').findOne({username:u,password:p});if(user)s.json({ok:1});else s.status(401).json({ok:0})})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.post(\\\"/login\\\",async(r,s)=>{const{u,p}=r.body;if(typeof u!='string'||typeof p!='string')return s.status(400).json({e:\\\"no\\\"});const user=await db.collection('users').findOne({username:u,password:p});if(user)s.json({ok:1});else s.status(401).json({ok:0})})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/search\\\",async(r,s)=>{const results=await db.collection('products').find({$where:`this.name.includes(\\\"${r.body.t}\\\")`}).toArray();s.json(results)})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.post(\\\"/search\\\",async(r,s)=>{if(typeof r.body.t!='string')return s.status(400).json({e:\\\"no\\\"});const results=await db.collection('products').find({name:{$regex:r.body.t,$options:'i'}}).toArray();s.json(results)})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/api/users\\\",async(r,s)=>{const users=await db.collection('users').find(r.body.q).toArray();s.json(users)})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.post(\\\"/api/users\\\",async(r,s)=>{const allowed=['name','email'];const q={};for(const k of Object.keys(r.body.q||{})){if(allowed.includes(k)&&typeof r.body.q[k]=='string')q[k]=r.body.q[k]}const users=await db.collection('users').find(q).toArray();s.json(users)})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.get(\\\"/user\\\",async(r,s)=>{const user=await db.collection('users').find({$where:`this.id==${r.query.id}`}).toArray();s.json(user)})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.get(\\\"/user\\\",async(r,s)=>{if(!/^[a-f0-9]{24}$/.test(r.query.id))return s.status(400).json({e:\\\"no\\\"});const user=await db.collection('users').findOne({_id:ObjectId(r.query.id)});s.json(user)})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/login\\\")\\\\ndef login():\\\\n    if check_login(request.form[\\\"u\\\"],request.form[\\\"p\\\"]):return \\\"ok\\\"\\\\n    return \\\"no\\\",401\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\nfrom flask_limiter import Limiter\\\\nlimiter=Limiter(app,key_func=lambda:request.remote_addr)\\\\n@app.route(\\\"/login\\\")\\\\n@limiter.limit(\\\"5/minute\\\")\\\\ndef login():\\\\n    if check_login(request.form[\\\"u\\\"],request.form[\\\"p\\\"]):return \\\"ok\\\"\\\\n    return \\\"no\\\",401\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/login\\\",(r,s)=>{const u=authenticate(r.body.u,r.body.p);if(u)s.json({t:createToken(u)});else s.status(401).json({e:\\\"no\\\"})})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\nconst rateLimit=require('express-rate-limit');const limiter=rateLimit({windowMs:60000,max:5,message:'cok fazla'});app.post(\\\"/login\\\",limiter,(r,s)=>{const u=authenticate(r.body.u,r.body.p);if(u)s.json({t:createToken(u)});else s.status(401).json({e:\\\"no\\\"})})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```java\\n@PostMapping(\\\"/login\\\")ResponseEntity<?>login(@RequestBody LoginRequest r){Optional<User>u=userService.auth(r.u,r.p);if(u.isPresent())return ResponseEntity.ok(new TokenResponse(generateToken(u.get())));return ResponseEntity.status(401).build()}\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```java\\n@PostMapping(\\\"/login\\\")@RateLimit(limit=5,duration=60)ResponseEntity<?>login(@RequestBody LoginRequest r){Optional<User>u=userService.auth(r.u,r.p);if(u.isPresent())return ResponseEntity.ok(new TokenResponse(generateToken(u.get())));return ResponseEntity.status(401).build()}\\n```\",\"language\":\"java\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```go\\nfunc login(w http.ResponseWriter,r*http.Request){u,err:=auth(r.FormValue(\\\"u\\\"),r.FormValue(\\\"p\\\"));if err!=nil{http.Error(w,\\\"no\\\",401);return}json.NewEncoder(w).Encode(map[string]string{\\\"t\\\":createToken(u)})}\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```go\\nimport \\\"golang.org/x/time/rate\\\"\\\\nvar l=rate.NewLimiter(5,1)\\\\nfunc login(w http.ResponseWriter,r*http.Request){if!l.Allow(){http.Error(w,\\\"cok fazla\\\",429);return}u,err:=auth(r.FormValue(\\\"u\\\"),r.FormValue(\\\"p\\\"));if err!=nil{http.Error(w,\\\"no\\\",401);return}json.NewEncoder(w).Encode(map[string]string{\\\"t\\\":createToken(u)})}\\n```\",\"language\":\"go\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/xml\\\",methods=[\\\"POST\\\"])\\\\ndef xml():\\\\n    return ET.tostring(ET.fromstring(request.data))\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\nfrom lxml import etree\\\\np=etree.XMLParser(resolve_entities=False,no_network=True)\\\\n@app.route(\\\"/xml\\\",methods=[\\\"POST\\\"])\\\\ndef xml():\\\\n    return etree.tostring(etree.fromstring(request.data,p))\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/xml\\\",(r,s)=>{new xml2js.Parser().parseString(r.body.x,(e,res)=>s.json(res))})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\nconst {XMLParser}=require('fast-xml-parser');const p=new XMLParser({processEntities:false});app.post(\\\"/xml\\\",(r,s)=>{s.json(p.parse(r.body.x))})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```java\\n@PostMapping(\\\"/xml\\\")String xml(@RequestBody String x)throws Exception{DocumentBuilder b=DocumentBuilderFactory.newInstance().newDocumentBuilder();return b.parse(new InputSource(new StringReader(x))).getDocumentElement().getTextContent()}\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```java\\n@PostMapping(\\\"/xml\\\")String xml(@RequestBody String x)throws Exception{DocumentBuilderFactory f=DocumentBuilderFactory.newInstance();f.setFeature(\\\"http://apache.org/xml/features/disallow-doctype-decl\\\",true);f.setFeature(\\\"http://xml.org/sax/features/external-general-entities\\\",false);return f.newDocumentBuilder().parse(new InputSource(new StringReader(x))).getDocumentElement().getTextContent()}\\n```\",\"language\":\"java\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\nfrom flask import render_template_string\\\\n@app.route(\\\"/h\\\")\\\\ndef h():n=request.args.get(\\\"n\\\");return render_template_string(f'<h1>{n}</h1>')\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\nfrom markupsafe import escape\\\\n@app.route(\\\"/h\\\")\\\\ndef h():n=request.args.get(\\\"n\\\");return render_template_string('<h1>{{n}}</h1>',n=escape(n))\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.get(\\\"/g\\\",(r,s)=>{s.send(`<h1>${r.query.n}</h1>`)})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\nconst esc=s=>s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');\\napp.get(\\\"/g\\\",(r,s)=>{s.send(`<h1>${esc(r.query.n)}</h1>`)})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/p\\\")\\\\ndef p():return render_template_string(request.args.get(\\\"t\\\"))\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\n@app.route(\\\"/p\\\")\\\\ndef p():t=request.args.get(\\\"t\\\");if t not in ['<h1>{{title}}</h1>']:return 'invalid',400;return render_template_string(t,title=\\\"x\\\")\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/upload\\\",methods=[\\\"POST\\\"])\\\\ndef up():f=request.files[\\\"f\\\"];f.save(f\\\"/uploads/{f.filename}\\\");return \\\"ok\\\"\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\nimport uuid,os\\\\nALLOWED={\\\"png\\\",\\\"jpg\\\",\\\"jpeg\\\",\\\"gif\\\"}\\\\n@app.route(\\\"/upload\\\",methods=[\\\"POST\\\"])\\\\ndef up():f=request.files[\\\"f\\\"];ext=f.filename.rsplit(\\\".\\\",1)[1].lower()if\\\".\\\"in f.filename else\\\"\\\";if ext not in ALLOWED:return \\\"no\\\",400;fn=f\\\"{uuid.uuid4()}.{ext}\\\";f.save(f\\\"/uploads/{fn}\\\");return \\\"ok\\\"\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.post(\\\"/upload\\\",upload.single('f'),(r,s)=>{fs.renameSync(r.file.path,'/uploads/'+r.file.originalname);s.send('ok')})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.post(\\\"/upload\\\",upload.single('f'),(r,s)=>{const ext=path.extname(r.file.originalname).toLowerCase();if(!['.png','.jpg','.jpeg'].includes(ext))return s.status(400).send('no');const n=uuid.v4()+ext;fs.renameSync(r.file.path,'/uploads/'+n);s.send('ok')})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```java\\n@PostMapping(\\\"/upload\\\")String up(@RequestParam MultipartFile f)throws IOException{f.transferTo(new File(\\\"/uploads/\\\"+f.getOriginalFilename()));return\\\"ok\\\"}\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```java\\n@PostMapping(\\\"/upload\\\")String up(@RequestParam MultipartFile f)throws IOException{String ext=StringUtils.getFilenameExtension(f.getOriginalFilename()).toLowerCase();if(!List.of(\\\"png\\\",\\\"jpg\\\",\\\"jpeg\\\").contains(ext))throw new IllegalArgumentException();f.transferTo(new File(\\\"/uploads/\\\"+UUID.randomUUID()+\\\".\\\"+ext));return\\\"ok\\\"}\\n```\",\"language\":\"java\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/avatar\\\",methods=[\\\"POST\\\"])\\\\ndef av():f=request.files[\\\"a\\\"];f.save(f\\\"avatars/{f.filename}\\\");return \\\"ok\\\"\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\nimport uuid\\\\nALLOWED={\\\"png\\\",\\\"jpg\\\",\\\"jpeg\\\"}\\\\n@app.route(\\\"/avatar\\\",methods=[\\\"POST\\\"])\\\\ndef av():f=request.files[\\\"a\\\"];ext=f.filename.rsplit(\\\".\\\",1)[1].lower()if\\\".\\\"in f.filename else\\\"\\\";if ext not in ALLOWED or len(f.read())>5*1024*1024:return \\\"no\\\",400;f.seek(0);fn=f\\\"{uuid.uuid4()}.{ext}\\\";f.save(f\\\"avatars/{fn}\\\");return \\\"ok\\\"\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```python\\n@app.route(\\\"/api/user/update\\\",methods=[\\\"POST\\\"])\\\\ndef up():data=request.json;user=current_user;user.name=data.get(\\\"name\\\",user.name);user.email=data.get(\\\"email\\\",user.email);user.role=data.get(\\\"role\\\",user.role);db.commit();return \\\"ok\\\"\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```python\\n@app.route(\\\"/api/user/update\\\",methods=[\\\"POST\\\"])\\\\ndef up():data=request.json;user=current_user;user.name=data.get(\\\"name\\\",user.name);user.email=data.get(\\\"email\\\",user.email);db.commit();return \\\"ok\\\"  # role alanini kaldir\\n```\",\"language\":\"python\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
"{\"instruction\":\"Bu kodda guvenlik acigi var mi? Coz:\\n```javascript\\napp.put(\\\"/api/user\\\",(r,s)=>{db.run(\\\"UPDATE users SET name=?,email=?,role=? WHERE id=?\\\",[r.body.n,r.body.e,r.body.r,r.user.id]);s.json({ok:1})})\\n```\",\"response\":\"Guvenlik acigi var. Cozumu:\\n```javascript\\napp.put(\\\"/api/user\\\",(r,s)=>{const{n,e}=r.body;db.run(\\\"UPDATE users SET name=?,email=? WHERE id=?\\\",[n,e,r.user.id]);s.json({ok:1})})\\n```\",\"language\":\"javascript\",\"category\":\"security\",\"type\":\"manual\",\"format\":\"security\"}"
