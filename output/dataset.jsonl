"{\"instruction\":\"Suffix array veri yapisini uygulayan fonksiyon yaz\",\"response\":\"func SuffixArray(s string) []int {\\n    n := len(s); sa := make([]int, n)\\n    for i := 0; i < n; i++ { sa[i] = i }\\n    sort.Slice(sa, func(i, j int) bool { return s[sa[i]:] < s[sa[j]:] })\\n    return sa\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ikili agaci (binary tree) dizi ile temsil eden sinif yaz\",\"response\":\"class BinaryTree:\\n    def __init__(self, capacity=16):\\n        self.tree = [None] * capacity; self.capacity = capacity\\n    def insert(self, val, idx=0):\\n        if idx >= self.capacity:\\n            self.capacity *= 2; self.tree.extend([None] * self.capacity)\\n        if self.tree[idx] is None: self.tree[idx] = val; return True\\n        if val < self.tree[idx]: return self.insert(val, 2 * idx + 1)\\n        else: return self.insert(val, 2 * idx + 2)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ikili agaci (binary tree) dizi ile temsil eden sinif yaz\",\"response\":\"class BinaryTree {\\n    constructor(capacity = 16) { this.tree = new Array(capacity).fill(null); this.capacity = capacity; }\\n    insert(val, idx = 0) {\\n        if (idx >= this.capacity) { this.capacity *= 2; this.tree = this.tree.concat(new Array(this.capacity).fill(null)); }\\n        if (this.tree[idx] === null) { this.tree[idx] = val; return true; }\\n        if (val < this.tree[idx]) return this.insert(val, 2 * idx + 1); else return this.insert(val, 2 * idx + 2);\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ikili agaci (binary tree) dizi ile temsil eden sinif yaz\",\"response\":\"type BinaryTree struct { tree []*int; capacity int }\\nfunc NewBinaryTree(capacity int) *BinaryTree { return &BinaryTree{tree: make([]*int, capacity), capacity: capacity} }\\nfunc (bt *BinaryTree) Insert(val int, idx int) bool {\\n    if idx >= bt.capacity { bt.capacity *= 2; newTree := make([]*int, bt.capacity); copy(newTree, bt.tree); bt.tree = newTree }\\n    if bt.tree[idx] == nil { bt.tree[idx] = &val; return true }\\n    if val < *bt.tree[idx] { return bt.Insert(val, 2*idx+1) }; return bt.Insert(val, 2*idx+2)\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rolling hash (kayan hash) fonksiyonu uygulayan sinif yaz\",\"response\":\"class RollingHash:\\n    def __init__(self, base=256, mod=101):\\n        self.base = base; self.mod = mod; self.hash = 0; self.power = 1\\n    def append(self, ch):\\n        self.hash = (self.hash * self.base + ord(ch)) % self.mod\\n        self.power = (self.power * self.base) % self.mod\\n    def skip(self, ch, n):\\n        self.hash = (self.hash - ord(ch) * self.power + self.mod * self.mod) % self.mod\\n    def get_hash(self): return self.hash\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rolling hash (kayan hash) fonksiyonu uygulayan sinif yaz\",\"response\":\"class RollingHash {\\n    constructor(base = 256, mod = 101) { this.base = base; this.mod = mod; this.hash = 0; this.power = 1; }\\n    append(ch) { this.hash = (this.hash * this.base + ch.charCodeAt(0)) % this.mod; this.power = (this.power * this.base) % this.mod; }\\n    skip(ch, n) { this.hash = (this.hash - ch.charCodeAt(0) * this.power % this.mod + this.mod) % this.mod; }\\n    getHash() { return this.hash; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rolling hash (kayan hash) fonksiyonu uygulayan sinif yaz\",\"response\":\"type RollingHash struct { base, mod, hash, power int }\\nfunc NewRollingHash(base, mod int) *RollingHash { return &RollingHash{base: base, mod: mod, power: 1} }\\nfunc (rh *RollingHash) Append(ch byte) { rh.hash = (rh.hash*rh.base + int(ch)) % rh.mod; rh.power = (rh.power * rh.base) % rh.mod }\\nfunc (rh *RollingHash) Skip(ch byte, n int) { rh.hash = (rh.hash - int(ch)*rh.power%rh.mod + rh.mod) % rh.mod }\\nfunc (rh *RollingHash) GetHash() int { return rh.hash }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Aralik agaci (interval tree) veri yapisini uygulayan sinif yaz\",\"response\":\"class IntervalNode:\\n    def __init__(self, interval): self.interval = interval; self.max = interval[1]; self.left = None; self.right = None\\nclass IntervalTree:\\n    def __init__(self): self.root = None\\n    def insert(self, interval, node=None):\\n        if node is None:\\n            if self.root is None: self.root = IntervalNode(interval); return\\n            node = self.root\\n        if interval[0] < node.interval[0]:\\n            if node.left: self.insert(interval, node.left)\\n            else: node.left = IntervalNode(interval)\\n        else:\\n            if node.right: self.insert(interval, node.right)\\n            else: node.right = IntervalNode(interval)\\n        node.max = max(node.max, interval[1])\\n    def overlap(self, interval, node=None):\\n        if node is None: node = self.root\\n        if node is None: return None\\n        if interval[0] <= node.interval[1] and node.interval[0] <= interval[1]: return node.interval\\n        if node.left and node.left.max >= interval[0]: return self.overlap(interval, node.left)\\n        return self.overlap(interval, node.right)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Aralik agaci (interval tree) veri yapisini uygulayan sinif yaz\",\"response\":\"class IntervalNode { constructor(interval) { this.interval = interval; this.max = interval[1]; this.left = null; this.right = null; } }\\nclass IntervalTree {\\n    constructor() { this.root = null; }\\n    insert(interval, node = this.root) {\\n        if (!this.root) { this.root = new IntervalNode(interval); return; }\\n        if (!node) { node = this.root; }\\n        if (interval[0] < node.interval[0]) { if (node.left) this.insert(interval, node.left); else node.left = new IntervalNode(interval); }\\n        else { if (node.right) this.insert(interval, node.right); else node.right = new IntervalNode(interval); }\\n        node.max = Math.max(node.max, interval[1]);\\n    }\\n    overlap(interval, node = this.root) {\\n        if (!node) return null;\\n        if (interval[0] <= node.interval[1] && node.interval[0] <= interval[1]) return node.interval;\\n        if (node.left && node.left.max >= interval[0]) return this.overlap(interval, node.left);\\n        return this.overlap(interval, node.right);\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Aralik agaci (interval tree) veri yapisini uygulayan sinif yaz\",\"response\":\"type IntervalNode struct { interval [2]int; max int; left, right *IntervalNode }\\ntype IntervalTree struct { root *IntervalNode }\\nfunc (t *IntervalTree) Insert(interval [2]int) {\\n    node := &IntervalNode{interval: interval, max: interval[1]}\\n    if t.root == nil { t.root = node; return }\\n    curr := t.root\\n    for {\\n        if interval[0] < curr.interval[0] {\\n            if curr.left == nil { curr.left = node; break }; curr = curr.left\\n        } else {\\n            if curr.right == nil { curr.right = node; break }; curr = curr.right\\n        }\\n    }\\n    for curr != nil { if interval[1] > curr.max { curr.max = interval[1] }; curr = nil }\\n}\\nfunc (t *IntervalTree) Overlap(interval [2]int) *[2]int {\\n    node := t.root\\n    for node != nil {\\n        if interval[0] <= node.interval[1] && node.interval[0] <= interval[1] { return &node.interval }\\n        if node.left != nil && node.left.max >= interval[0] { node = node.left } else { node = node.right }\\n    }\\n    return nil\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"R- agaci (R-tree) uzamsal veri yapisini uygulayan basit sinif yaz\",\"response\":\"class RTreeNode:\\n    def __init__(self, leaf=True): self.leaf = leaf; self.entries = []; self.bbox = None\\nclass RTree:\\n    def __init__(self, max_entries=4): self.root = RTreeNode(); self.max_entries = max_entries\\n    def insert(self, point, node=None):\\n        if node is None: node = self.root\\n        if node.leaf: node.entries.append(point); node.bbox = self._update_bbox(node)\\n        else:\\n            best = min(range(len(node.entries)), key=lambda i: self._bbox_area(node.entries[i]))\\n            self.insert(point, node.entries[best])\\n            node.bbox = self._update_bbox(node)\\n    def _update_bbox(self, node):\\n        if not node.entries: return None\\n        pts = node.entries\\n        return [min(p[0] for p in pts), min(p[1] for p in pts), max(p[0] for p in pts), max(p[1] for p in pts)]\\n    def _bbox_area(self, node): return (node.bbox[2]-node.bbox[0])*(node.bbox[3]-node.bbox[1]) if node.bbox else 0\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"R- agaci (R-tree) uzamsal veri yapisini uygulayan basit sinif yaz\",\"response\":\"class RTreeNode { constructor(leaf = true) { this.leaf = leaf; this.entries = []; this.bbox = null; } }\\nclass RTree {\\n    constructor(maxEntries = 4) { this.root = new RTreeNode(); this.maxEntries = maxEntries; }\\n    insert(point, node = this.root) {\\n        if (node.leaf) { node.entries.push(point); node.bbox = this.updateBBox(node); }\\n        else { const best = node.entries.reduce((a, b, i) => this.bboxArea(a) <= this.bboxArea(b) ? a : b); this.insert(point, best); node.bbox = this.updateBBox(node); }\\n    }\\n    updateBBox(node) { if (!node.entries.length) return null; const pts = node.entries; return [Math.min(...pts.map(p => p[0])), Math.min(...pts.map(p => p[1])), Math.max(...pts.map(p => p[0])), Math.max(...pts.map(p => p[1]))]; }\\n    bboxArea(node) { const b = node.bbox; return b ? (b[2] - b[0]) * (b[3] - b[1]) : 0; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"R- agaci (R-tree) uzamsal veri yapisini uygulayan basit sinif yaz\",\"response\":\"type RTreeNode struct { leaf bool; entries [][2]float64; bbox [4]float64 }\\ntype RTree struct { root *RTreeNode; maxEntries int }\\nfunc NewRTree(maxEntries int) *RTree { return &RTree{root: &RTreeNode{leaf: true}, maxEntries: maxEntries} }\\nfunc (t *RTree) Insert(point [2]float64, node *RTreeNode) {\\n    if node == nil { node = t.root }\\n    if node.leaf { node.entries = append(node.entries, point); t.updateBBox(node); return }\\n    bestIdx := 0; bestArea := t.bboxArea(node)\\n    for i := range node.entries { if area := t.bboxArea(&node.entries[i]); area < bestArea { bestIdx = i; bestArea = area } }\\n    t.Insert(point, &node.entries[bestIdx])\\n    t.updateBBox(node)\\n}\\nfunc (t *RTree) updateBBox(node *RTreeNode) {\\n    if len(node.entries) == 0 { return }\\n    minX, minY, maxX, maxY := node.entries[0][0], node.entries[0][1], node.entries[0][0], node.entries[0][1]\\n    for _, p := range node.entries { if p[0] < minX { minX = p[0] }; if p[1] < minY { minY = p[1] }; if p[0] > maxX { maxX = p[0] }; if p[1] > maxY { maxY = p[1] } }\\n    node.bbox = [4]float64{minX, minY, maxX, maxY}\\n}\\nfunc (t *RTree) bboxArea(node *RTreeNode) float64 { return (node.bbox[2] - node.bbox[0]) * (node.bbox[3] - node.bbox[1]) }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ters indeks (inverted index) veri yapisini uygulayan sinif yaz\",\"response\":\"from collections import defaultdict\\nclass InvertedIndex:\\n    def __init__(self): self.index = defaultdict(set)\\n    def add(self, doc_id, text):\\n        for word in text.lower().split(): self.index[word].add(doc_id)\\n    def search(self, query):\\n        result = None\\n        for word in query.lower().split():\\n            if word in self.index:\\n                if result is None: result = self.index[word].copy()\\n                else: result &= self.index[word]\\n        return result if result else set()\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ters indeks (inverted index) veri yapisini uygulayan sinif yaz\",\"response\":\"class InvertedIndex {\\n    constructor() { this.index = {}; }\\n    add(docId, text) { for (const word of text.toLowerCase().split(/\\\\s+/)) { if (!this.index[word]) this.index[word] = new Set(); this.index[word].add(docId); } }\\n    search(query) {\\n        let result = null;\\n        for (const word of query.toLowerCase().split(/\\\\s+/)) {\\n            if (this.index[word]) { if (result === null) result = new Set(this.index[word]); else result = new Set([...result].filter(x => this.index[word].has(x))); }\\n        }\\n        return result || new Set();\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ters indeks (inverted index) veri yapisini uygulayan sinif yaz\",\"response\":\"type InvertedIndex struct { index map[string]map[int]bool }\\nfunc NewInvertedIndex() *InvertedIndex { return &InvertedIndex{index: make(map[string]map[int]bool)} }\\nfunc (ii *InvertedIndex) Add(docID int, text string) {\\n    for _, word := range strings.Fields(strings.ToLower(text)) {\\n        if ii.index[word] == nil { ii.index[word] = make(map[int]bool) }\\n        ii.index[word][docID] = true\\n    }\\n}\\nfunc (ii *InvertedIndex) Search(query string) map[int]bool {\\n    var result map[int]bool\\n    for _, word := range strings.Fields(strings.ToLower(query)) {\\n        if docs, ok := ii.index[word]; ok {\\n            if result == nil { result = make(map[int]bool); for k := range docs { result[k] = true } }\\n            else { for k := range result { if !docs[k] { delete(result, k) } } }\\n        }\\n    }\\n    if result == nil { return make(map[int]bool) }; return result\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Birlestir-sirala-farkli (merge sort unique) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def merge_unique(arr1, arr2):\\n    result = []; i = j = 0\\n    while i < len(arr1) and j < len(arr2):\\n        if arr1[i] < arr2[j]:\\n            if not result or result[-1] != arr1[i]: result.append(arr1[i])\\n            i += 1\\n        elif arr1[i] > arr2[j]:\\n            if not result or result[-1] != arr2[j]: result.append(arr2[j])\\n            j += 1\\n        else:\\n            if not result or result[-1] != arr1[i]: result.append(arr1[i])\\n            i += 1; j += 1\\n    while i < len(arr1):\\n        if not result or result[-1] != arr1[i]: result.append(arr1[i])\\n        i += 1\\n    while j < len(arr2):\\n        if not result or result[-1] != arr2[j]: result.append(arr2[j])\\n        j += 1\\n    return result\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Birlestir-sirala-farkli (merge sort unique) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function mergeUnique(arr1, arr2) {\\n    const result = []; let i = 0, j = 0;\\n    while (i < arr1.length && j < arr2.length) {\\n        if (arr1[i] < arr2[j]) { if (!result.length || result[result.length-1] !== arr1[i]) result.push(arr1[i]); i++; }\\n        else if (arr1[i] > arr2[j]) { if (!result.length || result[result.length-1] !== arr2[j]) result.push(arr2[j]); j++; }\\n        else { if (!result.length || result[result.length-1] !== arr1[i]) result.push(arr1[i]); i++; j++; }\\n    }\\n    while (i < arr1.length) { if (!result.length || result[result.length-1] !== arr1[i]) result.push(arr1[i]); i++; }\\n    while (j < arr2.length) { if (!result.length || result[result.length-1] !== arr2[j]) result.push(arr2[j]); j++; }\\n    return result;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Birlestir-sirala-farkli (merge sort unique) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func MergeUnique(arr1, arr2 []int) []int {\\n    var result []int; i, j := 0, 0\\n    for i < len(arr1) && j < len(arr2) {\\n        if arr1[i] < arr2[j] {\\n            if len(result) == 0 || result[len(result)-1] != arr1[i] { result = append(result, arr1[i]) }; i++\\n        } else if arr1[i] > arr2[j] {\\n            if len(result) == 0 || result[len(result)-1] != arr2[j] { result = append(result, arr2[j]) }; j++\\n        } else {\\n            if len(result) == 0 || result[len(result)-1] != arr1[i] { result = append(result, arr1[i]) }; i++; j++\\n        }\\n    }\\n    for i < len(arr1) { if len(result) == 0 || result[len(result)-1] != arr1[i] { result = append(result, arr1[i]) }; i++ }\\n    for j < len(arr2) { if len(result) == 0 || result[len(result)-1] != arr2[j] { result = append(result, arr2[j]) }; j++ }\\n    return result\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Insertion sort algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def insertion_sort(arr):\\n    for i in range(1, len(arr)):\\n        key = arr[i]; j = i - 1\\n        while j >= 0 and arr[j] > key: arr[j + 1] = arr[j]; j -= 1\\n        arr[j + 1] = key\\n    return arr\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
