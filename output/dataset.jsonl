"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef spiral(n):\\n    m=[[0]*n for _ in range(n)]\\n    t,b,l,r=0,n-1,0,n-1; d=1\\n    while t<=b and l<=r:\\n        for i in range(l,r+1): m[t][i]=d; d+=1\\n        t+=1\\n        for i in range(t,b+1): m[i][r]=d; d+=1\\n        r-=1\\n        for i in range(r,l-1,-1): m[b][i]=d; d+=1\\n        b-=1\\n        for i in range(b,t-1,-1): m[i][l]=d; d+=1\\n        l+=1\\n    return m\",\"response\":\"def test_spiral():\\n    r=spiral(3); assert r[0][0]==1 and r[0][2]==3 and r[2][0]==7\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
