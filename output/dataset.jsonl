"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nimport json\\ndef is_json(s):\\n    try: json.loads(s); return True\\n    except: return False\",\"response\":\"def test_json_v():\\n    assert is_json('{\\\"name\\\":\\\"Ali\\\"}')==True\\n    assert is_json('[1,2,3]')==True\\n    assert is_json('{invalid}')==False\\n    assert is_json('')==False\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
