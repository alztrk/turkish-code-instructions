"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef fact_i(n):\\n    if n<0: raise ValueError('Neg')\\n    r=1\\n    for i in range(2,n+1): r*=i\\n    return r\",\"response\":\"def test_fact_i():\\n    assert fact_i(0)==1 and fact_i(5)==120\\n    import pytest\\n    with pytest.raises(ValueError): fact_i(-1)\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
