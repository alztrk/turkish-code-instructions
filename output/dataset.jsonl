"{\"instruction\":\"Semaphore ile kaynak sinirlama.\",\"response\":\"import java.util.concurrent.*;\\nSemaphore sem=new Semaphore(2);\\nfor(int i=0;i<3;i++){\\n  int id=i;\\n  new Thread(()->{try{sem.acquire();System.out.println(id);sem.release();}catch(Exception e){}}).start();\\n}\",\"language\":\"java\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
