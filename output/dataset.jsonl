"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef fact(n):\\n    if n<0: raise ValueError('Neg')\\n    return 1 if n<=1 else n*fact(n-1)\",\"response\":\"def test_factorial():\\n    assert fact(0)==1\\n    assert fact(5)==120\\n    assert fact(10)==3628800\\n    import pytest\\n    with pytest.raises(ValueError): fact(-1)\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef fib(n):\\n    if n<0: raise ValueError('Neg')\\n    return n if n<=1 else fib(n-1)+fib(n-2)\",\"response\":\"def test_fibonacci():\\n    assert fib(0)==0\\n    assert fib(1)==1\\n    assert fib(10)==55\\n    assert fib(20)==6765\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef is_prime(n):\\n    if n<2: return False\\n    for i in range(2,int(n**0.5)+1):\\n        if n%i==0: return False\\n    return True\",\"response\":\"def test_is_prime():\\n    assert is_prime(2)==True\\n    assert is_prime(17)==True\\n    assert is_prime(1)==False\\n    assert is_prime(4)==False\\n    assert is_prime(97)==True\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef gcd(a,b):\\n    while b: a,b=b,a%b\\n    return a\",\"response\":\"def test_gcd():\\n    assert gcd(12,8)==4\\n    assert gcd(17,5)==1\\n    assert gcd(0,5)==5\\n    assert gcd(48,18)==6\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef lcm(a,b): return a*b//gcd(a,b)\\ndef gcd(a,b):\\n    while b: a,b=b,a%b\\n    return a\",\"response\":\"def test_lcm():\\n    assert lcm(4,6)==12\\n    assert lcm(3,5)==15\\n    assert lcm(0,5)==0\\n    assert lcm(12,18)==36\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
