"{\"instruction\":\"Not Defteri uygulamasi yap. Kullanici not ekleyebilmeli, silebilmeli ve listeleyebilmeli.\",\"response\":\"class NotDefteri {\\n    constructor() { this.veriler = []; }\\n    ekle(deger) { this.veriler.push(deger); }\\n    listele() { this.veriler.forEach((v, i) => console.log((i+1) + '. ' + v)); }\\n    ara(kelime) { return this.veriler.filter(v => v.toLowerCase().includes(kelime.toLowerCase())); }\\n}\\nconst uyg = new NotDefteri();\\nuyg.ekle('Ornek 1'); uyg.ekle('Ornek 2');\\nuyg.listele(); console.log('Arama:', uyg.ara('ornek'));\",\"language\":\"javascript\",\"category\":\"project\",\"type\":\"manual\",\"format\":\"project\"}"
