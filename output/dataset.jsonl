"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nimport re\\ndef to_camel(s):\\n    w=re.split(r'[-_\\\\s]',s)\\n    return w[0].lower()+''.join(x.capitalize() for x in w[1:])\",\"response\":\"def test_to_camel():\\n    assert to_camel('hello-world')=='helloWorld'\\n    assert to_camel('merhaba_dunya')=='merhabaDunya'\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
