"{\"instruction\":\"select ile channel secimi.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"time\\\")\\nfunc main(){\\n  c1:=make(chan string);c2:=make(chan string)\\n  go func(){time.Sleep(1e9);c1<-\\\"bir\\\"}()\\n  go func(){time.Sleep(2e9);c2<-\\\"iki\\\"}()\\n  select{\\n  case m:=<-c1:fmt.Println(m)\\n  case m:=<-c2:fmt.Println(m)\\n  case<-time.After(3e9):fmt.Println(\\\"timeout\\\")\\n  }\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
