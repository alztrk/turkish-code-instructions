"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nimport copy\\ndef deep_c(obj): return copy.deepcopy(obj)\",\"response\":\"def test_clone():\\n    o={'a':[1,2,3],'b':{'c':4}}\\nc=deep_c(o)\\nassert c==o\\nc['a'].append(4)\\nassert o['a']==[1,2,3]\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef memo(fn):\\n    c={}\\n    def w(*a):\\n        if a not in c: c[a]=fn(*a)\\n        return c[a]\\n    return w\",\"response\":\"def test_memo():\\n    cc=0\\n@memo\\ndef add(a,b):\\n    nonlocal cc; cc+=1; return a+b\\nassert add(2,3)==5\\nassert add(2,3)==5\\nassert cc==1\\nassert add(3,4)==7\\nassert cc==2\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nimport time\\ndef retry(fn,mr=3,d=0.1):\\n    for i in range(mr):\\n        try: return fn()\\n        except:\\n            if i==mr-1: raise\\n            time.sleep(d)\",\"response\":\"def test_retry():\\n    from unittest.mock import Mock\\nfn=Mock(side_effect=[ValueError,ValueError,'success'])\\nassert retry(fn,mr=3,d=0.01)=='success'\\nassert fn.call_count==3\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nclass RateLimiter:\\n    def __init__(s,mc,p): s.max_calls=mc; s.period=p; s.calls=[]\\n    def allow(s):\\n        import time; n=time.time()\\n        s.calls=[c for c in s.calls if n-c<s.period]\\n        if len(s.calls)>=s.max_calls: return False\\n        s.calls.append(n); return True\",\"response\":\"def test_rate():\\n    rl=RateLimiter(2,10)\\nassert rl.allow()==True and rl.allow()==True and rl.allow()==False\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nclass LRUCache:\\n    def __init__(s,cap): s.cap=cap; s.cache={}; s.order=[]\\n    def get(s,k):\\n        if k in s.cache: s.order.remove(k); s.order.append(k); return s.cache[k]\\n        return -1\\n    def put(s,k,v):\\n        if k in s.cache: s.order.remove(k)\\n        elif len(s.cache)>=s.cap: o=s.order.pop(0); del s.cache[o]\\n        s.cache[k]=v; s.order.append(k)\",\"response\":\"def test_lru():\\n    c=LRUCache(2)\\nc.put(1,1);c.put(2,2)\\nassert c.get(1)==1\\nc.put(3,3); assert c.get(2)==-1\\nc.put(4,4); assert c.get(1)==-1; assert c.get(3)==3\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef mat_mul(A,B):\\n    n=len(A); m=len(A[0]); p=len(B[0])\\n    r=[[0]*p for _ in range(n)]\\n    for i in range(n):\\n        for j in range(p):\\n            for k in range(m): r[i][j]+=A[i][k]*B[k][j]\\n    return r\",\"response\":\"def test_mat_mul():\\n    A=[[1,2],[3,4]]; B=[[5,6],[7,8]]\\nassert mat_mul(A,B)==[[19,22],[43,50]]\\nassert mat_mul([[1,2,3]],[[4],[5],[6]])==[[32]]\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef dot_p(v1,v2): return sum(a*b for a,b in zip(v1,v2))\",\"response\":\"def test_dot():\\n    assert dot_p([1,2,3],[4,5,6])==32\\n    assert dot_p([0,0],[1,2])==0\\n    assert dot_p([-1,1],[-1,1])==2\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef vec_add(v1,v2): return [a+b for a,b in zip(v1,v2)]\",\"response\":\"def test_vec_add():\\n    assert vec_add([1,2],[3,4])==[4,6]\\n    assert vec_add([-1,0],[1,0])==[0,0]\\n    assert vec_add([],[])==[]\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
