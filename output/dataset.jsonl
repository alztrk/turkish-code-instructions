"{\"instruction\":\"Builder (insa edici) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Product struct { parts []string }; func (p *Product) Add(part string) { p.parts = append(p.parts, part) }; func (p Product) Show() string { return strings.Join(p.parts, \\\", \\\") }\\ntype Builder interface { BuildPartA(); BuildPartB(); GetResult() Product }\\ntype ConcreteBuilder struct { product Product }; func (b *ConcreteBuilder) BuildPartA() { b.product.Add(\\\"PartA\\\") }; func (b *ConcreteBuilder) BuildPartB() { b.product.Add(\\\"PartB\\\") }; func (b *ConcreteBuilder) GetResult() Product { return b.product }\\ntype Director struct { builder Builder }; func (d Director) Construct() Product { d.builder.BuildPartA(); d.builder.BuildPartB(); return d.builder.GetResult() }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Chain of responsibility (sorumluluk zinciri) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Handler:\\n    def __init__(self): self.next = None\\n    def set_next(self, handler): self.next = handler; return handler\\n    def handle(self, request):\\n        if self.next: return self.next.handle(request)\\n        return None\\nclass ConcreteHandlerA(Handler):\\n    def handle(self, request):\\n        if request == 'A': return 'Handled by A'\\n        return super().handle(request)\\nclass ConcreteHandlerB(Handler):\\n    def handle(self, request):\\n        if request == 'B': return 'Handled by B'\\n        return super().handle(request)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Chain of responsibility (sorumluluk zinciri) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Handler { constructor() { this.next = null; } setNext(handler) { this.next = handler; return handler; } handle(request) { if (this.next) return this.next.handle(request); return null; } }\\nclass ConcreteHandlerA extends Handler { handle(request) { if (request === 'A') return 'Handled by A'; return super.handle(request); } }\\nclass ConcreteHandlerB extends Handler { handle(request) { if (request === 'B') return 'Handled by B'; return super.handle(request); } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Chain of responsibility (sorumluluk zinciri) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Handler interface{ SetNext(Handler) Handler; Handle(string) string }\\ntype BaseHandler struct { next Handler }\\nfunc (h *BaseHandler) SetNext(next Handler) Handler { h.next = next; return next }\\nfunc (h BaseHandler) Handle(request string) string { if h.next != nil { return h.next.Handle(request) }; return \\\"\\\" }\\ntype ConcreteA struct{ BaseHandler }; func (h ConcreteA) Handle(request string) string { if request == \\\"A\\\" { return \\\"Handled by A\\\" }; return h.BaseHandler.Handle(request) }\\ntype ConcreteB struct{ BaseHandler }; func (h ConcreteB) Handle(request string) string { if request == \\\"B\\\" { return \\\"Handled by B\\\" }; return h.BaseHandler.Handle(request) }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"State (durum) tasarim desenini uygulayan sinif yaz\",\"response\":\"class State:\\n    def handle(self, context): pass\\nclass ConcreteStateA(State):\\n    def handle(self, context): context.state = ConcreteStateB()\\nclass ConcreteStateB(State):\\n    def handle(self, context): context.state = ConcreteStateA()\\nclass Context:\\n    def __init__(self): self.state = ConcreteStateA()\\n    def request(self): self.state.handle(self)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"State (durum) tasarim desenini uygulayan sinif yaz\",\"response\":\"class State { handle(context) {} }\\nclass ConcreteStateA extends State { handle(context) { context.state = new ConcreteStateB(); } }\\nclass ConcreteStateB extends State { handle(context) { context.state = new ConcreteStateA(); } }\\nclass Context { constructor() { this.state = new ConcreteStateA(); } request() { this.state.handle(this); } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"State (durum) tasarim desenini uygulayan sinif yaz\",\"response\":\"type State interface{ Handle(*Context) }\\ntype ConcreteStateA struct{}; func (ConcreteStateA) Handle(c *Context) { c.state = ConcreteStateB{} }\\ntype ConcreteStateB struct{}; func (ConcreteStateB) Handle(c *Context) { c.state = ConcreteStateA{} }\\ntype Context struct { state State }; func NewContext() *Context { return &Context{state: ConcreteStateA{}} }; func (c *Context) Request() { c.state.Handle(c) }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Memento (hatira) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Memento:\\n    def __init__(self, state): self.state = state\\n    def get_state(self): return self.state\\nclass Originator:\\n    def __init__(self): self.state = ''\\n    def set_state(self, state): self.state = state\\n    def save(self): return Memento(self.state)\\n    def restore(self, memento): self.state = memento.get_state()\\nclass Caretaker:\\n    def __init__(self): self.mementos = []\\n    def add(self, m): self.mementos.append(m)\\n    def get(self, i): return self.mementos[i]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Memento (hatira) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Memento { constructor(state) { this.state = state; } getState() { return this.state; } }\\nclass Originator { constructor() { this.state = ''; } setState(state) { this.state = state; } save() { return new Memento(this.state); } restore(memento) { this.state = memento.getState(); } }\\nclass Caretaker { constructor() { this.mementos = []; } add(m) { this.mementos.push(m); } get(i) { return this.mementos[i]; } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Memento (hatira) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Memento struct { state string }; func (m Memento) GetState() string { return m.state }\\ntype Originator struct { state string }; func (o *Originator) SetState(s string) { o.state = s }; func (o *Originator) Save() Memento { return Memento{state: o.state} }; func (o *Originator) Restore(m Memento) { o.state = m.GetState() }\\ntype Caretaker struct { mementos []Memento }; func (c *Caretaker) Add(m Memento) { c.mementos = append(c.mementos, m) }; func (c *Caretaker) Get(i int) Memento { return c.mementos[i] }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Proxy (vekil) tasarim desenini uygulayan sinif yaz\",\"response\":\"class RealSubject:\\n    def request(self): return 'RealSubject'\\nclass Proxy:\\n    def __init__(self, real_subject): self.real_subject = real_subject\\n    def request(self):\\n        if self.check_access():\\n            result = self.real_subject.request()\\n            self.log()\\n            return result\\n        return 'Access denied'\\n    def check_access(self): return True\\n    def log(self): pass\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Proxy (vekil) tasarim desenini uygulayan sinif yaz\",\"response\":\"class RealSubject { request() { return 'RealSubject'; } }\\nclass Proxy { constructor(realSubject) { this.realSubject = realSubject; } request() { if (this.checkAccess()) { const result = this.realSubject.request(); this.log(); return result; } return 'Access denied'; } checkAccess() { return true; } log() {} }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Proxy (vekil) tasarim desenini uygulayan sinif yaz\",\"response\":\"type RealSubject struct{}; func (RealSubject) Request() string { return \\\"RealSubject\\\" }\\ntype Proxy struct { realSubject RealSubject }; func (p Proxy) Request() string { if p.checkAccess() { r := p.realSubject.Request(); p.log(); return r }; return \\\"Access denied\\\" }; func (Proxy) checkAccess() bool { return true }; func (Proxy) log() {}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Facade (cephe) tasarim desenini uygulayan sinif yaz\",\"response\":\"class SubsystemA: def operation_a(self): return 'A'\\nclass SubsystemB: def operation_b(self): return 'B'\\nclass SubsystemC: def operation_c(self): return 'C'\\nclass Facade:\\n    def __init__(self): self.a = SubsystemA(); self.b = SubsystemB(); self.c = SubsystemC()\\n    def operation(self): return f'{self.a.operation_a()} + {self.b.operation_b()} + {self.c.operation_c()}'\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Facade (cephe) tasarim desenini uygulayan sinif yaz\",\"response\":\"class SubsystemA { operationA() { return 'A'; } }\\nclass SubsystemB { operationB() { return 'B'; } }\\nclass SubsystemC { operationC() { return 'C'; } }\\nclass Facade { constructor() { this.a = new SubsystemA(); this.b = new SubsystemB(); this.c = new SubsystemC(); } operation() { return `${this.a.operationA()} + ${this.b.operationB()} + ${this.c.operationC()}`; } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Facade (cephe) tasarim desenini uygulayan sinif yaz\",\"response\":\"type SubsystemA struct{}; func (SubsystemA) OperationA() string { return \\\"A\\\" }\\ntype SubsystemB struct{}; func (SubsystemB) OperationB() string { return \\\"B\\\" }\\ntype SubsystemC struct{}; func (SubsystemC) OperationC() string { return \\\"C\\\" }\\ntype Facade struct { a SubsystemA; b SubsystemB; c SubsystemC }; func (f Facade) Operation() string { return f.a.OperationA() + \\\" + \\\" + f.b.OperationB() + \\\" + \\\" + f.c.OperationC() }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Flyweight (sinek agirligi) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Flyweight:\\n    def __init__(self, shared): self.shared = shared\\n    def operation(self, unique): return f'Shared: {self.shared}, Unique: {unique}'\\nclass FlyweightFactory:\\n    def __init__(self): self.flyweights = {}\\n    def get(self, shared):\\n        if shared not in self.flyweights: self.flyweights[shared] = Flyweight(shared)\\n        return self.flyweights[shared]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Flyweight (sinek agirligi) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Flyweight { constructor(shared) { this.shared = shared; } operation(unique) { return `Shared: ${this.shared}, Unique: ${unique}`; } }\\nclass FlyweightFactory { constructor() { this.flyweights = {}; } get(shared) { if (!this.flyweights[shared]) this.flyweights[shared] = new Flyweight(shared); return this.flyweights[shared]; } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Flyweight (sinek agirligi) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Flyweight struct { shared string }; func (f Flyweight) Operation(unique string) string { return \\\"Shared: \\\" + f.shared + \\\", Unique: \\\" + unique }\\ntype FlyweightFactory struct { flyweights map[string]Flyweight }; func NewFlyweightFactory() *FlyweightFactory { return &FlyweightFactory{flyweights: make(map[string]Flyweight)} }; func (f *FlyweightFactory) Get(shared string) Flyweight { if _, ok := f.flyweights[shared]; !ok { f.flyweights[shared] = Flyweight{shared: shared} }; return f.flyweights[shared] }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Composite (bilesik) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Component:\\n    def operation(self): pass\\nclass Leaf(Component):\\n    def __init__(self, name): self.name = name\\n    def operation(self): return self.name\\nclass Composite(Component):\\n    def __init__(self): self.children = []\\n    def add(self, child): self.children.append(child)\\n    def remove(self, child): self.children.remove(child)\\n    def operation(self): return f'Composite({\\\", \\\".join(c.operation() for c in self.children)})'\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Composite (bilesik) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Component { operation() {} }\\nclass Leaf extends Component { constructor(name) { super(); this.name = name; } operation() { return this.name; } }\\nclass Composite extends Component { constructor() { super(); this.children = []; } add(child) { this.children.push(child); } remove(child) { this.children = this.children.filter(c => c !== child); } operation() { return `Composite(${this.children.map(c => c.operation()).join(', ')})`; } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Composite (bilesik) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Component interface{ Operation() string }\\ntype Leaf struct { name string }; func (l Leaf) Operation() string { return l.name }\\ntype Composite struct { children []Component }; func (c *Composite) Add(child Component) { c.children = append(c.children, child) }; func (c *Composite) Operation() string { parts := make([]string, len(c.children)); for i, child := range c.children { parts[i] = child.Operation() }; return \\\"Composite(\\\" + strings.Join(parts, \\\", \\\") + \\\")\\\" }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Interpreter (yorumlayici) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Expression:\\n    def interpret(self, context): pass\\nclass Number(Expression):\\n    def __init__(self, value): self.value = value\\n    def interpret(self, context): return self.value\\nclass Add(Expression):\\n    def __init__(self, left, right): self.left = left; self.right = right\\n    def interpret(self, context): return self.left.interpret(context) + self.right.interpret(context)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Interpreter (yorumlayici) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Expression { interpret(context) {} }\\nclass Number extends Expression { constructor(value) { super(); this.value = value; } interpret(context) { return this.value; } }\\nclass Add extends Expression { constructor(left, right) { super(); this.left = left; this.right = right; } interpret(context) { return this.left.interpret(context) + this.right.interpret(context); } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Interpreter (yorumlayici) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Expression interface{ Interpret(map[string]int) int }\\ntype Number struct{ value int }; func (n Number) Interpret(context map[string]int) int { return n.value }\\ntype Add struct{ left, right Expression }; func (a Add) Interpret(context map[string]int) int { return a.left.Interpret(context) + a.right.Interpret(context) }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Mediator (arabulucu) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Mediator:\\n    def notify(self, sender, event): pass\\nclass ConcreteMediator(Mediator):\\n    def __init__(self, c1, c2): self.c1 = c1; self.c2 = c2; self.c1.mediator = self; self.c2.mediator = self\\n    def notify(self, sender, event):\\n        if event == 'A': self.c2.do_c()\\n        elif event == 'B': self.c1.do_d()\\nclass Component:\\n    def __init__(self): self.mediator = None\\nclass ComponentA(Component):\\n    def do_a(self): self.mediator.notify(self, 'A')\\n    def do_d(self): pass\\nclass ComponentB(Component):\\n    def do_b(self): self.mediator.notify(self, 'B')\\n    def do_c(self): pass\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Mediator (arabulucu) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Mediator { notify(sender, event) {} }\\nclass ConcreteMediator extends Mediator { constructor(c1, c2) { super(); this.c1 = c1; this.c2 = c2; c1.mediator = this; c2.mediator = this; } notify(sender, event) { if (event === 'A') this.c2.doC(); if (event === 'B') this.c1.doD(); } }\\nclass Component { constructor() { this.mediator = null; } }\\nclass ComponentA extends Component { doA() { this.mediator.notify(this, 'A'); } doD() {} }\\nclass ComponentB extends Component { doB() { this.mediator.notify(this, 'B'); } doC() {} }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Mediator (arabulucu) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Mediator interface{ Notify(Component, string) }\\ntype ConcreteMediator struct { c1, c2 Component }; func (m *ConcreteMediator) Notify(sender Component, event string) { if event == \\\"A\\\" { m.c2.(*ComponentB).DoC() }; if event == \\\"B\\\" { m.c1.(*ComponentA).DoD() } }\\ntype Component struct{ mediator Mediator }\\ntype ComponentA struct{ Component }; func (c *ComponentA) DoA() { c.mediator.Notify(c, \\\"A\\\") }; func (c *ComponentA) DoD() {}\\ntype ComponentB struct{ Component }; func (c *ComponentB) DoB() { c.mediator.Notify(c, \\\"B\\\") }; func (c *ComponentB) DoC() {}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bridge (kopru) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Implementor:\\n    def operation_impl(self): pass\\nclass ConcreteImplementorA(Implementor):\\n    def operation_impl(self): return 'A'\\nclass ConcreteImplementorB(Implementor):\\n    def operation_impl(self): return 'B'\\nclass Abstraction:\\n    def __init__(self, implementor): self.implementor = implementor\\n    def operation(self): return f'Abstraction({self.implementor.operation_impl()})'\\nclass RefinedAbstraction(Abstraction):\\n    def operation(self): return f'Refined({self.implementor.operation_impl()})'\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bridge (kopru) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Implementor { operationImpl() {} }\\nclass ConcreteImplementorA extends Implementor { operationImpl() { return 'A'; } }\\nclass ConcreteImplementorB extends Implementor { operationImpl() { return 'B'; } }\\nclass Abstraction { constructor(implementor) { this.implementor = implementor; } operation() { return `Abstraction(${this.implementor.operationImpl()})`; } }\\nclass RefinedAbstraction extends Abstraction { operation() { return `Refined(${this.implementor.operationImpl()})`; } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bridge (kopru) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Implementor interface{ OperationImpl() string }\\ntype ConcreteA struct{}; func (ConcreteA) OperationImpl() string { return \\\"A\\\" }\\ntype ConcreteB struct{}; func (ConcreteB) OperationImpl() string { return \\\"B\\\" }\\ntype Abstraction struct { implementor Implementor }; func (a Abstraction) Operation() string { return \\\"Abstraction(\\\" + a.implementor.OperationImpl() + \\\")\\\" }\\ntype Refined struct{ Abstraction }; func (r Refined) Operation() string { return \\\"Refined(\\\" + r.implementor.OperationImpl() + \\\")\\\" }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iterator (gezici) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Iterator:\\n    def first(self): pass\\n    def next(self): pass\\n    def is_done(self): pass\\n    def current(self): pass\\nclass ConcreteIterator(Iterator):\\n    def __init__(self, items): self.items = items; self.index = 0\\n    def first(self): self.index = 0\\n    def next(self): self.index += 1\\n    def is_done(self): return self.index >= len(self.items)\\n    def current(self): return self.items[self.index] if not self.is_done() else None\\nclass Aggregate:\\n    def create_iterator(self): pass\\nclass ConcreteAggregate(Aggregate):\\n    def __init__(self): self.items = []\\n    def add(self, item): self.items.append(item)\\n    def create_iterator(self): return ConcreteIterator(self.items)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iterator (gezici) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Iterator { first() {} next() {} isDone() {} current() {} }\\nclass ConcreteIterator extends Iterator { constructor(items) { super(); this.items = items; this.index = 0; } first() { this.index = 0; } next() { this.index++; } isDone() { return this.index >= this.items.length; } current() { return this.isDone() ? null : this.items[this.index]; } }\\nclass ConcreteAggregate { constructor() { this.items = []; } add(item) { this.items.push(item); } createIterator() { return new ConcreteIterator(this.items); } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iterator (gezici) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Iterator interface{ First(); Next(); IsDone() bool; Current() interface{} }\\ntype ConcreteIterator struct { items []interface{}; index int }; func (it *ConcreteIterator) First() { it.index = 0 }; func (it *ConcreteIterator) Next() { it.index++ }; func (it *ConcreteIterator) IsDone() bool { return it.index >= len(it.items) }; func (it *ConcreteIterator) Current() interface{} { if it.IsDone() { return nil }; return it.items[it.index] }\\ntype Aggregate struct { items []interface{} }; func (a *Aggregate) Add(item interface{}) { a.items = append(a.items, item) }; func (a *Aggregate) CreateIterator() Iterator { return &ConcreteIterator{items: a.items} }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Prototype (klon) tasarim desenini uygulayan sinif yaz\",\"response\":\"import copy\\nclass Prototype:\\n    def clone(self): return copy.deepcopy(self)\\nclass ConcretePrototype(Prototype):\\n    def __init__(self, value): self.value = value\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Prototype (klon) tasarim desenini uygulayan sinif yaz\",\"response\":\"class Prototype { clone() { return Object.assign(Object.create(Object.getPrototypeOf(this)), JSON.parse(JSON.stringify(this))); } }\\nclass ConcretePrototype extends Prototype { constructor(value) { super(); this.value = value; } }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Prototype (klon) tasarim desenini uygulayan sinif yaz\",\"response\":\"type Prototype interface{ Clone() Prototype }\\ntype ConcretePrototype struct { value int }; func (p ConcretePrototype) Clone() Prototype { return ConcretePrototype{value: p.value} }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir dizideki en buyuk sayiyi bulan fonksiyon yaz\",\"response\":\"func FindMax(arr []int) *int {\\n    if len(arr) == 0 {\\n        return nil\\n    }\\n    max := arr[0]\\n    for _, num := range arr[1:] {\\n        if num > max {\\n            max = num\\n        }\\n    }\\n    return &max\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir string'in palindrom olup olmadigini kontrol eden fonksiyon yaz\",\"response\":\"def is_palindrome(s):\\n    s = s.replace(\\\" \\\", \\\"\\\").lower()\\n    return s == s[::-1]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir string'in palindrom olup olmadigini kontrol eden fonksiyon yaz\",\"response\":\"function isPalindrome(s) {\\n    const cleaned = s.replace(/\\\\s+/g, '').toLowerCase();\\n    return cleaned === cleaned.split('').reverse().join('');\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir string'in palindrom olup olmadigini kontrol eden fonksiyon yaz\",\"response\":\"public static boolean isPalindrome(String s) {\\n    String cleaned = s.replaceAll(\\\"\\\\\\\\s+\\\", \\\"\\\").toLowerCase();\\n    return cleaned.equals(new StringBuilder(cleaned).reverse().toString());\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Fibonacci sayisini hesaplayan fonksiyon yaz\",\"response\":\"def fibonacci(n):\\n    if n <= 0:\\n        return 0\\n    elif n == 1:\\n        return 1\\n    a, b = 0, 1\\n    for _ in range(2, n + 1):\\n        a, b = b, a + b\\n    return b\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Fibonacci sayisini hesaplayan fonksiyon yaz\",\"response\":\"function fibonacci(n) {\\n    if (n <= 0) return 0;\\n    if (n === 1) return 1;\\n    let a = 0, b = 1;\\n    for (let i = 2; i <= n; i++) {\\n        [a, b] = [b, a + b];\\n    }\\n    return b;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Fibonacci sayisini hesaplayan fonksiyon yaz\",\"response\":\"function fibonacci(n: number): number {\\n    if (n <= 0) return 0;\\n    if (n === 1) return 1;\\n    let a = 0, b = 1;\\n    for (let i = 2; i <= n; i++) {\\n        [a, b] = [b, a + b];\\n    }\\n    return b;\\n}\",\"language\":\"typescript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir diziyi ters ceviren fonksiyon yaz\",\"response\":\"def reverse_array(arr):\\n    return arr[::-1]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir diziyi ters ceviren fonksiyon yaz\",\"response\":\"function reverseArray(arr) {\\n    return arr.slice().reverse();\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir diziyi ters ceviren fonksiyon yaz\",\"response\":\"fn reverse_array(arr: &[i32]) -> Vec<i32> {\\n    arr.iter().rev().copied().collect()\\n}\",\"language\":\"rust\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir string'deki sesli harflerin sayisini bulan fonksiyon yaz\",\"response\":\"def count_vowels(s):\\n    vowels = set(\\\"aeiouAEIOU\\\")\\n    return sum(1 for c in s if c in vowels)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir string'deki sesli harflerin sayisini bulan fonksiyon yaz\",\"response\":\"function countVowels(s) {\\n    return (s.match(/[aeiou]/gi) || []).length;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir string'deki sesli harflerin sayisini bulan fonksiyon yaz\",\"response\":\"public static int countVowels(String s) {\\n    int count = 0;\\n    String vowels = \\\"aeiouAEIOU\\\";\\n    for (char c : s.toCharArray()) {\\n        if (vowels.indexOf(c) != -1) count++;\\n    }\\n    return count;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir sayinin faktoriyelini hesaplayan fonksiyon yaz\",\"response\":\"func Factorial(n int) *int {\\n    if n < 0 {\\n        return nil\\n    }\\n    result := 1\\n    for i := 2; i <= n; i++ {\\n        result *= i\\n    }\\n    return &result\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir sayinin faktoriyelini hesaplayan fonksiyon yaz\",\"response\":\"int factorial(int n) {\\n    if (n < 0) return -1;\\n    int result = 1;\\n    for (int i = 2; i <= n; i++) {\\n        result *= i;\\n    }\\n    return result;\\n}\",\"language\":\"cpp\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir sayinin asal olup olmadigini kontrol eden fonksiyon yaz\",\"response\":\"public static boolean isPrime(int n) {\\n    if (n < 2) return false;\\n    for (int i = 2; i <= Math.sqrt(n); i++) {\\n        if (n % i == 0) return false;\\n    }\\n    return true;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir sayinin asal olup olmadigini kontrol eden fonksiyon yaz\",\"response\":\"function isPrime(n: number): boolean {\\n    if (n < 2) return false;\\n    for (let i = 2; i <= Math.sqrt(n); i++) {\\n        if (n % i === 0) return false;\\n    }\\n    return true;\\n}\",\"language\":\"typescript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir dizide tekrar eden ilk elemani bulan fonksiyon yaz\",\"response\":\"def find_first_duplicate(arr):\\n    seen = set()\\n    for item in arr:\\n        if item in seen:\\n            return item\\n        seen.add(item)\\n    return None\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
