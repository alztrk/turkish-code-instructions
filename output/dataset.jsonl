"{\"instruction\":\"time.Timer ile tek seferlik zamanlayici.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"time\\\")\\nfunc main(){\\n  t:=time.NewTimer(time.Second)\\n  <-t.C\\n  fmt.Println(\\\"1 sn gecti\\\")\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"unicode/utf8 ile utf8 islemleri.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"unicode/utf8\\\")\\nfunc main(){\\n  s:=\\\"Merhaba\\\"\\n  fmt.Println(utf8.RuneCountInString(s),len(s))\\n  for len(s)>0{r,size:=utf8.DecodeRuneInString(s);fmt.Printf(\\\"%c \\\",r);s=s[size:]}\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"sync.Once ile tek seferlik islem.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"sync\\\")\\nfunc main(){\\n  var once sync.Once\\n  for i:=0;i<3;i++{\\n    once.Do(func(){fmt.Println(\\\"Bir kez calisir\\\")})\\n  }\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"sync.WaitGroup ile worker.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"sync\\\")\\nfunc main(){\\n  var wg sync.WaitGroup\\n  for i:=1;i<=5;i++{\\n    wg.Add(1)\\n    go func(n int){defer wg.Done();fmt.Println(n*n)}(i)\\n  }\\n  wg.Wait()\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
