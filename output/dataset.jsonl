"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nfrom collections import Counter\\ndef find_dup(arr): return [k for k,v in Counter(arr).items() if v>1]\",\"response\":\"def test_find_dup():\\n    assert sorted(find_dup([1,2,2,3,3,3]))==[2,3]\\n    assert find_dup([1,2,3])==[]\\n    assert find_dup([])==[]\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
