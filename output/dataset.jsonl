"{\"instruction\":\"Bir fonksiyonun calisma suresini olcen bir decorator yaz.\",\"response\":\"import time\\n\\ndef sure_olc(func):\\n    def wrapper(*args, **kwargs):\\n        basla = time.time()\\n        sonuc = func(*args, **kwargs)\\n        bitis = time.time()\\n        print(f'{func.__name__} {bitis - basla:.4f} saniye surdu')\\n        return sonuc\\n    return wrapper\\n\\n@sure_olc\\ndef bekle():\\n    time.sleep(1)\\n\\nbekle()\",\"language\":\"python\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
