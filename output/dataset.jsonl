"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef median(nums):\\n    s=sorted(nums); n=len(s); mid=n//2\\n    if n%2==0: return (s[mid-1]+s[mid])/2\\n    return s[mid]\",\"response\":\"def test_median():\\n    assert median([1,3,3,6,7,8,9])==6\\n    assert median([1,2,3,4])==2.5\\n    assert median([5])==5\\n    assert median([3,1,2])==2\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nfrom collections import Counter\\ndef mode(nums):\\n    c=Counter(nums); mx=max(c.values())\\n    return [k for k,v in c.items() if v==mx]\",\"response\":\"def test_mode():\\n    assert mode([1,2,2,3])==[2]\\n    assert set(mode([1,1,2,2]))=={1,2}\\n    assert mode([1])==[1]\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef is_pal(s):\\n    s=s.lower().replace(' ',''); return s==s[::-1]\",\"response\":\"def test_pal():\\n    assert is_pal('kek')==True\\n    assert is_pal('A man a plan a canal Panama')==True\\n    assert is_pal('merhaba')==False\\n    assert is_pal('')==True\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
