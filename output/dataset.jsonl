"{\"instruction\":\"LEFT JOIN ile tum musterileri getir.\",\"response\":\"SELECT m.ad,s.tarih FROM musteri m LEFT JOIN siparis s ON m.id=s.musteri_id;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"RIGHT JOIN ile tum siparisler.\",\"response\":\"SELECT m.ad,s.tutar FROM musteri m RIGHT JOIN siparis s ON m.id=s.musteri_id;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
