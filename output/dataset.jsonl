"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\npublic class StringUtils { public static String maskEmail(String e){String[] p=e.split(\\\"@\\\");if(p.length!=2)return e;String n=p[0],d=p[1];if(n.length()<=2)return e;return n.charAt(0)+\\\"*\\\".repeat(n.length()-2)+n.charAt(n.length()-1)+\\\"@\\\"+d;} }\",\"response\":\"import org.junit.*;\\nimport static org.junit.Assert.*;\\npublic class MaskEmailTest {\\n    @Test\\n    public void testMaskEmail() {\\n        assertEquals(\\\"m****t@test.com\\\",StringUtils.maskEmail(\\\"mehmet@test.com\\\"));\\n    }\\n}\",\"language\":\"java\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\npublic class StringUtils { public static String caesar(String t,int s){StringBuilder r=new StringBuilder();for(char c:t.toCharArray()){if(Character.isLetter(c)){char base=Character.isLowerCase(c)?'a':'A';r.append((char)((c-base+s)%26+base));}else r.append(c);}return r.toString();} }\",\"response\":\"import org.junit.*;\\nimport static org.junit.Assert.*;\\npublic class CaesarTest {\\n    @Test\\n    public void testCaesar() {\\n        assertEquals(\\\"bcd\\\",StringUtils.caesar(\\\"abc\\\",1));\\n        assertEquals(\\\"abc\\\",StringUtils.caesar(\\\"xyz\\\",3));\\n    }\\n}\",\"language\":\"java\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\npublic class StringUtils { public static String toRoman(int n){int[] v={1000,900,500,400,100,90,50,40,10,9,5,4,1};String[] s={\\\"M\\\",\\\"CM\\\",\\\"D\\\",\\\"CD\\\",\\\"C\\\",\\\"XC\\\",\\\"L\\\",\\\"XL\\\",\\\"X\\\",\\\"IX\\\",\\\"V\\\",\\\"IV\\\",\\\"I\\\"};StringBuilder r=new StringBuilder();for(int i=0;i<v.length;i++){while(n>=v[i]){r.append(s[i]);n-=v[i];}}return r.toString();} }\",\"response\":\"import org.junit.*;\\nimport static org.junit.Assert.*;\\npublic class RomanTest {\\n    @Test\\n    public void testRoman() {\\n        assertEquals(\\\"IV\\\",StringUtils.toRoman(4));\\n        assertEquals(\\\"MCMXCIV\\\",StringUtils.toRoman(1994));\\n    }\\n}\",\"language\":\"java\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\npublic class StringUtils { public static int fromRoman(String s){java.util.Map<Character,Integer> r=new java.util.HashMap<>();r.put('I',1);r.put('V',5);r.put('X',10);r.put('L',50);r.put('C',100);r.put('D',500);r.put('M',1000);int t=0;for(int i=0;i<s.length();i++){if(i+1<s.length()&&r.get(s.charAt(i))<r.get(s.charAt(i+1)))t-=r.get(s.charAt(i));else t+=r.get(s.charAt(i));}return t;} }\",\"response\":\"import org.junit.*;\\nimport static org.junit.Assert.*;\\npublic class FromRomanTest {\\n    @Test\\n    public void testFromRoman() {\\n        assertEquals(4,StringUtils.fromRoman(\\\"IV\\\"));\\n        assertEquals(1994,StringUtils.fromRoman(\\\"MCMXCIV\\\"));\\n    }\\n}\",\"language\":\"java\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
