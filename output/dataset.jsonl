"{\"instruction\":\"JSON formatter / guzel yazdirma fonksiyonu yaz\",\"response\":\"public static String prettyJSON(Object data) {\\n    try { ObjectMapper mapper = new ObjectMapper(); return mapper.writerWithDefaultPrettyPrinter().writeValueAsString(data); }\\n    catch (Exception e) { return null; }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"JSON formatter / guzel yazdirma fonksiyonu yaz\",\"response\":\"func PrettyJSON(data interface{}) string { b, _ := json.MarshalIndent(data, \\\"\\\", \\\"  \\\"); return string(b) }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"URL kisaltma fonksiyonu (base62) uygulayan sinif yaz\",\"response\":\"class URLShortener:\\n    def __init__(self): self.url_map = {}; self.reverse = {}; self.chars = '0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ'; self.id = 0\\n    def shorten(self, url):\\n        if url in self.reverse: return self.reverse[url]\\n        self.id += 1; n = self.id; short = []\\n        while n > 0: short.append(self.chars[n % 62]); n //= 62\\n        short = ''.join(reversed(short))\\n        self.url_map[short] = url; self.reverse[url] = short\\n        return short\\n    def expand(self, short): return self.url_map.get(short, None)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"URL kisaltma fonksiyonu (base62) uygulayan sinif yaz\",\"response\":\"class URLShortener {\\n    constructor() { this.urlMap = {}; this.reverse = {}; this.chars = '0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ'; this.id = 0; }\\n    shorten(url) {\\n        if (this.reverse[url]) return this.reverse[url];\\n        this.id++; let n = this.id; let short = '';\\n        while (n > 0) { short = this.chars[n % 62] + short; n = Math.floor(n / 62); }\\n        this.urlMap[short] = url; this.reverse[url] = short; return short;\\n    }\\n    expand(short) { return this.urlMap[short] || null; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"URL kisaltma fonksiyonu (base62) uygulayan sinif yaz\",\"response\":\"type URLShortener struct { urlMap, reverse map[string]string; id int64 }\\nfunc NewURLShortener() *URLShortener { return &URLShortener{urlMap: make(map[string]string), reverse: make(map[string]string)} }\\nconst chars = \\\"0123456789abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ\\\"\\nfunc (u *URLShortener) Shorten(url string) string { if s, ok := u.reverse[url]; ok { return s }; u.id++; n := u.id; short := \\\"\\\"; for n > 0 { short = string(chars[n%62]) + short; n /= 62 }; u.urlMap[short] = url; u.reverse[url] = short; return short }\\nfunc (u *URLShortener) Expand(short string) string { return u.urlMap[short] }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Password hash fonksiyonu (bcrypt benzeri) yaz\",\"response\":\"import hashlib, os\\ndef hash_password(password):\\n    salt = os.urandom(16)\\n    pwd_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 100000)\\n    return salt.hex() + ':' + pwd_hash.hex()\\ndef verify_password(password, stored):\\n    salt_hex, hash_hex = stored.split(':')\\n    salt = bytes.fromhex(salt_hex)\\n    pwd_hash = hashlib.pbkdf2_hmac('sha256', password.encode(), salt, 100000)\\n    return pwd_hash.hex() == hash_hex\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Password hash fonksiyonu (bcrypt benzeri) yaz\",\"response\":\"async function hashPassword(password) {\\n    const encoder = new TextEncoder(); const data = encoder.encode(password);\\n    const salt = crypto.getRandomValues(new Uint8Array(16));\\n    const key = await crypto.subtle.importKey('raw', data, { name: 'PBKDF2' }, false, ['deriveBits']);\\n    const hash = await crypto.subtle.deriveBits({ name: 'PBKDF2', salt, iterations: 100000, hash: 'SHA-256' }, key, 256);\\n    const saltHex = Array.from(salt).map(b => b.toString(16).padStart(2, '0')).join('');\\n    const hashHex = Array.from(new Uint8Array(hash)).map(b => b.toString(16).padStart(2, '0')).join('');\\n    return saltHex + ':' + hashHex;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Password hash fonksiyonu (bcrypt benzeri) yaz\",\"response\":\"func HashPassword(password string) string { salt := make([]byte, 16); rand.Read(salt); hash := pbkdf2.Key([]byte(password), salt, 100000, 32, sha256.New); return hex.EncodeToString(salt) + \\\":\\\" + hex.EncodeToString(hash) }\\nfunc VerifyPassword(password, stored string) bool { parts := strings.SplitN(stored, \\\":\\\", 2); salt, _ := hex.DecodeString(parts[0]); hash := pbkdf2.Key([]byte(password), salt, 100000, 32, sha256.New); return hex.EncodeToString(hash) == parts[1] }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"JWT (JSON Web Token) olusturma ve dogrulama fonksiyonu yaz\",\"response\":\"import hashlib, base64, json\\ndef base64url(data): return base64.urlsafe_b64encode(data).rstrip(b'=').decode()\\ndef create_jwt(payload, secret):\\n    header = base64url(json.dumps({'alg': 'HS256', 'typ': 'JWT'}).encode())\\n    payload_b64 = base64url(json.dumps(payload).encode())\\n    sig = hashlib.sha256(f'{header}.{payload_b64}{secret}'.encode()).hexdigest()\\n    return f'{header}.{payload_b64}.{sig}'\\ndef verify_jwt(token, secret):\\n    parts = token.split('.')\\n    if len(parts) != 3: return None\\n    sig = hashlib.sha256(f'{parts[0]}.{parts[1]}{secret}'.encode()).hexdigest()\\n    if sig != parts[2]: return None\\n    return json.loads(base64.urlsafe_b64decode(parts[1] + '=='))\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"JWT (JSON Web Token) olusturma ve dogrulama fonksiyonu yaz\",\"response\":\"function base64url(data) { return btoa(String.fromCharCode(...new Uint8Array(data))).replace(/=/g, '').replace(/\\\\+/g, '-').replace(/\\\\//g, '_'); }\\nfunction createJWT(payload, secret) {\\n    const header = base64url(new TextEncoder().encode(JSON.stringify({ alg: 'HS256', typ: 'JWT' })));\\n    const payloadB64 = base64url(new TextEncoder().encode(JSON.stringify(payload)));\\n    const sig = Array.from(new TextEncoder().encode(header + '.' + payloadB64 + secret)).map(b => b.toString(16).padStart(2, '0')).join('');\\n    return header + '.' + payloadB64 + '.' + sig;\\n}\\nfunction verifyJWT(token, secret) { const parts = token.split('.'); if (parts.length !== 3) return null; const sig = Array.from(new TextEncoder().encode(parts[0] + '.' + parts[1] + secret)).map(b => b.toString(16).padStart(2, '0')).join(''); if (sig !== parts[2]) return null; return JSON.parse(atob(parts[1])); }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"JWT (JSON Web Token) olusturma ve dogrulama fonksiyonu yaz\",\"response\":\"func CreateJWT(payload map[string]interface{}, secret string) string { header := base64url(json.RawMessage(`{\\\"alg\\\":\\\"HS256\\\",\\\"typ\\\":\\\"JWT\\\"}`)); payloadB64 := base64url(toJSON(payload)); sig := fmt.Sprintf(\\\"%x\\\", sha256.Sum256([]byte(header+\\\".\\\"+payloadB64+secret))); return header + \\\".\\\" + payloadB64 + \\\".\\\" + sig }\\nfunc base64url(data []byte) string { return strings.TrimRight(base64.URLEncoding.EncodeToString(data), \\\"=\\\") }\\nfunc VerifyJWT(token, secret string) map[string]interface{} { parts := strings.Split(token, \\\".\\\"); if len(parts) != 3 { return nil }; sig := fmt.Sprintf(\\\"%x\\\", sha256.Sum256([]byte(parts[0]+\\\".\\\"+parts[1]+secret))); if sig != parts[2] { return nil }; p, _ := base64.URLEncoding.DecodeString(parts[1] + \\\"==\\\"); var r map[string]interface{}; json.Unmarshal(p, &r); return r }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Web sayfasi icin HTML sanitizasyon fonksiyonu yaz\",\"response\":\"import html\\ndef sanitize_html(text):\\n    return html.escape(text, quote=True)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Web sayfasi icin HTML sanitizasyon fonksiyonu yaz\",\"response\":\"function sanitizeHTML(text) {\\n    const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '\\\"': '&quot;', \\\"'\\\": '&#x27;' };\\n    return text.replace(/[&<>\\\"']/g, m => map[m]);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Web sayfasi icin HTML sanitizasyon fonksiyonu yaz\",\"response\":\"func SanitizeHTML(text string) string {\\n    replacer := strings.NewReplacer(\\\"&\\\", \\\"&amp;\\\", \\\"<\\\", \\\"&lt;\\\", \\\">\\\", \\\"&gt;\\\", \\\"\\\"\\\", \\\"&quot;\\\", \\\"'\\\", \\\"&#x27;\\\")\\n    return replacer.Replace(text)\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"JSON Web Token (JWT) dogrulama ortasi (middleware) uygulayan fonksiyon yaz\",\"response\":\"def jwt_middleware(handler, secret):\\n    def wrapper(request):\\n        token = request.headers.get('Authorization', '').replace('Bearer ', '')\\n        if not token: return {'error': 'No token'}, 401\\n        try:\\n            parts = token.split('.')\\n            if len(parts) != 3: raise ValueError\\n            import hashlib, json, base64\\n            sig = hashlib.sha256(f'{parts[0]}.{parts[1]}{secret}'.encode()).hexdigest()\\n            if sig != parts[2]: raise ValueError\\n            payload = json.loads(base64.urlsafe_b64decode(parts[1] + '=='))\\n            request.user = payload\\n        except: return {'error': 'Invalid token'}, 401\\n        return handler(request)\\n    return wrapper\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"JSON Web Token (JWT) dogrulama ortasi (middleware) uygulayan fonksiyon yaz\",\"response\":\"function jwtMiddleware(handler, secret) {\\n    return function(request) {\\n        const token = (request.headers['Authorization'] || '').replace('Bearer ', '');\\n        if (!token) return { status: 401, body: { error: 'No token' } };\\n        try {\\n            const parts = token.split('.');\\n            if (parts.length !== 3) throw new Error();\\n            const sig = Array.from(new TextEncoder().encode(parts[0] + '.' + parts[1] + secret)).map(b => b.toString(16).padStart(2, '0')).join('');\\n            if (sig !== parts[2]) throw new Error();\\n            request.user = JSON.parse(atob(parts[1]));\\n        } catch { return { status: 401, body: { error: 'Invalid token' } }; }\\n        return handler(request);\\n    };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"JSON Web Token (JWT) dogrulama ortasi (middleware) uygulayan fonksiyon yaz\",\"response\":\"func JWTMiddleware(handler http.HandlerFunc, secret string) http.HandlerFunc {\\n    return func(w http.ResponseWriter, r *http.Request) {\\n        token := strings.TrimPrefix(r.Header.Get(\\\"Authorization\\\"), \\\"Bearer \\\")\\n        if token == \\\"\\\" { http.Error(w, `{\\\"error\\\":\\\"No token\\\"}`, 401); return }\\n        parts := strings.Split(token, \\\".\\\")\\n        if len(parts) != 3 { http.Error(w, `{\\\"error\\\":\\\"Invalid token\\\"}`, 401); return }\\n        sig := fmt.Sprintf(\\\"%x\\\", sha256.Sum256([]byte(parts[0]+\\\".\\\"+parts[1]+secret)))\\n        if sig != parts[2] { http.Error(w, `{\\\"error\\\":\\\"Invalid token\\\"}`, 401); return }\\n        handler(w, r)\\n    }\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rate limiting middleware uygulayan fonksiyon yaz\",\"response\":\"import time\\ndef rate_limit_middleware(handler, max_requests=100, window=60):\\n    requests = {}\\n    def wrapper(request):\\n        ip = request.get('ip', 'unknown')\\n        now = time.time()\\n        if ip in requests:\\n            requests[ip] = [t for t in requests[ip] if now - t < window]\\n            if len(requests[ip]) >= max_requests: return {'error': 'Rate limit exceeded'}, 429\\n            requests[ip].append(now)\\n        else: requests[ip] = [now]\\n        return handler(request)\\n    return wrapper\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rate limiting middleware uygulayan fonksiyon yaz\",\"response\":\"function rateLimitMiddleware(handler, maxRequests = 100, window = 60000) {\\n    const requests = {};\\n    return function(request) {\\n        const ip = request.ip || 'unknown'; const now = Date.now();\\n        if (requests[ip]) { requests[ip] = requests[ip].filter(t => now - t < window); if (requests[ip].length >= maxRequests) return { status: 429, body: { error: 'Rate limit exceeded' } }; requests[ip].push(now); }\\n        else requests[ip] = [now];\\n        return handler(request);\\n    };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rate limiting middleware uygulayan fonksiyon yaz\",\"response\":\"func RateLimitMiddleware(handler http.HandlerFunc, maxRequests int, window time.Duration) http.HandlerFunc {\\n    type entry struct { times []time.Time; mu sync.Mutex }\\n    requests := make(map[string]*entry); var mu sync.Mutex\\n    return func(w http.ResponseWriter, r *http.Request) {\\n        ip := r.RemoteAddr\\n        mu.Lock()\\n        e, ok := requests[ip]\\n        if !ok { e = &entry{}; requests[ip] = e }\\n        mu.Unlock()\\n        e.mu.Lock()\\n        now := time.Now()\\n        filtered := make([]time.Time, 0)\\n        for _, t := range e.times { if now.Sub(t) < window { filtered = append(filtered, t) } }\\n        e.times = filtered\\n        if len(e.times) >= maxRequests { e.mu.Unlock(); http.Error(w, `{\\\"error\\\":\\\"Rate limit exceeded\\\"}`, 429); return }\\n        e.times = append(e.times, now)\\n        e.mu.Unlock()\\n        handler(w, r)\\n    }\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"CORS middleware uygulayan fonksiyon yaz\",\"response\":\"def cors_middleware(handler, origins='*'):\\n    def wrapper(request):\\n        response = handler(request)\\n        response['headers'] = response.get('headers', {})\\n        response['headers']['Access-Control-Allow-Origin'] = origins\\n        response['headers']['Access-Control-Allow-Methods'] = 'GET, POST, PUT, DELETE, OPTIONS'\\n        response['headers']['Access-Control-Allow-Headers'] = 'Content-Type, Authorization'\\n        return response\\n    return wrapper\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"CORS middleware uygulayan fonksiyon yaz\",\"response\":\"function corsMiddleware(handler, origins = '*') {\\n    return function(request) {\\n        if (request.method === 'OPTIONS') return { status: 204, headers: { 'Access-Control-Allow-Origin': origins, 'Access-Control-Allow-Methods': 'GET, POST, PUT, DELETE, OPTIONS', 'Access-Control-Allow-Headers': 'Content-Type, Authorization' } };\\n        const response = handler(request);\\n        response.headers = { ...response.headers, 'Access-Control-Allow-Origin': origins };\\n        return response;\\n    };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"CORS middleware uygulayan fonksiyon yaz\",\"response\":\"func CORSMiddleware(handler http.HandlerFunc) http.HandlerFunc {\\n    return func(w http.ResponseWriter, r *http.Request) {\\n        w.Header().Set(\\\"Access-Control-Allow-Origin\\\", \\\"*\\\")\\n        w.Header().Set(\\\"Access-Control-Allow-Methods\\\", \\\"GET, POST, PUT, DELETE, OPTIONS\\\")\\n        w.Header().Set(\\\"Access-Control-Allow-Headers\\\", \\\"Content-Type, Authorization\\\")\\n        if r.Method == \\\"OPTIONS\\\" { w.WriteHeader(204); return }\\n        handler(w, r)\\n    }\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Logging middleware uygulayan fonksiyon yaz\",\"response\":\"import time, logging\\ndef logging_middleware(handler):\\n    def wrapper(request):\\n        start = time.time()\\n        response = handler(request)\\n        elapsed = time.time() - start\\n        logging.info(f'{request.get(\\\"method\\\", \\\"GET\\\")} {request.get(\\\"path\\\", \\\"/\\\")} -> {response.get(\\\"status\\\", 200)} ({elapsed:.3f}s)')\\n        return response\\n    return wrapper\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Logging middleware uygulayan fonksiyon yaz\",\"response\":\"function loggingMiddleware(handler) {\\n    return function(request) {\\n        const start = Date.now();\\n        const response = handler(request);\\n        console.log(`${request.method || 'GET'} ${request.path || '/'} -> ${response.status || 200} (${Date.now() - start}ms)`);\\n        return response;\\n    };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Logging middleware uygulayan fonksiyon yaz\",\"response\":\"func LoggingMiddleware(handler http.HandlerFunc) http.HandlerFunc {\\n    return func(w http.ResponseWriter, r *http.Request) {\\n        start := time.Now()\\n        lrw := &loggingResponseWriter{ResponseWriter: w, statusCode: 200}\\n        handler(lrw, r)\\n        log.Printf(\\\"%s %s -> %d (%v)\\\", r.Method, r.URL.Path, lrw.statusCode, time.Since(start))\\n    }\\n}\\ntype loggingResponseWriter struct { http.ResponseWriter; statusCode int }\\nfunc (lrw *loggingResponseWriter) WriteHeader(code int) { lrw.statusCode = code; lrw.ResponseWriter.WriteHeader(code) }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Error handling middleware uygulayan fonksiyon yaz\",\"response\":\"def error_middleware(handler):\\n    def wrapper(request):\\n        try: return handler(request)\\n        except Exception as e: return {'error': str(e), 'status': 500}\\n    return wrapper\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Error handling middleware uygulayan fonksiyon yaz\",\"response\":\"function errorMiddleware(handler) {\\n    return async function(request) {\\n        try { return await handler(request); }\\n        catch (err) { return { status: 500, body: { error: err.message } }; }\\n    };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Error handling middleware uygulayan fonksiyon yaz\",\"response\":\"func ErrorMiddleware(handler http.HandlerFunc) http.HandlerFunc {\\n    return func(w http.ResponseWriter, r *http.Request) {\\n        defer func() {\\n            if err := recover(); err != nil { http.Error(w, fmt.Sprintf(`{\\\"error\\\":\\\"%v\\\"}`, err), 500) }\\n        }()\\n        handler(w, r)\\n    }\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kuyruk bazli isleme (job queue) sistemi uygulayan sinif yaz\",\"response\":\"from collections import deque\\nimport threading, time\\nclass JobQueue:\\n    def __init__(self): self.queue = deque(); self.workers = []\\n    def add_job(self, job): self.queue.append(job)\\n    def start_workers(self, n=3):\\n        def worker():\\n            while True:\\n                if self.queue:\\n                    job = self.queue.popleft()\\n                    try: job()\\n                    except: pass\\n                else: time.sleep(0.1)\\n        for _ in range(n): t = threading.Thread(target=worker, daemon=True); t.start(); self.workers.append(t)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kuyruk bazli isleme (job queue) sistemi uygulayan sinif yaz\",\"response\":\"class JobQueue {\\n    constructor() { this.queue = []; this.workers = []; }\\n    addJob(job) { this.queue.push(job); }\\n    startWorkers(n = 3) {\\n        const worker = () => { setInterval(() => { if (this.queue.length) { const job = this.queue.shift(); try { job(); } catch {} } }, 100); };\\n        for (let i = 0; i < n; i++) { const t = new Promise(resolve => { worker(); resolve(); }); this.workers.push(t); }\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Kuyruk bazli isleme (job queue) sistemi uygulayan sinif yaz\",\"response\":\"type JobQueue struct { queue chan func(); wg sync.WaitGroup }\\nfunc NewJobQueue(buffer int) *JobQueue { return &JobQueue{queue: make(chan func(), buffer)} }\\nfunc (jq *JobQueue) AddJob(job func()) { jq.queue <- job }\\nfunc (jq *JobQueue) StartWorkers(n int) {\\n    for i := 0; i < n; i++ { jq.wg.Add(1); go func() { defer jq.wg.Done(); for job := range jq.queue { func() { defer func() { recover() }(); job() }() } }() }\\n}\\nfunc (jq *JobQueue) Stop() { close(jq.queue); jq.wg.Wait() }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Pub/sub (yayinla/abone ol) mesaj sistemi uygulayan sinif yaz\",\"response\":\"class PubSub:\\n    def __init__(self): self.subscribers = {}\\n    def subscribe(self, event, callback):\\n        if event not in self.subscribers: self.subscribers[event] = []\\n        self.subscribers[event].append(callback)\\n    def unsubscribe(self, event, callback):\\n        if event in self.subscribers:\\n            self.subscribers[event] = [cb for cb in self.subscribers[event] if cb != callback]\\n    def publish(self, event, data=None):\\n        if event in self.subscribers:\\n            for callback in self.subscribers[event]: callback(data)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Pub/sub (yayinla/abone ol) mesaj sistemi uygulayan sinif yaz\",\"response\":\"class PubSub {\\n    constructor() { this.subscribers = {}; }\\n    subscribe(event, callback) { if (!this.subscribers[event]) this.subscribers[event] = []; this.subscribers[event].push(callback); }\\n    unsubscribe(event, callback) { if (this.subscribers[event]) this.subscribers[event] = this.subscribers[event].filter(cb => cb !== callback); }\\n    publish(event, data) { if (this.subscribers[event]) this.subscribers[event].forEach(cb => cb(data)); }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Pub/sub (yayinla/abone ol) mesaj sistemi uygulayan sinif yaz\",\"response\":\"type PubSub struct { subscribers map[string][]func(interface{}); mu sync.RWMutex }\\nfunc NewPubSub() *PubSub { return &PubSub{subscribers: make(map[string][]func(interface{}))} }\\nfunc (ps *PubSub) Subscribe(event string, callback func(interface{})) { ps.mu.Lock(); defer ps.mu.Unlock(); ps.subscribers[event] = append(ps.subscribers[event], callback) }\\nfunc (ps *PubSub) Publish(event string, data interface{}) { ps.mu.RLock(); defer ps.mu.RUnlock(); if cbs, ok := ps.subscribers[event]; ok { for _, cb := range cbs { go cb(data) } } }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Event emitter (olay yayici) sinifi uygulayin\",\"response\":\"class EventEmitter:\\n    def __init__(self): self._events = {}\\n    def on(self, event, listener):\\n        if event not in self._events: self._events[event] = []\\n        self._events[event].append(listener)\\n        return self\\n    def emit(self, event, *args, **kwargs):\\n        if event in self._events:\\n            for listener in self._events[event]: listener(*args, **kwargs)\\n    def remove(self, event, listener):\\n        if event in self._events:\\n            self._events[event] = [l for l in self._events[event] if l != listener]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Event emitter (olay yayici) sinifi uygulayin\",\"response\":\"class EventEmitter {\\n    constructor() { this._events = {}; }\\n    on(event, listener) { if (!this._events[event]) this._events[event] = []; this._events[event].push(listener); return this; }\\n    emit(event, ...args) { if (this._events[event]) this._events[event].forEach(l => l(...args)); }\\n    remove(event, listener) { if (this._events[event]) this._events[event] = this._events[event].filter(l => l !== listener); }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Event emitter (olay yayici) sinifi uygulayin\",\"response\":\"type EventEmitter struct { listeners map[string][]func(...interface{}); mu sync.Mutex }\\nfunc NewEventEmitter() *EventEmitter { return &EventEmitter{listeners: make(map[string][]func(...interface{}))} }\\nfunc (ee *EventEmitter) On(event string, listener func(...interface{})) { ee.mu.Lock(); defer ee.mu.Unlock(); ee.listeners[event] = append(ee.listeners[event], listener) }\\nfunc (ee *EventEmitter) Emit(event string, args ...interface{}) { ee.mu.Lock(); defer ee.mu.Unlock(); if ls, ok := ee.listeners[event]; ok { for _, l := range ls { go l(args...) } } }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Object pool (nesne havuzu) tasarim desenini uygulayan sinif yaz\",\"response\":\"class ObjectPool:\\n    def __init__(self, factory, max_size=10):\\n        self.factory = factory; self.max_size = max_size; self.pool = []\\n    def acquire(self):\\n        if self.pool: return self.pool.pop()\\n        return self.factory()\\n    def release(self, obj):\\n        if len(self.pool) < self.max_size: self.pool.append(obj)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Object pool (nesne havuzu) tasarim desenini uygulayan sinif yaz\",\"response\":\"class ObjectPool {\\n    constructor(factory, maxSize = 10) { this.factory = factory; this.maxSize = maxSize; this.pool = []; }\\n    acquire() { return this.pool.length ? this.pool.pop() : this.factory(); }\\n    release(obj) { if (this.pool.length < this.maxSize) this.pool.push(obj); }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Object pool (nesne havuzu) tasarim desenini uygulayan sinif yaz\",\"response\":\"type ObjectPool struct { factory func() interface{}; pool []interface{}; maxSize int; mu sync.Mutex }\\nfunc NewObjectPool(factory func() interface{}, maxSize int) *ObjectPool { return &ObjectPool{factory: factory, maxSize: maxSize} }\\nfunc (op *ObjectPool) Acquire() interface{} { op.mu.Lock(); defer op.mu.Unlock(); if len(op.pool) > 0 { r := op.pool[len(op.pool)-1]; op.pool = op.pool[:len(op.pool)-1]; return r }; return op.factory() }\\nfunc (op *ObjectPool) Release(obj interface{}) { op.mu.Lock(); defer op.mu.Unlock(); if len(op.pool) < op.maxSize { op.pool = append(op.pool, obj) } }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Thread pool (is parcacigi havuzu) uygulayan sinif yaz\",\"response\":\"from concurrent.futures import ThreadPoolExecutor\\nclass ThreadPool:\\n    def __init__(self, max_workers=4):\\n        self.executor = ThreadPoolExecutor(max_workers=max_workers)\\n    def submit(self, fn, *args, **kwargs): return self.executor.submit(fn, *args, **kwargs)\\n    def shutdown(self): self.executor.shutdown()\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Thread pool (is parcacigi havuzu) uygulayan sinif yaz\",\"response\":\"class ThreadPool {\\n    constructor(maxWorkers = 4) { this.maxWorkers = maxWorkers; this.queue = []; this.running = 0; }\\n    submit(fn, ...args) { return new Promise((resolve, reject) => { const task = () => { this.running++; fn(...args).then(resolve, reject).finally(() => { this.running--; this.processQueue(); }); }; this.queue.push(task); this.processQueue(); }); }\\n    processQueue() { while (this.running < this.maxWorkers && this.queue.length) { const task = this.queue.shift(); task(); } }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Thread pool (is parcacigi havuzu) uygulayan sinif yaz\",\"response\":\"type ThreadPool struct { jobs chan func(); wg sync.WaitGroup }\\nfunc NewThreadPool(maxWorkers int) *ThreadPool { tp := &ThreadPool{jobs: make(chan func(), 100)}; for i := 0; i < maxWorkers; i++ { tp.wg.Add(1); go func() { defer tp.wg.Done(); for job := range tp.jobs { func() { defer func() { recover() }(); job() }() } }() }; return tp }\\nfunc (tp *ThreadPool) Submit(fn func()) { tp.jobs <- fn }\\nfunc (tp *ThreadPool) Shutdown() { close(tp.jobs); tp.wg.Wait() }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
