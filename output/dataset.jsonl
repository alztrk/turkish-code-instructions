"{\"instruction\":\"Bir diziyi belirtilen boyutta parcalara ayiran fonksiyon yaz\",\"response\":\"func ChunkIslemi(dizi []int, boyut int) [][]int {\\n    var s [][]int\\n    for i := 0; i < len(dizi); i += boyut {\\n        son := i + boyut\\n        if son > len(dizi) { son = len(dizi) }\\n        s = append(s, dizi[i:son])\\n    }\\n    return s\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
