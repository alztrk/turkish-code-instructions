"{\"instruction\":\"JSON Veritabani Yoneticisi uygulamasi yap. Veri ekleme, silme, listeleme ve arama ozellikleri olsun. JSON tabanli CRUD islemleri yapan veritabani yoneticisi uygulamasi.\",\"response\":\"import java.util.*;\\nimport java.io.*;\\npublic class JSONVeritabaniYoneticisi {\\n    static List<String> veriler = new ArrayList<>();\\n    static String dosya = \\\"json_veritabani_yoneticisi.json\\\";\\n    public static void yukle() throws Exception {\\n        File f = new File(dosya);\\n        if (f.exists()) {\\n            Scanner sc = new Scanner(f); sc.useDelimiter(\\\"\\\\\\\\Z\\\");\\n            String icerik = sc.hasNext() ? sc.next() : \\\"\\\"; sc.close();\\n            try { veriler = new ArrayList<>(Arrays.asList(new com.google.gson.Gson().fromJson(icerik, String[].class))); }\\n            catch(Exception e) { veriler = new ArrayList<>(); }\\n        }\\n    }\\n    public static void kaydet() throws Exception {\\n        try (PrintWriter pw = new PrintWriter(dosya)) {\\n            pw.println(new com.google.gson.GsonBuilder().setPrettyPrinting().create().toJson(veriler));\\n        }\\n    }\\n    public static void ekle(String deger) throws Exception { veriler.add(deger); kaydet(); System.out.println(\\\"Eklendi: \\\" + deger); }\\n    public static void listele() { for(int i=0;i<veriler.size();i++) System.out.println((i+1) + \\\". \\\" + veriler.get(i)); }\\n    public static void sil(int idx) throws Exception {\\n        if(idx>=0 && idx<veriler.size()) { String s = veriler.remove(idx); kaydet(); System.out.println(\\\"Silindi: \\\" + s); }\\n    }\\n    public static void main(String[] args) throws Exception {\\n        yukle(); Scanner sc = new Scanner(System.in);\\n        while(true) {\\n            System.out.print(\\\"\\\\\\\\n1:Ekle 2:Listele 3:Sil 4:Cikis: \\\");\\n            String s = sc.nextLine();\\n            if(s.equals(\\\"4\\\")) break;\\n            else if(s.equals(\\\"1\\\")) { System.out.print(\\\"Deger: \\\"); ekle(sc.nextLine()); }\\n            else if(s.equals(\\\"2\\\")) listele();\\n            else if(s.equals(\\\"3\\\")) { System.out.print(\\\"Index: \\\"); sil(Integer.parseInt(sc.nextLine())-1); }\\n        }\\n    }\\n}\",\"language\":\"java\",\"category\":\"project\",\"type\":\"manual\",\"format\":\"project\"}"
"{\"instruction\":\"Markdown Editor uygulamasi yap. Veri ekleme, silme, listeleme ve arama ozellikleri olsun. Markdown metnini HTML'e donusturen editor uygulamasi.\",\"response\":\"import java.util.*;\\nimport java.io.*;\\npublic class MarkdownEditor {\\n    static List<String> veriler = new ArrayList<>();\\n    static String dosya = \\\"markdown_editor.json\\\";\\n    public static void yukle() throws Exception {\\n        File f = new File(dosya);\\n        if (f.exists()) {\\n            Scanner sc = new Scanner(f); sc.useDelimiter(\\\"\\\\\\\\Z\\\");\\n            String icerik = sc.hasNext() ? sc.next() : \\\"\\\"; sc.close();\\n            try { veriler = new ArrayList<>(Arrays.asList(new com.google.gson.Gson().fromJson(icerik, String[].class))); }\\n            catch(Exception e) { veriler = new ArrayList<>(); }\\n        }\\n    }\\n    public static void kaydet() throws Exception {\\n        try (PrintWriter pw = new PrintWriter(dosya)) {\\n            pw.println(new com.google.gson.GsonBuilder().setPrettyPrinting().create().toJson(veriler));\\n        }\\n    }\\n    public static void ekle(String deger) throws Exception { veriler.add(deger); kaydet(); System.out.println(\\\"Eklendi: \\\" + deger); }\\n    public static void listele() { for(int i=0;i<veriler.size();i++) System.out.println((i+1) + \\\". \\\" + veriler.get(i)); }\\n    public static void sil(int idx) throws Exception {\\n        if(idx>=0 && idx<veriler.size()) { String s = veriler.remove(idx); kaydet(); System.out.println(\\\"Silindi: \\\" + s); }\\n    }\\n    public static void main(String[] args) throws Exception {\\n        yukle(); Scanner sc = new Scanner(System.in);\\n        while(true) {\\n            System.out.print(\\\"\\\\\\\\n1:Ekle 2:Listele 3:Sil 4:Cikis: \\\");\\n            String s = sc.nextLine();\\n            if(s.equals(\\\"4\\\")) break;\\n            else if(s.equals(\\\"1\\\")) { System.out.print(\\\"Deger: \\\"); ekle(sc.nextLine()); }\\n            else if(s.equals(\\\"2\\\")) listele();\\n            else if(s.equals(\\\"3\\\")) { System.out.print(\\\"Index: \\\"); sil(Integer.parseInt(sc.nextLine())-1); }\\n        }\\n    }\\n}\",\"language\":\"java\",\"category\":\"project\",\"type\":\"manual\",\"format\":\"project\"}"
