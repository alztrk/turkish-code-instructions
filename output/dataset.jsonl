"{\"instruction\":\"keyof ile bir interface'in anahtarlarindan union tip olustur.\",\"response\":\"interface Kisi {\\n  ad: string;\\n  yas: number;\\n  email: string;\\n}\\n\\ntype KisiAnahtari = keyof Kisi;\\n\\nlet anahtar: KisiAnahtari = \\\"ad\\\";\\nanahtar = \\\"yas\\\";\\nanahtar = \\\"email\\\";\\n// anahtar = \\\"telefon\\\"; // Hata\\n\\nconsole.log(anahtar);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Pick ile bir interface'den sadece belirli alanlari alan yeni bir tip olustur.\",\"response\":\"interface Personel {\\n  id: number;\\n  ad: string;\\n  maas: number;\\n  sifre: string;\\n}\\n\\ntype PersonelGoruntuleme = Pick<Personel, \\\"id\\\" | \\\"ad\\\">;\\n\\nconst gorunen: PersonelGoruntuleme = { id: 1, ad: \\\"Zeynep\\\" };\\nconsole.log(gorunen);\\n\\n// Omit ile tersi\\n// type PersonelGizli = Omit<Personel, \\\"sifre\\\">;\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Record ile bir sozluk (dictionary) tipi olustur ve kullan.\",\"response\":\"type SehirPlaka = Record<string, number>;\\n\\nconst plakalar: SehirPlaka = {\\n  Istanbul: 34,\\n  Ankara: 6,\\n  Izmir: 35\\n};\\n\\nconsole.log(plakalar.Istanbul);\\nconsole.log(plakalar);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir sayının karesini hesaplayan fonksiyon yaz (tip tanımlı).\",\"response\":\"function kareHesapla(sayi: number): number {\\n  return sayi * sayi;\\n}\\n\\nlet deger: number = 9;\\nlet sonuc: number = kareHesapla(deger);\\nconsole.log(sonuc);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir ürün listesinden fiyatı belirli aralıkta olanları filtrele.\",\"response\":\"interface Urun {\\n  isim: string;\\n  fiyat: number;\\n  miktar: number;\\n}\\n\\nfunction urunFiltrele(urunler: Urun[], minFiyat: number, maxFiyat: number): Urun[] {\\n  return urunler.filter(function(urun) {\\n    return urun.fiyat >= minFiyat && urun.fiyat <= maxFiyat;\\n  });\\n}\\n\\nlet liste: Urun[] = [\\n  { isim: \\\"Kalem\\\", fiyat: 5, miktar: 100 },\\n  { isim: \\\"Defter\\\", fiyat: 15, miktar: 50 },\\n  { isim: \\\"Silgi\\\", fiyat: 3, miktar: 200 }\\n];\\nlet sonuc = urunFiltrele(liste, 4, 10);\\nconsole.log(sonuc);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir dizi içindeki sayıların karelerinden yeni dizi oluştur.\",\"response\":\"function kareDiziOlustur(sayilar: number[]): number[] {\\n  let kareler: number[] = [];\\n  for (let index = 0; index < sayilar.length; index++) {\\n    kareler.push(sayilar[index] * sayilar[index]);\\n  }\\n  return kareler;\\n}\\n\\nlet girdi: number[] = [1, 2, 3, 4, 5];\\nlet cikti: number[] = kareDiziOlustur(girdi);\\nconsole.log(cikti);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir kullanıcı nesnesinin yaşını kontrol eden fonksiyon yaz.\",\"response\":\"interface Kullanici {\\n  isim: string;\\n  yas: number;\\n  sehir: string;\\n}\\n\\nfunction yasKontrol(kullanici: Kullanici, sinir: number): string {\\n  if (kullanici.yas >= sinir) {\\n    return kullanici.isim + \\\" gecerli\\\";\\n  }\\n  return kullanici.isim + \\\" gecersiz\\\";\\n}\\n\\nlet kisi: Kullanici = { isim: \\\"Ayse\\\", yas: 22, sehir: \\\"Ankara\\\" };\\nlet mesaj: string = yasKontrol(kisi, 18);\\nconsole.log(mesaj);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"İki string'i birleştirip boşluk ekleyen fonksiyon yaz.\",\"response\":\"function kelimeBirlestir(kelime1: string, kelime2: string): string {\\n  return kelime1 + \\\" \\\" + kelime2;\\n}\\n\\nlet ilkKelime: string = \\\"merhaba\\\";\\nlet ikinciKelime: string = \\\"dunya\\\";\\nlet cumle: string = kelimeBirlestir(ilkKelime, ikinciKelime);\\nconsole.log(cumle);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir dizinin elemanlarını iki katına çıkaran fonksiyon yaz.\",\"response\":\"function ikiKatYap(degerler: number[]): number[] {\\n  let sonuc: number[] = [];\\n  for (let index = 0; index < degerler.length; index++) {\\n    sonuc.push(degerler[index] * 2);\\n  }\\n  return sonuc;\\n}\\n\\nlet sayilar: number[] = [3, 6, 9, 12];\\nlet katlanmis: number[] = ikiKatYap(sayilar);\\nconsole.log(katlanmis);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir anahtar-değer çiftini saklayan ve döndüren fonksiyon yaz.\",\"response\":\"function kayitOlustur(anahtar: string, deger: any): object {\\n  let kayit: any = {};\\n  kayit[anahtar] = deger;\\n  return kayit;\\n}\\n\\nlet yeniKayit = kayitOlustur(\\\"sehir\\\", \\\"Istanbul\\\");\\nconsole.log(yeniKayit);\\n\\nlet hataKaydi = kayitOlustur(\\\"hata\\\", \\\"bulunamadi\\\");\\nconsole.log(hataKaydi);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir string dizisindeki en uzun kelimeyi bulan fonksiyon yaz.\",\"response\":\"function enUzunKelimeBul(kelimeler: string[]): string {\\n  let enUzun: string = kelimeler[0];\\n  for (let index = 1; index < kelimeler.length; index++) {\\n    if (kelimeler[index].length > enUzun.length) {\\n      enUzun = kelimeler[index];\\n    }\\n  }\\n  return enUzun;\\n}\\n\\nlet kelimeListesi: string[] = [\\\"elma\\\", \\\"armut\\\", \\\"karpuz\\\", \\\"muz\\\"];\\nlet sonuc: string = enUzunKelimeBul(kelimeListesi);\\nconsole.log(sonuc);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir sayı dizisindeki pozitif sayıları filtrele.\",\"response\":\"function pozitifleriFiltrele(sayilar: number[]): number[] {\\n  return sayilar.filter(function(sayi) {\\n    return sayi > 0;\\n  });\\n}\\n\\nlet dizi: number[] = [-3, 5, -1, 8, 0, 2];\\nlet pozitifDizi: number[] = pozitifleriFiltrele(dizi);\\nconsole.log(pozitifDizi);\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Girilen bir tarihin hafta sonu olup olmadığını kontrol et.\",\"response\":\"function haftaSonuMu(tarih: Date): boolean {\\n  let gun: number = tarih.getDay();\\n  return gun === 0 || gun === 6;\\n}\\n\\nlet bugun: Date = new Date();\\nlet secim: Date = new Date(2026, 5, 23);\\nconsole.log(\\\"Bugun hafta sonu mu? \\\" + haftaSonuMu(bugun));\\nconsole.log(\\\"Secim hafta sonu mu? \\\" + haftaSonuMu(secim));\",\"language\":\"typescript\",\"category\":\"typescript\",\"type\":\"manual\"}"
"{\"instruction\":\"Basit bir HTML sayfa yapısı oluştur. html, head, body etiketlerini kullan.\",\"response\":\"<!DOCTYPE html>\\n<html lang=\\\"tr\\\">\\n<head>\\n  <meta charset=\\\"UTF-8\\\">\\n  <title>Sayfam</title>\\n</head>\\n<body>\\n  <p>Hoş geldiniz!</p>\\n</body>\\n</html>\",\"language\":\"web\",\"category\":\"web\",\"type\":\"manual\"}"
