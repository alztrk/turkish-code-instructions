"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nimport re\\ndef valid_time(t): return bool(re.match(r'^([01]\\\\d|2[0-3]):[0-5]\\\\d(:[0-5]\\\\d)?$',t))\",\"response\":\"def test_time_v():\\n    assert valid_time('14:30')==True\\n    assert valid_time('25:00')==False\\n    assert valid_time('14:30:45')==True\\n    assert valid_time('abc')==False\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef to_roman(n):\\n    v=[1000,900,500,400,100,90,50,40,10,9,5,4,1]\\n    s=['M','CM','D','CD','C','XC','L','XL','X','IX','V','IV','I']\\n    r=''\\n    for vv,ss in zip(v,s):\\n        while n>=vv: r+=ss; n-=vv\\n    return r\",\"response\":\"def test_roman():\\n    assert to_roman(4)=='IV' and to_roman(9)=='IX'\\n    assert to_roman(58)=='LVIII' and to_roman(1994)=='MCMXCIV'\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef from_roman(s):\\n    rom={'I':1,'V':5,'X':10,'L':50,'C':100,'D':500,'M':1000}\\n    t=0\\n    for i in range(len(s)):\\n        if i+1<len(s) and rom[s[i]]<rom[s[i+1]]: t-=rom[s[i]]\\n        else: t+=rom[s[i]]\\n    return t\",\"response\":\"def test_from_roman():\\n    assert from_roman('IV')==4 and from_roman('IX')==9\\n    assert from_roman('LVIII')==58 and from_roman('MCMXCIV')==1994\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
