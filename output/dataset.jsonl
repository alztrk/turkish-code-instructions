"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef hex_to_rgb(h):\\n    h=h.lstrip('#')\\n    return tuple(int(h[i:i+2],16) for i in (0,2,4))\",\"response\":\"def test_h2r():\\n    assert hex_to_rgb('#FF0000')==(255,0,0)\\n    assert hex_to_rgb('#00FF00')==(0,255,0)\\n    assert hex_to_rgb('#0000FF')==(0,0,255)\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
