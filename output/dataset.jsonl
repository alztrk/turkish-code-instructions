"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nimport random,string\\ndef rand_s(l): return ''.join(random.choices(string.ascii_letters+string.digits,k=l))\",\"response\":\"def test_rand_s():\\n    r1=rand_s(10); r2=rand_s(10)\\nassert len(r1)==10 and len(r2)==10 and r1!=r2\\nassert r1.isalnum()\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef d_comp(a,b):\\n    if type(a)!=type(b): return False\\n    if isinstance(a,dict): return a.keys()==b.keys() and all(d_comp(a[k],b[k]) for k in a)\\n    if isinstance(a,(list,tuple)): return len(a)==len(b) and all(d_comp(x,y) for x,y in zip(a,b))\\n    return a==b\",\"response\":\"def test_d_comp():\\n    assert d_comp({'a':[1,2]},{'a':[1,2]})==True\\n    assert d_comp({'a':[1,2]},{'a':[1,3]})==False\\n    assert d_comp([1,2],[1,2])==True\\n    assert d_comp('abc','abc')==True\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef once(fn):\\n    called=False; r=None\\n    def w(*a,**kw):\\n        nonlocal called,r\\n        if not called: r=fn(*a,**kw); called=True\\n        return r\\n    return w\",\"response\":\"def test_once_f():\\n    cc=0\\n@once\\ndef c(): nonlocal cc; cc+=1; return 42\\nassert c()==42 and c()==42 and cc==1\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef pipe(*fns):\\n    def apply(x):\\n        for fn in fns: x=fn(x)\\n        return x\\n    return apply\",\"response\":\"def test_pipe():\\n    f=pipe(lambda x:x+1,lambda x:x*2)\\nassert f(5)==12 and f(0)==2\\nassert pipe()(5)==5\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef compose(*fns):\\n    def apply(x):\\n        for fn in reversed(fns): x=fn(x)\\n        return x\\n    return apply\",\"response\":\"def test_compose():\\n    f=compose(lambda x:x+1,lambda x:x*2)\\nassert f(5)==11\\nassert compose()(5)==5\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef curry(fn):\\n    def c(*a):\\n        if len(a)>=fn.__code__.co_argcount: return fn(*a)\\n        return lambda *m: c(*a,*m)\\n    return c\",\"response\":\"def test_curry():\\n    @curry\\ndef add(a,b,c): return a+b+c\\nassert add(1)(2)(3)==6\\nassert add(1,2)(3)==6\\nassert add(1,2,3)==6\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef is_pow2(n): return n>0 and (n&(n-1))==0\",\"response\":\"def test_is_pow2():\\n    assert is_pow2(1)==True and is_pow2(16)==True\\n    assert is_pow2(0)==False and is_pow2(3)==False\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef to_bin(n):\\n    if n==0: return '0'\\n    r=''\\n    while n>0: r=str(n%2)+r; n//=2\\n    return r\",\"response\":\"def test_to_bin():\\n    assert to_bin(0)=='0' and to_bin(5)=='101'\\n    assert to_bin(255)=='11111111' and to_bin(1)=='1'\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef from_bin(b): return int(b,2)\",\"response\":\"def test_from_bin():\\n    assert from_bin('101')==5 and from_bin('0')==0\\n    assert from_bin('11111111')==255\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef caesar(text,shift):\\n    r=[]\\n    for c in text:\\n        if c.isalpha():\\n            base=ord('a') if c.islower() else ord('A')\\n            r.append(chr((ord(c)-base+shift)%26+base))\\n        else: r.append(c)\\n    return ''.join(r)\",\"response\":\"def test_caesar():\\n    assert caesar('abc',1)=='bcd'\\n    assert caesar('xyz',3)=='abc'\\n    assert caesar('Test',0)=='Test'\\n    assert caesar('123',5)=='123'\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef bal_paren(s):\\n    st=[]; p={')':'(',']':'[','}':'{'}\\n    for c in s:\\n        if c in '([{': st.append(c)\\n        elif c in ')]}':\\n            if not st or st.pop()!=p[c]: return False\\n    return len(st)==0\",\"response\":\"def test_bal():\\n    assert bal_paren('()[]{}')==True\\n    assert bal_paren('([)]')==False\\n    assert bal_paren('(')==False\\n    assert bal_paren('')==True\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef kmp(text,pat):\\n    n,m=len(text),len(pat)\\n    if m==0: return 0\\n    lps=[0]*m; j=0\\n    for i in range(1,m):\\n        while j>0 and pat[i]!=pat[j]: j=lps[j-1]\\n        if pat[i]==pat[j]: j+=1; lps[i]=j\\n    j=0\\n    for i in range(n):\\n        while j>0 and text[i]!=pat[j]: j=lps[j-1]\\n        if text[i]==pat[j]: j+=1\\n        if j==m: return i-m+1\\n    return -1\",\"response\":\"def test_kmp():\\n    assert kmp('ABABDABACDABABCABAB','ABABCABAB')==10\\n    assert kmp('hello','ll')==2\\n    assert kmp('hello','x')==-1\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef rk(text,pat):\\n    n,m=len(text),len(pat)\\n    if m==0: return 0\\n    d,q=256,101; h=pow(d,m-1,q); p=t=0\\n    for i in range(m): p=(d*p+ord(pat[i]))%q; t=(d*t+ord(text[i]))%q\\n    for i in range(n-m+1):\\n        if p==t and text[i:i+m]==pat: return i\\n        if i<n-m: t=(d*(t-ord(text[i])*h)+ord(text[i+m]))%q\\n    return -1\",\"response\":\"def test_rk():\\n    assert rk('2359023141526739921','31415')==6\\n    assert rk('hello','ll')==2\\n    assert rk('test','x')==-1\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef lps(s):\\n    n=len(s)\\n    if n<2: return s\\n    st,mx=0,1\\n    for i in range(n):\\n        for l,r in[(i,i),(i,i+1)]:\\n            while l>=0 and r<n and s[l]==s[r]:\\n                if r-l+1>mx: st,mx=l,r-l+1\\n                l-=1; r+=1\\n    return s[st:st+mx]\",\"response\":\"def test_lps():\\n    assert lps('babad') in ['bab','aba']\\n    assert lps('cbbd')=='bb'\\n    assert lps('a')=='a'\\n    assert lps('')==''\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef lcp(strs):\\n    if not strs: return ''\\n    p=strs[0]\\n    for s in strs[1:]:\\n        while not s.startswith(p):\\n            p=p[:-1]\\n            if not p: return ''\\n    return p\",\"response\":\"def test_lcp():\\n    assert lcp(['flower','flow','flight'])=='fl'\\n    assert lcp(['dog','racecar','car'])==''\\n    assert lcp([])==''\\n    assert lcp(['alone'])=='alone'\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nimport re\\ndef valid_postal(c): return bool(re.match(r'^\\\\d{5}(-\\\\d{4})?$',c))\",\"response\":\"def test_postal():\\n    assert valid_postal('12345')==True\\n    assert valid_postal('12345-6789')==True\\n    assert valid_postal('1234')==False\\n    assert valid_postal('abcde')==False\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
