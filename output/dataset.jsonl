"{\"instruction\":\"sync.Mutex ile eszamanli erisim.\",\"response\":\"package main\\nimport(\\\"fmt\\\";\\\"sync\\\")\\ntype S struct{mu sync.Mutex;v int}\\nfunc(s *S)A(){s.mu.Lock();s.v++;s.mu.Unlock()}\\nfunc main(){\\n  var s S;var wg sync.WaitGroup\\n  for i:=0;i<1000;i++{wg.Add(1);go func(){defer wg.Done();s.A()}()}\\n  wg.Wait();fmt.Println(s.v)\\n}\",\"language\":\"go\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
