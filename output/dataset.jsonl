"{\"instruction\":\"CTE (WITH) ile gecici tablo.\",\"response\":\"WITH yuksek AS (SELECT * FROM urun WHERE fiyat>100) SELECT * FROM yuksek;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Recursive CTE ile hiyerarsi.\",\"response\":\"WITH RECURSIVE alt AS (SELECT id,ad,ust_id FROM kategori WHERE ust_id IS NULL UNION ALL SELECT k.id,k.ad,k.ust_id FROM kategori k JOIN alt a ON k.ust_id=a.id) SELECT * FROM alt;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"ROW_NUMBER ile sira.\",\"response\":\"SELECT ad,fiyat,ROW_NUMBER() OVER(ORDER BY fiyat DESC) AS sira FROM urun;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"RANK ve DENSE_RANK ile siralama.\",\"response\":\"SELECT ad,puan,RANK() OVER(ORDER BY puan DESC) AS r,DENSE_RANK() OVER(ORDER BY puan DESC) AS dr FROM ogrenci;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"LAG ile onceki deger.\",\"response\":\"SELECT tarih,tutar,LAG(tutar,1) OVER(ORDER BY tarih) AS onceki FROM satis;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"LEAD ile sonraki deger.\",\"response\":\"SELECT tarih,tutar,LEAD(tutar,1) OVER(ORDER BY tarih) AS sonraki FROM satis;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"SUM OVER ile kumulatif.\",\"response\":\"SELECT tarih,tutar,SUM(tutar) OVER(ORDER BY tarih) AS kumulatif FROM satis;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"AVG OVER ile hareketli ortalama.\",\"response\":\"SELECT tarih,tutar,AVG(tutar) OVER(ORDER BY tarih ROWS BETWEEN 2 PRECEDING AND CURRENT ROW) AS ortalama FROM satis;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"FIRST_VALUE ve LAST_VALUE.\",\"response\":\"SELECT ad,bolum,maas,FIRST_VALUE(ad) OVER(PARTITION BY bolum ORDER BY maas DESC) AS en_yuksek FROM calisan;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"NTILE ile dilimlere ayirma.\",\"response\":\"SELECT ad,maas,NTILE(4) OVER(ORDER BY maas DESC) AS dilim FROM calisan;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"CUME_DIST ile kumulatif dagilim.\",\"response\":\"SELECT ad,maas,CUME_DIST() OVER(ORDER BY maas) FROM calisan;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"PERCENT_RANK ile yuzdelik.\",\"response\":\"SELECT ad,maas,PERCENT_RANK() OVER(ORDER BY maas) FROM calisan;\",\"language\":\"sql\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
