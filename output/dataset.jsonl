"{\"instruction\":\"Edmonds-Karp algoritmasini (BFS ile max flow) uygulayan fonksiyon yaz\",\"response\":\"func EdmondsKarp(graph [][]int, source, sink int) int {\\n    n := len(graph); residual := make([][]int, n)\\n    for i := range residual { residual[i] = make([]int, n); copy(residual[i], graph[i]) }\\n    flow := 0\\n    for {\\n        parent := make([]int, n); for i := range parent { parent[i] = -1 }\\n        q := []int{source}; parent[source] = -2\\n        for len(q) > 0 && parent[sink] == -1 { u := q[0]; q = q[1:]; for v := 0; v < n; v++ { if parent[v] == -1 && residual[u][v] > 0 { parent[v] = u; q = append(q, v) } } }\\n        if parent[sink] == -1 { break }\\n        pathFlow := 1 << 31\\n        for v := sink; v != source; v = parent[v] { u := parent[v]; if residual[u][v] < pathFlow { pathFlow = residual[u][v] } }\\n        for v := sink; v != source; v = parent[v] { u := parent[v]; residual[u][v] -= pathFlow; residual[v][u] += pathFlow }\\n        flow += pathFlow\\n    }\\n    return flow\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
