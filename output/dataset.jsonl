"{\"instruction\":\"Stream ile listeyi buyuk harfe cevirip Collectors.toList ile topla.\",\"response\":\"import java.util.*;\\nimport java.util.stream.*;\\nList<String> isimler = Arrays.asList(\\\"ali\\\", \\\"ayse\\\", \\\"mehmet\\\");\\nList<String> buyuk = isimler.stream().map(String::toUpperCase).collect(Collectors.toList());\\nSystem.out.println(buyuk);\",\"language\":\"java\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Stream ile ogeleri gruplamak icin Collectors.groupingBy kullan.\",\"response\":\"import java.util.*;\\nimport java.util.stream.*;\\nList<String> kelimeler = Arrays.asList(\\\"elma\\\",\\\"armut\\\",\\\"muz\\\",\\\"erik\\\",\\\"ayva\\\");\\nMap<Character, List<String>> gruplanmis = kelimeler.stream().collect(Collectors.groupingBy(k -> k.charAt(0)));\\nSystem.out.println(gruplanmis);\",\"language\":\"java\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Stream ile sayilari cift/tek diye ayirmak icin partitioningBy kullan.\",\"response\":\"import java.util.*;\\nimport java.util.stream.*;\\nList<Integer> sayilar = Arrays.asList(1,2,3,4,5,6);\\nMap<Boolean, List<Integer>> ayrilmis = sayilar.stream().collect(Collectors.partitioningBy(s -> s % 2 == 0));\\nSystem.out.println(\\\"Cift: \\\" + ayrilmis.get(true) + \\\" Tek: \\\" + ayrilmis.get(false));\",\"language\":\"java\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"Stream flatMap ile ic ice listeleri tek bir listede birlestir.\",\"response\":\"import java.util.*;\\nimport java.util.stream.*;\\nList<List<Integer>> icice = Arrays.asList(Arrays.asList(1,2), Arrays.asList(3,4,5), Arrays.asList(6));\\nList<Integer> duz = icice.stream().flatMap(List::stream).collect(Collectors.toList());\\nSystem.out.println(duz);\",\"language\":\"java\",\"category\":\"manual\",\"type\":\"manual\",\"format\":\"standard\"}"
