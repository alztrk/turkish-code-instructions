"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nfrom datetime import datetime\\ndef age_from_bd(bd):\\n    b=datetime.strptime(bd,'%Y-%m-%d'); t=datetime.now()\\n    age=t.year-b.year\\n    if (t.month,t.day)<(b.month,b.day): age-=1\\n    return age\",\"response\":\"def test_age():\\n    age=age_from_bd('1990-06-15')\\nassert isinstance(age,int) and age>=0\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\nfrom datetime import datetime,timedelta\\ndef add_days(d,n): return (datetime.strptime(d,'%Y-%m-%d')+timedelta(days=n)).strftime('%Y-%m-%d')\",\"response\":\"def test_add_d():\\n    assert add_days('2024-01-01',10)=='2024-01-11'\\n    assert add_days('2024-01-01',-1)=='2023-12-31'\\n    assert add_days('2024-12-31',1)=='2025-01-01'\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
