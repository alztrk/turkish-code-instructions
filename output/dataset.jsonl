"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef fizzbuzz(n):\\n    r=[]\\n    for i in range(1,n+1):\\n        if i%15==0: r.append('FizzBuzz')\\n        elif i%3==0: r.append('Fizz')\\n        elif i%5==0: r.append('Buzz')\\n        else: r.append(str(i))\\n    return r\",\"response\":\"def test_fizz():\\n    assert fizzbuzz(5)==['1','2','Fizz','4','Buzz']\\n    assert fizzbuzz(0)==[]\\n    assert fizzbuzz(15)[14]=='FizzBuzz'\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
