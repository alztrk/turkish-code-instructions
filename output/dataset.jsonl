"{\"instruction\":\"Tarjan algoritmasini (guclu bagli bilesen) uygulayan fonksiyon yaz\",\"response\":\"func Tarjan(graph [][]int) [][]int {\\n    n := len(graph); index := 0; indices := make([]int, n); lowlink := make([]int, n); onStack := make([]bool, n); stack := make([]int, 0); var sccs [][]int\\n    for i := range indices { indices[i] = -1 }\\n    var strongconnect func(int)\\n    strongconnect = func(v int) {\\n        indices[v] = index; lowlink[v] = index; index++; stack = append(stack, v); onStack[v] = true\\n        for _, w := range graph[v] {\\n            if indices[w] == -1 { strongconnect(w); if lowlink[w] < lowlink[v] { lowlink[v] = lowlink[w] } } else if onStack[w] && indices[w] < lowlink[v] { lowlink[v] = indices[w] }\\n        }\\n        if lowlink[v] == indices[v] { var comp []int; for { w := stack[len(stack)-1]; stack = stack[:len(stack)-1]; onStack[w] = false; comp = append(comp, w); if w == v { break } }; sccs = append(sccs, comp) }\\n    }\\n    for v := 0; v < n; v++ { if indices[v] == -1 { strongconnect(v) } }\\n    return sccs\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ford-Fulkerson algoritmasini (max flow) uygulayan fonksiyon yaz\",\"response\":\"from collections import deque\\ndef ford_fulkerson(graph, source, sink):\\n    n = len(graph); flow = 0\\n    while True:\\n        parent = [-1] * n; q = deque([source]); parent[source] = -2\\n        while q and parent[sink] == -1:\\n            u = q.popleft()\\n            for v in range(n):\\n                if parent[v] == -1 and graph[u][v] > 0: parent[v] = u; q.append(v)\\n        if parent[sink] == -1: break\\n        path_flow = float('inf'); v = sink\\n        while v != source: u = parent[v]; path_flow = min(path_flow, graph[u][v]); v = u\\n        v = sink\\n        while v != source: u = parent[v]; graph[u][v] -= path_flow; graph[v][u] += path_flow; v = u\\n        flow += path_flow\\n    return flow\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ford-Fulkerson algoritmasini (max flow) uygulayan fonksiyon yaz\",\"response\":\"function fordFulkerson(graph, source, sink) {\\n    const n = graph.length; let flow = 0;\\n    while (true) {\\n        const parent = new Array(n).fill(-1); const q = [source]; parent[source] = -2;\\n        while (q.length && parent[sink] === -1) { const u = q.shift(); for (let v = 0; v < n; v++) { if (parent[v] === -1 && graph[u][v] > 0) { parent[v] = u; q.push(v); } } }\\n        if (parent[sink] === -1) break;\\n        let pathFlow = Infinity; let v = sink;\\n        while (v !== source) { const u = parent[v]; pathFlow = Math.min(pathFlow, graph[u][v]); v = u; }\\n        v = sink;\\n        while (v !== source) { const u = parent[v]; graph[u][v] -= pathFlow; graph[v][u] += pathFlow; v = u; }\\n        flow += pathFlow;\\n    }\\n    return flow;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ford-Fulkerson algoritmasini (max flow) uygulayan fonksiyon yaz\",\"response\":\"public static int fordFulkerson(int[][] graph, int source, int sink) {\\n    int n = graph.length; int[][] residual = new int[n][n];\\n    for (int i = 0; i < n; i++) System.arraycopy(graph[i], 0, residual[i], 0, n);\\n    int flow = 0;\\n    while (true) {\\n        int[] parent = new int[n]; Arrays.fill(parent, -1);\\n        Queue<Integer> q = new LinkedList<>(); q.offer(source); parent[source] = -2;\\n        while (!q.isEmpty() && parent[sink] == -1) { int u = q.poll(); for (int v = 0; v < n; v++) { if (parent[v] == -1 && residual[u][v] > 0) { parent[v] = u; q.offer(v); } } }\\n        if (parent[sink] == -1) break;\\n        int pathFlow = Integer.MAX_VALUE;\\n        for (int v = sink; v != source; v = parent[v]) { int u = parent[v]; pathFlow = Math.min(pathFlow, residual[u][v]); }\\n        for (int v = sink; v != source; v = parent[v]) { int u = parent[v]; residual[u][v] -= pathFlow; residual[v][u] += pathFlow; }\\n        flow += pathFlow;\\n    }\\n    return flow;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ford-Fulkerson algoritmasini (max flow) uygulayan fonksiyon yaz\",\"response\":\"func FordFulkerson(graph [][]int, source, sink int) int {\\n    n := len(graph); residual := make([][]int, n)\\n    for i := range residual { residual[i] = make([]int, n); copy(residual[i], graph[i]) }\\n    flow := 0\\n    for {\\n        parent := make([]int, n); for i := range parent { parent[i] = -1 }\\n        q := []int{source}; parent[source] = -2\\n        for len(q) > 0 && parent[sink] == -1 { u := q[0]; q = q[1:]; for v := 0; v < n; v++ { if parent[v] == -1 && residual[u][v] > 0 { parent[v] = u; q = append(q, v) } } }\\n        if parent[sink] == -1 { break }\\n        pathFlow := 1 << 31\\n        for v := sink; v != source; v = parent[v] { u := parent[v]; if residual[u][v] < pathFlow { pathFlow = residual[u][v] } }\\n        for v := sink; v != source; v = parent[v] { u := parent[v]; residual[u][v] -= pathFlow; residual[v][u] += pathFlow }\\n        flow += pathFlow\\n    }\\n    return flow\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
