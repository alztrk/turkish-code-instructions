"{\"instruction\":\"Bir ürünün KDV'li fiyatını hesaplayan fonksiyon yaz.\",\"response\":\"function kdvliFiyatHesapla(fiyat, oran) {\\n  return fiyat + (fiyat * oran / 100);\\n}\\n\\nlet urunFiyati = 100;\\nlet kdvOrani = 18;\\nlet toplamTutar = kdvliFiyatHesapla(urunFiyati, kdvOrani);\\nconsole.log(toplamTutar);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir dizideki sayıların ortalamasını hesapla.\",\"response\":\"function ortalamaHesapla(dizi) {\\n  let toplam = 0;\\n  for (let index = 0; index < dizi.length; index++) {\\n    toplam += dizi[index];\\n  }\\n  return toplam / dizi.length;\\n}\\n\\nlet notlar = [70, 85, 90, 65, 80];\\nlet ortalama = ortalamaHesapla(notlar);\\nconsole.log(\\\"Ortalama: \\\" + ortalama);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir string'deki sesli harfleri sayan fonksiyon yaz.\",\"response\":\"function sesliHarfleriSay(kelime) {\\n  let sesliHarfler = [\\\"a\\\", \\\"e\\\", \\\"i\\\", \\\"o\\\", \\\"u\\\"];\\n  let sayac = 0;\\n  for (let index = 0; index < kelime.length; index++) {\\n    if (sesliHarfler.includes(kelime[index].toLowerCase())) {\\n      sayac++;\\n    }\\n  }\\n  return sayac;\\n}\\n\\nlet cumle = \\\"merhaba dunya\\\";\\nlet sonuc = sesliHarfleriSay(cumle);\\nconsole.log(sonuc);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Faktöriyel hesaplayan fonksiyon yaz.\",\"response\":\"function faktoriyelHesapla(sayi) {\\n  if (sayi === 0 || sayi === 1) {\\n    return 1;\\n  }\\n  let sonuc = 1;\\n  for (let index = 2; index <= sayi; index++) {\\n    sonuc *= index;\\n  }\\n  return sonuc;\\n}\\n\\nlet deger = 5;\\nconsole.log(deger + \\\"! = \\\" + faktoriyelHesapla(deger));\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir dizideki elemanları tersten sıralayan fonksiyon yaz.\",\"response\":\"function terstenSirala(dizi) {\\n  let yeniDizi = [];\\n  for (let index = dizi.length - 1; index >= 0; index--) {\\n    yeniDizi.push(dizi[index]);\\n  }\\n  return yeniDizi;\\n}\\n\\nlet liste = [1, 2, 3, 4, 5];\\nlet tersListe = terstenSirala(liste);\\nconsole.log(tersListe);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir kelimenin palindrom olup olmadığını kontrol et.\",\"response\":\"function palindromKontrol(kelime) {\\n  let temiz = kelime.toLowerCase();\\n  let ters = temiz.split(\\\"\\\").reverse().join(\\\"\\\");\\n  return temiz === ters;\\n}\\n\\nlet girdi = \\\"kabak\\\";\\nlet sonuc = palindromKontrol(girdi);\\nconsole.log(girdi + \\\" palindrom mu? \\\" + sonuc);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir dizideki tek sayıların toplamını hesapla.\",\"response\":\"function tekSayilarinToplami(dizi) {\\n  let toplam = 0;\\n  for (let index = 0; index < dizi.length; index++) {\\n    if (dizi[index] % 2 !== 0) {\\n      toplam += dizi[index];\\n    }\\n  }\\n  return toplam;\\n}\\n\\nlet sayilar = [1, 2, 3, 4, 5, 6];\\nlet sonuc = tekSayilarinToplami(sayilar);\\nconsole.log(sonuc);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir string'deki boşlukları kaldıran fonksiyon yaz.\",\"response\":\"function bosluklariKaldir(cumle) {\\n  let sonuc = \\\"\\\";\\n  for (let index = 0; index < cumle.length; index++) {\\n    if (cumle[index] !== \\\" \\\") {\\n      sonuc += cumle[index];\\n    }\\n  }\\n  return sonuc;\\n}\\n\\nlet mesaj = \\\"merhaba dunya nasilsin\\\";\\nlet temizMesaj = bosluklariKaldir(mesaj);\\nconsole.log(temizMesaj);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"Bir sayının asal olup olmadığını kontrol eden fonksiyon yaz.\",\"response\":\"function asalKontrol(sayi) {\\n  if (sayi <= 1) return false;\\n  for (let index = 2; index < sayi; index++) {\\n    if (sayi % index === 0) {\\n      return false;\\n    }\\n  }\\n  return true;\\n}\\n\\nlet deger = 17;\\nconsole.log(deger + \\\" asal mi? \\\" + asalKontrol(deger));\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
"{\"instruction\":\"İki diziyi birleştirip sıralayan fonksiyon yaz.\",\"response\":\"function birlestirVeSirala(dizi1, dizi2) {\\n  let yeniDizi = dizi1.concat(dizi2);\\n  yeniDizi.sort(function(a, b) {\\n    return a - b;\\n  });\\n  return yeniDizi;\\n}\\n\\nlet liste1 = [3, 1, 4];\\nlet liste2 = [2, 5, 6];\\nlet siralanmis = birlestirVeSirala(liste1, liste2);\\nconsole.log(siralanmis);\",\"language\":\"javascript\",\"category\":\"javascript\",\"type\":\"manual\"}"
