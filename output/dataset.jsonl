"{\"instruction\":\"Ikili agac uzerinde preorder dolasma yapan fonksiyon yaz\",\"response\":\"public List<Integer> preorder(TreeNode root) {\\n    List<Integer> result = new ArrayList<>(); traverse(root, result); return result;\\n}\\nprivate void traverse(TreeNode node, List<Integer> result) {\\n    if (node == null) return;\\n    result.add(node.val); traverse(node.left, result); traverse(node.right, result);\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
