"{\"instruction\":\"Asagidaki fonksiyon icin unit test yaz:\\ndef valid_tc(tc):\\n    if len(tc)!=11 or not tc.isdigit(): return False\\n    d=list(map(int,tc))\\n    o=sum(d[0:10:2]); e=sum(d[1:9:2])\\n    if (o*7-e)%10!=d[9]: return False\\n    return sum(d[:10])%10==d[10]\",\"response\":\"def test_tc():\\n    assert valid_tc('10000000146')==True\\n    assert valid_tc('12345678901')==False\\n    assert valid_tc('abc')==False\\nimport pytest; pytest.main()\",\"language\":\"python\",\"category\":\"test\",\"type\":\"manual\",\"format\":\"test\"}"
