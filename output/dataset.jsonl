"{\"instruction\":\"Ikili agac uzerinde seviye seviye (level order) dolasma yapan fonksiyon yaz\",\"response\":\"from collections import deque\\ndef level_order(root):\\n    if not root: return []\\n    result = []; queue = deque([root])\\n    while queue:\\n        level = []\\n        for _ in range(len(queue)):\\n            node = queue.popleft(); level.append(node.val)\\n            if node.left: queue.append(node.left)\\n            if node.right: queue.append(node.right)\\n        result.append(level)\\n    return result\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ikili agac uzerinde seviye seviye (level order) dolasma yapan fonksiyon yaz\",\"response\":\"function levelOrder(root) {\\n    if (!root) return [];\\n    const result = []; const queue = [root];\\n    while (queue.length) {\\n        const level = []; const len = queue.length;\\n        for (let i = 0; i < len; i++) {\\n            const node = queue.shift(); level.push(node.val);\\n            if (node.left) queue.push(node.left); if (node.right) queue.push(node.right);\\n        }\\n        result.push(level);\\n    }\\n    return result;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ikili agac uzerinde seviye seviye (level order) dolasma yapan fonksiyon yaz\",\"response\":\"public List<List<Integer>> levelOrder(TreeNode root) {\\n    List<List<Integer>> result = new ArrayList<>();\\n    if (root == null) return result;\\n    Queue<TreeNode> queue = new LinkedList<>(); queue.offer(root);\\n    while (!queue.isEmpty()) {\\n        List<Integer> level = new ArrayList<>(); int len = queue.size();\\n        for (int i = 0; i < len; i++) {\\n            TreeNode node = queue.poll(); level.add(node.val);\\n            if (node.left != null) queue.offer(node.left);\\n            if (node.right != null) queue.offer(node.right);\\n        }\\n        result.add(level);\\n    }\\n    return result;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ikili agacin maksimum derinligini bulan fonksiyon yaz\",\"response\":\"def max_depth(root):\\n    if not root: return 0\\n    return 1 + max(max_depth(root.left), max_depth(root.right))\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ikili agacin maksimum derinligini bulan fonksiyon yaz\",\"response\":\"function maxDepth(root) { if (!root) return 0; return 1 + Math.max(maxDepth(root.left), maxDepth(root.right)); }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ikili agacin maksimum derinligini bulan fonksiyon yaz\",\"response\":\"func MaxDepth(root *TreeNode) int {\\n    if root == nil { return 0 }\\n    left := MaxDepth(root.Left); right := MaxDepth(root.Right)\\n    if left > right { return 1 + left }; return 1 + right\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir ikili agacin gecerli bir ikili arama agaci (BST) olup olmadigini kontrol eden fonksiyon yaz\",\"response\":\"def is_valid_bst(root):\\n    def validate(node, low, high):\\n        if not node: return True\\n        if node.val <= low or node.val >= high: return False\\n        return validate(node.left, low, node.val) and validate(node.right, node.val, high)\\n    return validate(root, float('-inf'), float('inf'))\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir ikili agacin gecerli bir ikili arama agaci (BST) olup olmadigini kontrol eden fonksiyon yaz\",\"response\":\"function isValidBST(root) {\\n    function validate(node, low, high) {\\n        if (!node) return true;\\n        if (node.val <= low || node.val >= high) return false;\\n        return validate(node.left, low, node.val) && validate(node.right, node.val, high);\\n    }\\n    return validate(root, -Infinity, Infinity);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bir ikili agacin gecerli bir ikili arama agaci (BST) olup olmadigini kontrol eden fonksiyon yaz\",\"response\":\"public boolean isValidBST(TreeNode root) {\\n    return validate(root, Long.MIN_VALUE, Long.MAX_VALUE);\\n}\\nprivate boolean validate(TreeNode node, long low, long high) {\\n    if (node == null) return true;\\n    if (node.val <= low || node.val >= high) return false;\\n    return validate(node.left, low, node.val) && validate(node.right, node.val, high);\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Graf uzerinde genislik oncelikli arama (BFS) yapan fonksiyon yaz\",\"response\":\"from collections import deque\\ndef bfs(graph, start):\\n    visited = {start}; queue = deque([start]); result = []\\n    while queue:\\n        node = queue.popleft(); result.append(node)\\n        for neighbor in graph[node]:\\n            if neighbor not in visited: visited.add(neighbor); queue.append(neighbor)\\n    return result\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Graf uzerinde genislik oncelikli arama (BFS) yapan fonksiyon yaz\",\"response\":\"function bfs(graph, start) {\\n    const visited = new Set([start]); const queue = [start]; const result = [];\\n    while (queue.length) {\\n        const node = queue.shift(); result.push(node);\\n        for (const neighbor of graph[node]) {\\n            if (!visited.has(neighbor)) { visited.add(neighbor); queue.push(neighbor); }\\n        }\\n    }\\n    return result;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Graf uzerinde genislik oncelikli arama (BFS) yapan fonksiyon yaz\",\"response\":\"func BFS(graph map[int][]int, start int) []int {\\n    visited := map[int]bool{start: true}; queue := []int{start}; var result []int\\n    for len(queue) > 0 {\\n        node := queue[0]; queue = queue[1:]; result = append(result, node)\\n        for _, neighbor := range graph[node] {\\n            if !visited[neighbor] { visited[neighbor] = true; queue = append(queue, neighbor) }\\n        }\\n    }\\n    return result\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Graf uzerinde derinlik oncelikli arama (DFS) yapan fonksiyon yaz\",\"response\":\"def dfs(graph, start):\\n    visited = set(); result = []\\n    def explore(node):\\n        visited.add(node); result.append(node)\\n        for neighbor in graph[node]:\\n            if neighbor not in visited: explore(neighbor)\\n    explore(start)\\n    return result\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Graf uzerinde derinlik oncelikli arama (DFS) yapan fonksiyon yaz\",\"response\":\"function dfs(graph, start) {\\n    const visited = new Set(); const result = [];\\n    function explore(node) {\\n        visited.add(node); result.push(node);\\n        for (const neighbor of graph[node]) { if (!visited.has(neighbor)) explore(neighbor); }\\n    }\\n    explore(start); return result;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Graf uzerinde derinlik oncelikli arama (DFS) yapan fonksiyon yaz\",\"response\":\"public List<Integer> dfs(Map<Integer, List<Integer>> graph, int start) {\\n    Set<Integer> visited = new HashSet<>(); List<Integer> result = new ArrayList<>();\\n    explore(graph, start, visited, result); return result;\\n}\\nprivate void explore(Map<Integer, List<Integer>> graph, int node, Set<Integer> visited, List<Integer> result) {\\n    visited.add(node); result.add(node);\\n    for (int neighbor : graph.get(node)) { if (!visited.contains(neighbor)) explore(graph, neighbor, visited, result); }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Min heap (en kucuk yigin) veri yapisini uygulayan sinif yaz\",\"response\":\"class MinHeap:\\n    def __init__(self): self.heap = []\\n    def parent(self, i): return (i - 1) // 2\\n    def left(self, i): return 2 * i + 1\\n    def right(self, i): return 2 * i + 2\\n    def insert(self, val):\\n        self.heap.append(val); i = len(self.heap) - 1\\n        while i > 0 and self.heap[i] < self.heap[self.parent(i)]:\\n            self.heap[i], self.heap[self.parent(i)] = self.heap[self.parent(i)], self.heap[i]\\n            i = self.parent(i)\\n    def extract_min(self):\\n        if not self.heap: return None\\n        min_val = self.heap[0]; self.heap[0] = self.heap.pop()\\n        self._heapify(0); return min_val\\n    def _heapify(self, i):\\n        smallest = i; l, r = self.left(i), self.right(i)\\n        if l < len(self.heap) and self.heap[l] < self.heap[smallest]: smallest = l\\n        if r < len(self.heap) and self.heap[r] < self.heap[smallest]: smallest = r\\n        if smallest != i:\\n            self.heap[i], self.heap[smallest] = self.heap[smallest], self.heap[i]\\n            self._heapify(smallest)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Min heap (en kucuk yigin) veri yapisini uygulayan sinif yaz\",\"response\":\"class MinHeap {\\n    constructor() { this.heap = []; }\\n    parent(i) { return Math.floor((i - 1) / 2); }\\n    left(i) { return 2 * i + 1; }\\n    right(i) { return 2 * i + 2; }\\n    insert(val) {\\n        this.heap.push(val); let i = this.heap.length - 1;\\n        while (i > 0 && this.heap[i] < this.heap[this.parent(i)]) {\\n            [this.heap[i], this.heap[this.parent(i)]] = [this.heap[this.parent(i)], this.heap[i]];\\n            i = this.parent(i);\\n        }\\n    }\\n    extractMin() { if (!this.heap.length) return null; const min = this.heap[0]; this.heap[0] = this.heap.pop(); this.heapify(0); return min; }\\n    heapify(i) {\\n        let smallest = i; const l = this.left(i), r = this.right(i);\\n        if (l < this.heap.length && this.heap[l] < this.heap[smallest]) smallest = l;\\n        if (r < this.heap.length && this.heap[r] < this.heap[smallest]) smallest = r;\\n        if (smallest !== i) { [this.heap[i], this.heap[smallest]] = [this.heap[smallest], this.heap[i]]; this.heapify(smallest); }\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Min heap (en kucuk yigin) veri yapisini uygulayan sinif yaz\",\"response\":\"public class MinHeap {\\n    private List<Integer> heap = new ArrayList<>();\\n    private int parent(int i) { return (i - 1) / 2; }\\n    private int left(int i) { return 2 * i + 1; }\\n    private int right(int i) { return 2 * i + 2; }\\n    public void insert(int val) {\\n        heap.add(val); int i = heap.size() - 1;\\n        while (i > 0 && heap.get(i) < heap.get(parent(i))) { Collections.swap(heap, i, parent(i)); i = parent(i); }\\n    }\\n    public int extractMin() {\\n        if (heap.isEmpty()) return -1;\\n        int min = heap.get(0); heap.set(0, heap.remove(heap.size() - 1)); heapify(0); return min;\\n    }\\n    private void heapify(int i) {\\n        int smallest = i, l = left(i), r = right(i);\\n        if (l < heap.size() && heap.get(l) < heap.get(smallest)) smallest = l;\\n        if (r < heap.size() && heap.get(r) < heap.get(smallest)) smallest = r;\\n        if (smallest != i) { Collections.swap(heap, i, smallest); heapify(smallest); }\\n    }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Oncelikli kuyruk (priority queue) veri yapisini uygulayan sinif yaz\",\"response\":\"import heapq\\nclass PriorityQueue:\\n    def __init__(self): self.heap = []\\n    def push(self, item, priority): heapq.heappush(self.heap, (priority, item))\\n    def pop(self): return None if not self.heap else heapq.heappop(self.heap)[1]\\n    def peek(self): return None if not self.heap else self.heap[0][1]\\n    def is_empty(self): return len(self.heap) == 0\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Oncelikli kuyruk (priority queue) veri yapisini uygulayan sinif yaz\",\"response\":\"class PriorityQueue {\\n    constructor() { this.heap = []; }\\n    push(item, priority) {\\n        this.heap.push({item, priority}); let i = this.heap.length - 1;\\n        while (i > 0) {\\n            const p = Math.floor((i - 1) / 2);\\n            if (this.heap[i].priority >= this.heap[p].priority) break;\\n            [this.heap[i], this.heap[p]] = [this.heap[p], this.heap[i]]; i = p;\\n        }\\n    }\\n    pop() {\\n        if (!this.heap.length) return null; const top = this.heap[0];\\n        this.heap[0] = this.heap.pop(); let i = 0;\\n        while (true) {\\n            let smallest = i, l = 2*i+1, r = 2*i+2;\\n            if (l < this.heap.length && this.heap[l].priority < this.heap[smallest].priority) smallest = l;\\n            if (r < this.heap.length && this.heap[r].priority < this.heap[smallest].priority) smallest = r;\\n            if (smallest === i) break;\\n            [this.heap[i], this.heap[smallest]] = [this.heap[smallest], this.heap[i]]; i = smallest;\\n        }\\n        return top.item;\\n    }\\n    isEmpty() { return this.heap.length === 0; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Oncelikli kuyruk (priority queue) veri yapisini uygulayan sinif yaz\",\"response\":\"type PriorityQueue struct { items []struct{ item interface{}; priority int } }\\nfunc (pq *PriorityQueue) Push(item interface{}, priority int) {\\n    pq.items = append(pq.items, struct{ item interface{}; priority int }{item, priority})\\n    i := len(pq.items) - 1\\n    for i > 0 {\\n        p := (i - 1) / 2; if pq.items[i].priority >= pq.items[p].priority { break }\\n        pq.items[i], pq.items[p] = pq.items[p], pq.items[i]; i = p\\n    }\\n}\\nfunc (pq *PriorityQueue) Pop() interface{} {\\n    if len(pq.items) == 0 { return nil }; top := pq.items[0]\\n    pq.items[0] = pq.items[len(pq.items)-1]; pq.items = pq.items[:len(pq.items)-1]\\n    i := 0\\n    for {\\n        smallest := i; l, r := 2*i+1, 2*i+2\\n        if l < len(pq.items) && pq.items[l].priority < pq.items[smallest].priority { smallest = l }\\n        if r < len(pq.items) && pq.items[r].priority < pq.items[smallest].priority { smallest = r }\\n        if smallest == i { break }\\n        pq.items[i], pq.items[smallest] = pq.items[smallest], pq.items[i]; i = smallest\\n    }\\n    return top.item\\n}\\nfunc (pq *PriorityQueue) IsEmpty() bool { return len(pq.items) == 0 }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Basit bir hash map (sozluk) veri yapisini uygulayan sinif yaz\",\"response\":\"class HashMap:\\n    def __init__(self, capacity=16):\\n        self.capacity = capacity; self.size = 0\\n        self.buckets = [[] for _ in range(capacity)]\\n    def _hash(self, key): return hash(key) % self.capacity\\n    def put(self, key, value):\\n        idx = self._hash(key)\\n        for i, (k, v) in enumerate(self.buckets[idx]):\\n            if k == key: self.buckets[idx][i] = (key, value); return\\n        self.buckets[idx].append((key, value)); self.size += 1\\n    def get(self, key):\\n        idx = self._hash(key)\\n        for k, v in self.buckets[idx]:\\n            if k == key: return v\\n        return None\\n    def remove(self, key):\\n        idx = self._hash(key)\\n        for i, (k, v) in enumerate(self.buckets[idx]):\\n            if k == key: del self.buckets[idx][i]; self.size -= 1; return True\\n        return False\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Basit bir hash map (sozluk) veri yapisini uygulayan sinif yaz\",\"response\":\"class HashMap {\\n    constructor(capacity = 16) { this.capacity = capacity; this.buckets = Array.from({length: capacity}, () => []); this.size = 0; }\\n    _hash(key) { let h = 0; const s = String(key); for (let i = 0; i < s.length; i++) h = ((h << 5) - h) + s.charCodeAt(i) | 0; return Math.abs(h) % this.capacity; }\\n    put(key, value) {\\n        const idx = this._hash(key); const bucket = this.buckets[idx];\\n        for (let i = 0; i < bucket.length; i++) { if (bucket[i][0] === key) { bucket[i][1] = value; return; } }\\n        bucket.push([key, value]); this.size++;\\n    }\\n    get(key) { const idx = this._hash(key); for (const [k, v] of this.buckets[idx]) if (k === key) return v; return null; }\\n    remove(key) { const idx = this._hash(key); const bucket = this.buckets[idx]; for (let i = 0; i < bucket.length; i++) { if (bucket[i][0] === key) { bucket.splice(i, 1); this.size--; return true; } } return false; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Basit bir hash map (sozluk) veri yapisini uygulayan sinif yaz\",\"response\":\"type HashMap struct { buckets [][]struct{ key, value interface{} }; size, capacity int }\\nfunc NewHashMap(capacity int) *HashMap {\\n    b := make([][]struct{ key, value interface{} }, capacity)\\n    for i := range b { b[i] = make([]struct{ key, value interface{} }, 0) }\\n    return &HashMap{buckets: b, capacity: capacity}\\n}\\nfunc (m *HashMap) hash(key interface{}) int {\\n    h := 0; s := fmt.Sprint(key)\\n    for _, c := range s { h = int(c) + (h << 6) + (h << 16) - h }\\n    if h < 0 { h = -h }; return h % m.capacity\\n}\\nfunc (m *HashMap) Put(key, value interface{}) {\\n    idx := m.hash(key)\\n    for i, e := range m.buckets[idx] { if e.key == key { m.buckets[idx][i].value = value; return } }\\n    m.buckets[idx] = append(m.buckets[idx], struct{ key, value interface{} }{key, value}); m.size++\\n}\\nfunc (m *HashMap) Get(key interface{}) interface{} {\\n    idx := m.hash(key)\\n    for _, e := range m.buckets[idx] { if e.key == key { return e.value } }\\n    return nil\\n}\\nfunc (m *HashMap) Remove(key interface{}) bool {\\n    idx := m.hash(key)\\n    for i, e := range m.buckets[idx] {\\n        if e.key == key { m.buckets[idx] = append(m.buckets[idx][:i], m.buckets[idx][i+1:]...); m.size--; return true }\\n    }\\n    return false\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iki kume uzerinde kesisim, birlestirme ve fark islemlerini yapan fonksiyonlar yaz\",\"response\":\"def union(s1, s2): return s1 | s2\\ndef intersection(s1, s2): return s1 & s2\\ndef difference(s1, s2): return s1 - s2\\ndef symmetric_difference(s1, s2): return s1 ^ s2\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iki kume uzerinde kesisim, birlestirme ve fark islemlerini yapan fonksiyonlar yaz\",\"response\":\"function union(s1, s2) { return new Set([...s1, ...s2]); }\\nfunction intersection(s1, s2) { return new Set([...s1].filter(x => s2.has(x))); }\\nfunction difference(s1, s2) { return new Set([...s1].filter(x => !s2.has(x))); }\\nfunction symmetricDifference(s1, s2) { return new Set([...s1].filter(x => !s2.has(x)).concat([...s2].filter(x => !s1.has(x)))); }\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iki kume uzerinde kesisim, birlestirme ve fark islemlerini yapan fonksiyonlar yaz\",\"response\":\"public static <T> Set<T> union(Set<T> s1, Set<T> s2) { Set<T> r = new HashSet<>(s1); r.addAll(s2); return r; }\\npublic static <T> Set<T> intersection(Set<T> s1, Set<T> s2) { Set<T> r = new HashSet<>(s1); r.retainAll(s2); return r; }\\npublic static <T> Set<T> difference(Set<T> s1, Set<T> s2) { Set<T> r = new HashSet<>(s1); r.removeAll(s2); return r; }\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"LRU (Least Recently Used) onbellek mekanizmasini uygulayan sinif yaz\",\"response\":\"from collections import OrderedDict\\nclass LRUCache:\\n    def __init__(self, capacity):\\n        self.cache = OrderedDict(); self.capacity = capacity\\n    def get(self, key):\\n        if key not in self.cache: return -1\\n        self.cache.move_to_end(key); return self.cache[key]\\n    def put(self, key, value):\\n        if key in self.cache: self.cache.move_to_end(key)\\n        self.cache[key] = value\\n        if len(self.cache) > self.capacity: self.cache.popitem(last=False)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"LRU (Least Recently Used) onbellek mekanizmasini uygulayan sinif yaz\",\"response\":\"class LRUCache {\\n    constructor(capacity) { this.capacity = capacity; this.cache = new Map(); }\\n    get(key) {\\n        if (!this.cache.has(key)) return -1;\\n        const val = this.cache.get(key);\\n        this.cache.delete(key); this.cache.set(key, val); return val;\\n    }\\n    put(key, value) {\\n        if (this.cache.has(key)) this.cache.delete(key);\\n        this.cache.set(key, value);\\n        if (this.cache.size > this.capacity) { const first = this.cache.keys().next().value; this.cache.delete(first); }\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"LRU (Least Recently Used) onbellek mekanizmasini uygulayan sinif yaz\",\"response\":\"public class LRUCache<K, V> extends LinkedHashMap<K, V> {\\n    private final int capacity;\\n    public LRUCache(int capacity) { super(capacity, 0.75f, true); this.capacity = capacity; }\\n    public V get(K key) { return super.getOrDefault(key, null); }\\n    @Override\\n    protected boolean removeEldestEntry(Map.Entry<K, V> eldest) { return size() > capacity; }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Trie (on ek agaci) veri yapisini uygulayan sinif yaz\",\"response\":\"class TrieNode:\\n    def __init__(self): self.children = {}; self.is_end = False\\nclass Trie:\\n    def __init__(self): self.root = TrieNode()\\n    def insert(self, word):\\n        node = self.root\\n        for ch in word:\\n            if ch not in node.children: node.children[ch] = TrieNode()\\n            node = node.children[ch]\\n        node.is_end = True\\n    def search(self, word):\\n        node = self.root\\n        for ch in word:\\n            if ch not in node.children: return False\\n            node = node.children[ch]\\n        return node.is_end\\n    def starts_with(self, prefix):\\n        node = self.root\\n        for ch in prefix:\\n            if ch not in node.children: return False\\n            node = node.children[ch]\\n        return True\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Trie (on ek agaci) veri yapisini uygulayan sinif yaz\",\"response\":\"class TrieNode { constructor() { this.children = {}; this.isEnd = false; } }\\nclass Trie {\\n    constructor() { this.root = new TrieNode(); }\\n    insert(word) {\\n        let node = this.root;\\n        for (const ch of word) { if (!node.children[ch]) node.children[ch] = new TrieNode(); node = node.children[ch]; }\\n        node.isEnd = true;\\n    }\\n    search(word) {\\n        let node = this.root;\\n        for (const ch of word) { if (!node.children[ch]) return false; node = node.children[ch]; }\\n        return node.isEnd;\\n    }\\n    startsWith(prefix) {\\n        let node = this.root;\\n        for (const ch of prefix) { if (!node.children[ch]) return false; node = node.children[ch]; }\\n        return true;\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Trie (on ek agaci) veri yapisini uygulayan sinif yaz\",\"response\":\"type TrieNode struct { children map[byte]*TrieNode; isEnd bool }\\ntype Trie struct { root *TrieNode }\\nfunc NewTrie() *Trie { return &Trie{root: &TrieNode{children: make(map[byte]*TrieNode)}} }\\nfunc (t *Trie) Insert(word string) {\\n    node := t.root\\n    for i := 0; i < len(word); i++ {\\n        ch := word[i]\\n        if node.children[ch] == nil { node.children[ch] = &TrieNode{children: make(map[byte]*TrieNode)} }\\n        node = node.children[ch]\\n    }\\n    node.isEnd = true\\n}\\nfunc (t *Trie) Search(word string) bool {\\n    node := t.root\\n    for i := 0; i < len(word); i++ {\\n        if node.children[word[i]] == nil { return false }\\n        node = node.children[word[i]]\\n    }\\n    return node.isEnd\\n}\\nfunc (t *Trie) StartsWith(prefix string) bool {\\n    node := t.root\\n    for i := 0; i < len(prefix); i++ {\\n        if node.children[prefix[i]] == nil { return false }\\n        node = node.children[prefix[i]]\\n    }\\n    return true\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bloom filtresi veri yapisini uygulayan sinif yaz\",\"response\":\"import hashlib\\nclass BloomFilter:\\n    def __init__(self, size, num_hashes):\\n        self.size = size; self.num_hashes = num_hashes; self.bits = [False] * size\\n    def _hashes(self, item): return [int(hashlib.md5(f'{item}{i}'.encode()).hexdigest(), 16) % self.size for i in range(self.num_hashes)]\\n    def add(self, item):\\n        for h in self._hashes(item): self.bits[h] = True\\n    def might_contain(self, item): return all(self.bits[h] for h in self._hashes(item))\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bloom filtresi veri yapisini uygulayan sinif yaz\",\"response\":\"class BloomFilter {\\n    constructor(size, numHashes) { this.size = size; this.numHashes = numHashes; this.bits = new Array(size).fill(false); }\\n    _hash(item, seed) { let h = 0; const s = String(item) + seed; for (let i = 0; i < s.length; i++) h = ((h << 5) - h) + s.charCodeAt(i) | 0; return Math.abs(h) % this.size; }\\n    add(item) { for (let i = 0; i < this.numHashes; i++) this.bits[this._hash(item, i)] = true; }\\n    mightContain(item) { for (let i = 0; i < this.numHashes; i++) if (!this.bits[this._hash(item, i)]) return false; return true; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Bloom filtresi veri yapisini uygulayan sinif yaz\",\"response\":\"type BloomFilter struct { bits []bool; size, numHashes int }\\nfunc NewBloomFilter(size, numHashes int) *BloomFilter { return &BloomFilter{bits: make([]bool, size), size: size, numHashes: numHashes} }\\nfunc (bf *BloomFilter) hash(item string, seed int) int {\\n    h := 0; s := fmt.Sprintf(\\\"%s%d\\\", item, seed)\\n    for _, c := range s { h = int(c) + (h << 6) + (h << 16) - h }\\n    if h < 0 { h = -h }; return h % bf.size\\n}\\nfunc (bf *BloomFilter) Add(item string) { for i := 0; i < bf.numHashes; i++ { bf.bits[bf.hash(item, i)] = true } }\\nfunc (bf *BloomFilter) MightContain(item string) bool { for i := 0; i < bf.numHashes; i++ { if !bf.bits[bf.hash(item, i)] { return false } }; return true }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Agirlikli rastgele secim yapan fonksiyon yaz\",\"response\":\"import random\\ndef weighted_random(items, weights):\\n    total = sum(weights); r = random.uniform(0, total); cum = 0\\n    for item, w in zip(items, weights):\\n        cum += w\\n        if r < cum: return item\\n    return items[-1]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Agirlikli rastgele secim yapan fonksiyon yaz\",\"response\":\"function weightedRandom(items, weights) {\\n    const total = weights.reduce((a, b) => a + b, 0);\\n    let r = Math.random() * total;\\n    for (let i = 0; i < items.length; i++) { r -= weights[i]; if (r <= 0) return items[i]; }\\n    return items[items.length - 1];\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Agirlikli rastgele secim yapan fonksiyon yaz\",\"response\":\"func WeightedRandom(items []string, weights []float64) string {\\n    total := 0.0; for _, w := range weights { total += w }\\n    r := rand.Float64() * total\\n    for i, w := range weights { r -= w; if r <= 0 { return items[i] } }\\n    return items[len(items)-1]\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rezervuar ornekleme (reservoir sampling) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import random\\ndef reservoir_sample(stream, k):\\n    reservoir = []\\n    for i, item in enumerate(stream):\\n        if i < k: reservoir.append(item)\\n        else:\\n            j = random.randint(0, i)\\n            if j < k: reservoir[j] = item\\n    return reservoir\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rezervuar ornekleme (reservoir sampling) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function reservoirSample(stream, k) {\\n    const reservoir = [];\\n    for (let i = 0; i < stream.length; i++) {\\n        if (i < k) reservoir.push(stream[i]);\\n        else { const j = Math.floor(Math.random() * (i + 1)); if (j < k) reservoir[j] = stream[i]; }\\n    }\\n    return reservoir;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rezervuar ornekleme (reservoir sampling) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static <T> List<T> reservoirSample(List<T> stream, int k) {\\n    List<T> reservoir = new ArrayList<>(k); Random rand = new Random();\\n    for (int i = 0; i < stream.size(); i++) {\\n        if (i < k) reservoir.add(stream.get(i));\\n        else { int j = rand.nextInt(i + 1); if (j < k) reservoir.set(j, stream.get(i)); }\\n    }\\n    return reservoir;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Round-robin yuk dengeleyici (load balancer) algoritmasi uygulayan sinif yaz\",\"response\":\"class RoundRobinLoadBalancer:\\n    def __init__(self, servers): self.servers = servers; self.index = 0\\n    def next(self):\\n        server = self.servers[self.index]\\n        self.index = (self.index + 1) % len(self.servers)\\n        return server\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Round-robin yuk dengeleyici (load balancer) algoritmasi uygulayan sinif yaz\",\"response\":\"class RoundRobinLoadBalancer {\\n    constructor(servers) { this.servers = servers; this.index = 0; }\\n    next() { const s = this.servers[this.index]; this.index = (this.index + 1) % this.servers.length; return s; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Round-robin yuk dengeleyici (load balancer) algoritmasi uygulayan sinif yaz\",\"response\":\"type RoundRobinLB struct { servers []string; index int; mu sync.Mutex }\\nfunc NewRoundRobinLB(servers []string) *RoundRobinLB { return &RoundRobinLB{servers: servers} }\\nfunc (lb *RoundRobinLB) Next() string { lb.mu.Lock(); defer lb.mu.Unlock(); s := lb.servers[lb.index]; lb.index = (lb.index + 1) % len(lb.servers); return s }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Basit bir hiz sinirlayici (rate limiter) uygulayan sinif yaz\",\"response\":\"import time\\nclass RateLimiter:\\n    def __init__(self, max_requests, window_seconds):\\n        self.max_requests = max_requests; self.window = window_seconds; self.requests = []\\n    def allow(self):\\n        now = time.time()\\n        self.requests = [t for t in self.requests if now - t < self.window]\\n        if len(self.requests) < self.max_requests: self.requests.append(now); return True\\n        return False\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Basit bir hiz sinirlayici (rate limiter) uygulayan sinif yaz\",\"response\":\"class RateLimiter {\\n    constructor(maxRequests, windowMs) { this.maxRequests = maxRequests; this.window = windowMs; this.requests = []; }\\n    allow() {\\n        const now = Date.now(); this.requests = this.requests.filter(t => now - t < this.window);\\n        if (this.requests.length < this.maxRequests) { this.requests.push(now); return true; }\\n        return false;\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Basit bir hiz sinirlayici (rate limiter) uygulayan sinif yaz\",\"response\":\"type RateLimiter struct { maxRequests int; window time.Duration; requests []time.Time; mu sync.Mutex }\\nfunc NewRateLimiter(maxRequests int, window time.Duration) *RateLimiter { return &RateLimiter{maxRequests: maxRequests, window: window} }\\nfunc (rl *RateLimiter) Allow() bool {\\n    rl.mu.Lock(); defer rl.mu.Unlock()\\n    now := time.Now(); cutoff := now.Add(-rl.window)\\n    filtered := make([]time.Time, 0)\\n    for _, t := range rl.requests { if t.After(cutoff) { filtered = append(filtered, t) } }\\n    rl.requests = filtered\\n    if len(rl.requests) < rl.maxRequests { rl.requests = append(rl.requests, now); return true }\\n    return false\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Circuit breaker (devre kesici) desenini uygulayan sinif yaz\",\"response\":\"import time\\nclass CircuitBreaker:\\n    def __init__(self, failure_threshold, recovery_timeout):\\n        self.failure_threshold = failure_threshold; self.recovery_timeout = recovery_timeout\\n        self.failure_count = 0; self.last_failure_time = 0; self.state = 'CLOSED'\\n    def call(self, func, *args, **kwargs):\\n        if self.state == 'OPEN':\\n            if time.time() - self.last_failure_time > self.recovery_timeout: self.state = 'HALF_OPEN'\\n            else: raise Exception('Circuit breaker is OPEN')\\n        try:\\n            result = func(*args, **kwargs)\\n            self.failure_count = 0; self.state = 'CLOSED'; return result\\n        except Exception as e:\\n            self.failure_count += 1; self.last_failure_time = time.time()\\n            if self.failure_count >= self.failure_threshold: self.state = 'OPEN'\\n            raise e\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Circuit breaker (devre kesici) desenini uygulayan sinif yaz\",\"response\":\"class CircuitBreaker {\\n    constructor(failureThreshold, recoveryTimeoutMs) {\\n        this.failureThreshold = failureThreshold; this.recoveryTimeout = recoveryTimeoutMs;\\n        this.failureCount = 0; this.lastFailureTime = 0; this.state = 'CLOSED';\\n    }\\n    async call(fn, ...args) {\\n        if (this.state === 'OPEN') {\\n            if (Date.now() - this.lastFailureTime > this.recoveryTimeout) this.state = 'HALF_OPEN';\\n            else throw new Error('Circuit breaker is OPEN');\\n        }\\n        try {\\n            const result = await fn(...args);\\n            this.failureCount = 0; this.state = 'CLOSED'; return result;\\n        } catch (err) {\\n            this.failureCount++; this.lastFailureTime = Date.now();\\n            if (this.failureCount >= this.failureThreshold) this.state = 'OPEN';\\n            throw err;\\n        }\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Circuit breaker (devre kesici) desenini uygulayan sinif yaz\",\"response\":\"type CircuitBreaker struct { failureThreshold int; recoveryTimeout time.Duration; failureCount int; lastFailureTime time.Time; state string; mu sync.Mutex }\\nfunc NewCircuitBreaker(threshold int, timeout time.Duration) *CircuitBreaker {\\n    return &CircuitBreaker{failureThreshold: threshold, recoveryTimeout: timeout, state: \\\"CLOSED\\\"}\\n}\\nfunc (cb *CircuitBreaker) Call(fn func() (interface{}, error)) (interface{}, error) {\\n    cb.mu.Lock()\\n    if cb.state == \\\"OPEN\\\" {\\n        if time.Since(cb.lastFailureTime) > cb.recoveryTimeout { cb.state = \\\"HALF_OPEN\\\" } else { cb.mu.Unlock(); return nil, fmt.Errorf(\\\"circuit breaker is OPEN\\\") }\\n    }\\n    cb.mu.Unlock(); result, err := fn()\\n    cb.mu.Lock(); defer cb.mu.Unlock()\\n    if err != nil { cb.failureCount++; cb.lastFailureTime = time.Now(); if cb.failureCount >= cb.failureThreshold { cb.state = \\\"OPEN\\\" }; return nil, err }\\n    cb.failureCount = 0; cb.state = \\\"CLOSED\\\"; return result, nil\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Geriye donus ve bekleme ile tekrar deneme (retry) mekanizmasi uygulayan fonksiyon yaz\",\"response\":\"import time, random\\ndef retry(func, max_retries=3, base_delay=1, backoff_factor=2):\\n    for attempt in range(max_retries):\\n        try: return func()\\n        except Exception as e:\\n            if attempt == max_retries - 1: raise e\\n            delay = base_delay * (backoff_factor ** attempt) + random.uniform(0, 0.5)\\n            time.sleep(delay)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Geriye donus ve bekleme ile tekrar deneme (retry) mekanizmasi uygulayan fonksiyon yaz\",\"response\":\"async function retry(fn, maxRetries = 3, baseDelay = 1000, backoffFactor = 2) {\\n    for (let attempt = 0; attempt < maxRetries; attempt++) {\\n        try { return await fn(); }\\n        catch (err) {\\n            if (attempt === maxRetries - 1) throw err;\\n            const delay = baseDelay * Math.pow(backoffFactor, attempt) + Math.random() * 500;\\n            await new Promise(r => setTimeout(r, delay));\\n        }\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Geriye donus ve bekleme ile tekrar deneme (retry) mekanizmasi uygulayan fonksiyon yaz\",\"response\":\"public static <T> T retry(Supplier<T> func, int maxRetries, long baseDelayMs, double backoffFactor) {\\n    for (int attempt = 0; attempt < maxRetries; attempt++) {\\n        try { return func.get(); }\\n        catch (Exception e) {\\n            if (attempt == maxRetries - 1) throw e;\\n            long delay = (long) (baseDelayMs * Math.pow(backoffFactor, attempt) + Math.random() * 500);\\n            try { Thread.sleep(delay); } catch (InterruptedException ie) { Thread.currentThread().interrupt(); throw e; }\\n        }\\n    }\\n    return null;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Token bucket hiz sinirlama algoritmasini uygulayan sinif yaz\",\"response\":\"import time\\nclass TokenBucket:\\n    def __init__(self, capacity, fill_rate):\\n        self.capacity = capacity; self.fill_rate = fill_rate\\n        self.tokens = capacity; self.last_refill = time.time()\\n    def consume(self, tokens=1):\\n        self._refill()\\n        if self.tokens >= tokens: self.tokens -= tokens; return True\\n        return False\\n    def _refill(self):\\n        now = time.time(); elapsed = now - self.last_refill\\n        self.tokens = min(self.capacity, self.tokens + elapsed * self.fill_rate)\\n        self.last_refill = now\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Token bucket hiz sinirlama algoritmasini uygulayan sinif yaz\",\"response\":\"class TokenBucket {\\n    constructor(capacity, fillRate) { this.capacity = capacity; this.fillRate = fillRate; this.tokens = capacity; this.lastRefill = Date.now(); }\\n    consume(tokens = 1) { this.refill(); if (this.tokens >= tokens) { this.tokens -= tokens; return true; } return false; }\\n    refill() { const now = Date.now(); const elapsed = (now - this.lastRefill) / 1000; this.tokens = Math.min(this.capacity, this.tokens + elapsed * this.fillRate); this.lastRefill = now; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Token bucket hiz sinirlama algoritmasini uygulayan sinif yaz\",\"response\":\"type TokenBucket struct { capacity, fillRate, tokens float64; lastRefill time.Time; mu sync.Mutex }\\nfunc NewTokenBucket(capacity, fillRate float64) *TokenBucket { return &TokenBucket{capacity: capacity, fillRate: fillRate, tokens: capacity, lastRefill: time.Now()} }\\nfunc (tb *TokenBucket) Consume(tokens float64) bool { tb.mu.Lock(); defer tb.mu.Unlock(); tb.refill(); if tb.tokens >= tokens { tb.tokens -= tokens; return true }; return false }\\nfunc (tb *TokenBucket) refill() { elapsed := time.Since(tb.lastRefill).Seconds(); tb.tokens = math.Min(tb.capacity, tb.tokens+elapsed*tb.fillRate); tb.lastRefill = time.Now() }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Leaky bucket (sizinti kovasi) hiz sinirlama algoritmasini uygulayan sinif yaz\",\"response\":\"import time\\nclass LeakyBucket:\\n    def __init__(self, capacity, leak_rate):\\n        self.capacity = capacity; self.leak_rate = leak_rate\\n        self.water = 0; self.last_leak = time.time()\\n    def add(self, drops=1):\\n        self._leak()\\n        if self.water + drops <= self.capacity: self.water += drops; return True\\n        return False\\n    def _leak(self):\\n        now = time.time()\\n        self.water = max(0, self.water - (now - self.last_leak) * self.leak_rate)\\n        self.last_leak = now\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Leaky bucket (sizinti kovasi) hiz sinirlama algoritmasini uygulayan sinif yaz\",\"response\":\"class LeakyBucket {\\n    constructor(capacity, leakRate) { this.capacity = capacity; this.leakRate = leakRate; this.water = 0; this.lastLeak = Date.now(); }\\n    add(drops = 1) { this.leak(); if (this.water + drops <= this.capacity) { this.water += drops; return true; } return false; }\\n    leak() { const now = Date.now(); const elapsed = (now - this.lastLeak) / 1000; this.water = Math.max(0, this.water - elapsed * this.leakRate); this.lastLeak = now; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Leaky bucket (sizinti kovasi) hiz sinirlama algoritmasini uygulayan sinif yaz\",\"response\":\"type LeakyBucket struct { capacity, leakRate, water float64; lastLeak time.Time; mu sync.Mutex }\\nfunc NewLeakyBucket(capacity, leakRate float64) *LeakyBucket { return &LeakyBucket{capacity: capacity, leakRate: leakRate, lastLeak: time.Now()} }\\nfunc (lb *LeakyBucket) Add(drops float64) bool { lb.mu.Lock(); defer lb.mu.Unlock(); lb.leak(); if lb.water+drops <= lb.capacity { lb.water += drops; return true }; return false }\\nfunc (lb *LeakyBucket) leak() { elapsed := time.Since(lb.lastLeak).Seconds(); lb.water = math.Max(0, lb.water-elapsed*lb.leakRate); lb.lastLeak = time.Now() }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tutarli hashing (consistent hashing) algoritmasini uygulayan sinif yaz\",\"response\":\"import hashlib, bisect\\nclass ConsistentHash:\\n    def __init__(self, nodes=None, replicas=3):\\n        self.replicas = replicas; self.ring = {}; self.sorted_keys = []\\n        if nodes:\\n            for node in nodes: self.add_node(node)\\n    def _hash(self, key): return int(hashlib.md5(key.encode()).hexdigest(), 16)\\n    def add_node(self, node):\\n        for i in range(self.replicas):\\n            h = self._hash(f'{node}:{i}')\\n            self.ring[h] = node; self.sorted_keys.append(h)\\n        self.sorted_keys.sort()\\n    def remove_node(self, node):\\n        for i in range(self.replicas):\\n            h = self._hash(f'{node}:{i}')\\n            del self.ring[h]; self.sorted_keys.remove(h)\\n    def get_node(self, key):\\n        if not self.ring: return None\\n        h = self._hash(key)\\n        idx = bisect.bisect_right(self.sorted_keys, h) % len(self.sorted_keys)\\n        return self.ring[self.sorted_keys[idx]]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tutarli hashing (consistent hashing) algoritmasini uygulayan sinif yaz\",\"response\":\"class ConsistentHash {\\n    constructor(nodes = [], replicas = 3) { this.replicas = replicas; this.ring = new Map(); this.sortedKeys = []; for (const node of nodes) this.addNode(node); }\\n    _hash(key) { let h = 0; for (let i = 0; i < key.length; i++) h = ((h << 5) - h) + key.charCodeAt(i) | 0; return h >>> 0; }\\n    addNode(node) {\\n        for (let i = 0; i < this.replicas; i++) { const h = this._hash(node + ':' + i); this.ring.set(h, node); this.sortedKeys.push(h); }\\n        this.sortedKeys.sort((a, b) => a - b);\\n    }\\n    removeNode(node) {\\n        for (let i = 0; i < this.replicas; i++) { const h = this._hash(node + ':' + i); this.ring.delete(h); this.sortedKeys.splice(this.sortedKeys.indexOf(h), 1); }\\n    }\\n    getNode(key) { if (!this.ring.size) return null; const h = this._hash(key); let idx = this.sortedKeys.findIndex(k => k >= h); if (idx === -1) idx = 0; return this.ring.get(this.sortedKeys[idx]); }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tutarli hashing (consistent hashing) algoritmasini uygulayan sinif yaz\",\"response\":\"type ConsistentHash struct { replicas int; ring map[int]string; sortedKeys []int; mu sync.RWMutex }\\nfunc NewConsistentHash(replicas int) *ConsistentHash { return &ConsistentHash{replicas: replicas, ring: make(map[int]string)} }\\nfunc (ch *ConsistentHash) hash(key string) int { h := 0; for _, c := range key { h = int(c) + (h << 6) + (h << 16) - h }; if h < 0 { h = -h }; return h }\\nfunc (ch *ConsistentHash) AddNode(node string) {\\n    ch.mu.Lock(); defer ch.mu.Unlock()\\n    for i := 0; i < ch.replicas; i++ { h := ch.hash(fmt.Sprintf(\\\"%s:%d\\\", node, i)); ch.ring[h] = node; ch.sortedKeys = append(ch.sortedKeys, h) }\\n    sort.Ints(ch.sortedKeys)\\n}\\nfunc (ch *ConsistentHash) RemoveNode(node string) {\\n    ch.mu.Lock(); defer ch.mu.Unlock()\\n    for i := 0; i < ch.replicas; i++ { h := ch.hash(fmt.Sprintf(\\\"%s:%d\\\", node, i)); delete(ch.ring, h); for j, k := range ch.sortedKeys { if k == h { ch.sortedKeys = append(ch.sortedKeys[:j], ch.sortedKeys[j+1:]...); break } } }\\n}\\nfunc (ch *ConsistentHash) GetNode(key string) string {\\n    ch.mu.RLock(); defer ch.mu.RUnlock()\\n    if len(ch.ring) == 0 { return \\\"\\\" }\\n    h := ch.hash(key); idx := sort.Search(len(ch.sortedKeys), func(i int) bool { return ch.sortedKeys[i] >= h })\\n    if idx == len(ch.sortedKeys) { idx = 0 }; return ch.ring[ch.sortedKeys[idx]]\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Merkle agaci veri yapisini uygulayan sinif yaz\",\"response\":\"import hashlib\\nclass MerkleTree:\\n    def __init__(self, data):\\n        self.leaves = [self._hash(d) for d in data]\\n        self.root = self._build(self.leaves)\\n    def _hash(self, data): return hashlib.sha256(str(data).encode()).hexdigest()\\n    def _build(self, nodes):\\n        if len(nodes) == 1: return nodes[0]\\n        new_level = []\\n        for i in range(0, len(nodes), 2):\\n            if i + 1 < len(nodes): new_level.append(self._hash(nodes[i] + nodes[i+1]))\\n            else: new_level.append(nodes[i])\\n        return self._build(new_level)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Merkle agaci veri yapisini uygulayan sinif yaz\",\"response\":\"class MerkleTree {\\n    constructor(data) { this.leaves = data.map(d => this.hash(d)); this.root = this.build(this.leaves); }\\n    hash(data) { let h = 0; const s = String(data); for (let i = 0; i < s.length; i++) h = ((h << 5) - h) + s.charCodeAt(i) | 0; return Math.abs(h).toString(16); }\\n    build(nodes) {\\n        if (nodes.length === 1) return nodes[0];\\n        const newLevel = [];\\n        for (let i = 0; i < nodes.length; i += 2) { if (i + 1 < nodes.length) newLevel.push(this.hash(nodes[i] + nodes[i+1])); else newLevel.push(nodes[i]); }\\n        return this.build(newLevel);\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Merkle agaci veri yapisini uygulayan sinif yaz\",\"response\":\"public class MerkleTree {\\n    private String root;\\n    public MerkleTree(List<String> data) { List<String> leaves = data.stream().map(this::hash).collect(Collectors.toList()); this.root = build(leaves); }\\n    private String hash(String data) {\\n        try { MessageDigest md = MessageDigest.getInstance(\\\"SHA-256\\\"); StringBuilder sb = new StringBuilder(); for (byte b : md.digest(data.getBytes())) sb.append(String.format(\\\"%02x\\\", b)); return sb.toString(); }\\n        catch (Exception e) { return null; }\\n    }\\n    private String build(List<String> nodes) {\\n        if (nodes.size() == 1) return nodes.get(0);\\n        List<String> newLevel = new ArrayList<>();\\n        for (int i = 0; i < nodes.size(); i += 2) { if (i + 1 < nodes.size()) newLevel.add(hash(nodes.get(i) + nodes.get(i + 1))); else newLevel.add(nodes.get(i)); }\\n        return build(newLevel);\\n    }\\n    public String getRoot() { return root; }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"RAFT log cogaltma mekanizmasini uygulayan basit sinif yaz\",\"response\":\"class RaftLog:\\n    def __init__(self): self.log = []; self.commit_index = -1\\n    def append(self, entry): self.log.append(entry)\\n    def get_entries(self, start_index):\\n        if start_index >= len(self.log): return []\\n        return self.log[start_index:]\\n    def commit(self, index): self.commit_index = max(self.commit_index, index)\\n    def last_index(self): return len(self.log) - 1\\n    def last_term(self): return 0 if not self.log else self.log[-1]['term']\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"RAFT log cogaltma mekanizmasini uygulayan basit sinif yaz\",\"response\":\"class RaftLog {\\n    constructor() { this.log = []; this.commitIndex = -1; }\\n    append(entry) { this.log.push(entry); }\\n    getEntries(startIndex) { if (startIndex >= this.log.length) return []; return this.log.slice(startIndex); }\\n    commit(index) { this.commitIndex = Math.max(this.commitIndex, index); }\\n    lastIndex() { return this.log.length - 1; }\\n    lastTerm() { return this.log.length ? this.log[this.log.length - 1].term : 0; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"RAFT log cogaltma mekanizmasini uygulayan basit sinif yaz\",\"response\":\"type LogEntry struct { Term int; Command interface{} }\\ntype RaftLog struct { log []LogEntry; commitIndex int; mu sync.Mutex }\\nfunc NewRaftLog() *RaftLog { return &RaftLog{log: make([]LogEntry, 0), commitIndex: -1} }\\nfunc (rl *RaftLog) Append(entry LogEntry) { rl.mu.Lock(); defer rl.mu.Unlock(); rl.log = append(rl.log, entry) }\\nfunc (rl *RaftLog) GetEntries(startIndex int) []LogEntry {\\n    rl.mu.Lock(); defer rl.mu.Unlock()\\n    if startIndex >= len(rl.log) { return []LogEntry{} }\\n    r := make([]LogEntry, len(rl.log)-startIndex); copy(r, rl.log[startIndex:]); return r\\n}\\nfunc (rl *RaftLog) Commit(index int) { rl.mu.Lock(); defer rl.mu.Unlock(); if index > rl.commitIndex { rl.commitIndex = index } }\\nfunc (rl *RaftLog) LastIndex() int { rl.mu.Lock(); defer rl.mu.Unlock(); return len(rl.log) - 1 }\\nfunc (rl *RaftLog) LastTerm() int { rl.mu.Lock(); defer rl.mu.Unlock(); if len(rl.log) == 0 { return 0 }; return rl.log[len(rl.log)-1].Term }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dedikodu (gossip) protokolu yayilma mekanizmasini uygulayan sinif yaz\",\"response\":\"import random\\nclass GossipProtocol:\\n    def __init__(self, node_id, peers): self.node_id = node_id; self.peers = peers; self.messages = set()\\n    def receive(self, message):\\n        if message in self.messages: return False\\n        self.messages.add(message); self._gossip(message); return True\\n    def _gossip(self, message):\\n        sample = random.sample([p for p in self.peers if p != self.node_id], min(3, len(self.peers)))\\n        for peer in sample: peer.receive(message)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dedikodu (gossip) protokolu yayilma mekanizmasini uygulayan sinif yaz\",\"response\":\"class GossipProtocol {\\n    constructor(nodeId, peers) { this.nodeId = nodeId; this.peers = peers; this.messages = new Set(); }\\n    receive(message) { if (this.messages.has(message)) return false; this.messages.add(message); this.gossip(message); return true; }\\n    gossip(message) {\\n        const candidates = this.peers.filter(p => p.nodeId !== this.nodeId);\\n        for (let i = candidates.length - 1; i > 0; i--) { const j = Math.floor(Math.random() * (i + 1)); [candidates[i], candidates[j]] = [candidates[j], candidates[i]]; }\\n        candidates.slice(0, 3).forEach(p => p.receive(message));\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dedikodu (gossip) protokolu yayilma mekanizmasini uygulayan sinif yaz\",\"response\":\"type GossipProtocol struct { nodeID string; peers []*GossipProtocol; messages map[string]bool; mu sync.Mutex }\\nfunc NewGossipProtocol(nodeID string, peers []*GossipProtocol) *GossipProtocol { return &GossipProtocol{nodeID: nodeID, peers: peers, messages: make(map[string]bool)} }\\nfunc (g *GossipProtocol) Receive(message string) bool {\\n    g.mu.Lock(); if g.messages[message] { g.mu.Unlock(); return false }; g.messages[message] = true; g.mu.Unlock()\\n    g.gossip(message); return true\\n}\\nfunc (g *GossipProtocol) gossip(message string) {\\n    candidates := make([]*GossipProtocol, 0)\\n    for _, p := range g.peers { if p.nodeID != g.nodeID { candidates = append(candidates, p) } }\\n    rand.Shuffle(len(candidates), func(i, j int) { candidates[i], candidates[j] = candidates[j], candidates[i] })\\n    n := 3; if len(candidates) < n { n = len(candidates) }; for _, p := range candidates[:n] { p.Receive(message) }\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iki asamali commit (2PC) protokolunu uygulayan sinif yaz\",\"response\":\"class TwoPhaseCommit:\\n    def __init__(self, participants): self.participants = participants\\n    def execute(self, transaction):\\n        for p in self.participants:\\n            if not p.prepare(transaction): self._abort(transaction); return False\\n        for p in self.participants: p.commit(transaction)\\n        return True\\n    def _abort(self, transaction):\\n        for p in self.participants: p.abort(transaction)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iki asamali commit (2PC) protokolunu uygulayan sinif yaz\",\"response\":\"class TwoPhaseCommit {\\n    constructor(participants) { this.participants = participants; }\\n    execute(transaction) { for (const p of this.participants) { if (!p.prepare(transaction)) { this.abort(transaction); return false; } } for (const p of this.participants) p.commit(transaction); return true; }\\n    abort(transaction) { for (const p of this.participants) p.abort(transaction); }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Iki asamali commit (2PC) protokolunu uygulayan sinif yaz\",\"response\":\"type Participant interface { Prepare(interface{}) bool; Commit(interface{}); Abort(interface{}) }\\ntype TwoPhaseCommit struct { participants []Participant }\\nfunc New2PC(p []Participant) *TwoPhaseCommit { return &TwoPhaseCommit{participants: p} }\\nfunc (tpc *TwoPhaseCommit) Execute(tx interface{}) bool { for _, p := range tpc.participants { if !p.Prepare(tx) { tpc.abort(tx); return false } }; for _, p := range tpc.participants { p.Commit(tx) }; return true }\\nfunc (tpc *TwoPhaseCommit) abort(tx interface{}) { for _, p := range tpc.participants { p.Abort(tx) } }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Vektor saati (vector clock) veri yapisini uygulayan sinif yaz\",\"response\":\"class VectorClock:\\n    def __init__(self): self.clock = {}\\n    def increment(self, node): self.clock[node] = self.clock.get(node, 0) + 1\\n    def update(self, other):\\n        for node, ts in other.clock.items(): self.clock[node] = max(self.clock.get(node, 0), ts)\\n    def get(self, node): return self.clock.get(node, 0)\\n    def __eq__(self, other): return self.clock == other.clock\\n    def __lt__(self, other): return all(self.clock.get(k, 0) <= v for k, v in other.clock.items()) and self.clock != other.clock\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Vektor saati (vector clock) veri yapisini uygulayan sinif yaz\",\"response\":\"class VectorClock {\\n    constructor() { this.clock = {}; }\\n    increment(node) { this.clock[node] = (this.clock[node] || 0) + 1; }\\n    update(other) { for (const [node, ts] of Object.entries(other.clock)) { this.clock[node] = Math.max(this.clock[node] || 0, ts); } }\\n    get(node) { return this.clock[node] || 0; }\\n    equals(other) { const allKeys = new Set([...Object.keys(this.clock), ...Object.keys(other.clock)]); return [...allKeys].every(k => this.get(k) === other.get(k)); }\\n    lessThan(other) { const allKeys = new Set([...Object.keys(this.clock), ...Object.keys(other.clock)]); return [...allKeys].every(k => this.get(k) <= other.get(k)) && !this.equals(other); }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Vektor saati (vector clock) veri yapisini uygulayan sinif yaz\",\"response\":\"type VectorClock struct { clock map[string]int; mu sync.Mutex }\\nfunc NewVectorClock() *VectorClock { return &VectorClock{clock: make(map[string]int)} }\\nfunc (vc *VectorClock) Increment(node string) { vc.mu.Lock(); defer vc.mu.Unlock(); vc.clock[node]++ }\\nfunc (vc *VectorClock) Update(other *VectorClock) { vc.mu.Lock(); defer vc.mu.Unlock(); for n, ts := range other.clock { if ts > vc.clock[n] { vc.clock[n] = ts } } }\\nfunc (vc *VectorClock) Get(node string) int { vc.mu.Lock(); defer vc.mu.Unlock(); return vc.clock[node] }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"CRDT (Conflict-free Replicated Data Type) olarak yalnizca artan sayac sinifi yaz\",\"response\":\"class GCounter:\\n    def __init__(self, node_id): self.node_id = node_id; self.counts = {}\\n    def increment(self): self.counts[self.node_id] = self.counts.get(self.node_id, 0) + 1\\n    def value(self): return sum(self.counts.values())\\n    def merge(self, other):\\n        for node, count in other.counts.items(): self.counts[node] = max(self.counts.get(node, 0), count)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"CRDT (Conflict-free Replicated Data Type) olarak yalnizca artan sayac sinifi yaz\",\"response\":\"class GCounter {\\n    constructor(nodeId) { this.nodeId = nodeId; this.counts = {}; }\\n    increment() { this.counts[this.nodeId] = (this.counts[this.nodeId] || 0) + 1; }\\n    value() { return Object.values(this.counts).reduce((a, b) => a + b, 0); }\\n    merge(other) { for (const [node, count] of Object.entries(other.counts)) { this.counts[node] = Math.max(this.counts[node] || 0, count); } }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"CRDT (Conflict-free Replicated Data Type) olarak yalnizca artan sayac sinifi yaz\",\"response\":\"type GCounter struct { nodeID string; counts map[string]int; mu sync.Mutex }\\nfunc NewGCounter(nodeID string) *GCounter { return &GCounter{nodeID: nodeID, counts: make(map[string]int)} }\\nfunc (g *GCounter) Increment() { g.mu.Lock(); defer g.mu.Unlock(); g.counts[g.nodeID]++ }\\nfunc (g *GCounter) Value() int { g.mu.Lock(); defer g.mu.Unlock(); t := 0; for _, v := range g.counts { t += v }; return t }\\nfunc (g *GCounter) Merge(other *GCounter) { g.mu.Lock(); defer g.mu.Unlock(); for n, c := range other.counts { if c > g.counts[n] { g.counts[n] = c } } }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"LSM (Log-Structured Merge-Tree) agaci yapisini uygulayan basit sinif yaz\",\"response\":\"class LSMTree:\\n    def __init__(self): self.memtable = {}; self.sstables = []\\n    def put(self, key, value):\\n        self.memtable[key] = value\\n        if len(self.memtable) >= 3: self.flush()\\n    def get(self, key):\\n        if key in self.memtable: return self.memtable[key]\\n        for table in reversed(self.sstables):\\n            if key in table: return table[key]\\n        return None\\n    def flush(self):\\n        self.sstables.append(dict(sorted(self.memtable.items()))); self.memtable = {}\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"LSM (Log-Structured Merge-Tree) agaci yapisini uygulayan basit sinif yaz\",\"response\":\"class LSMTree {\\n    constructor() { this.memtable = {}; this.sstables = []; }\\n    put(key, value) { this.memtable[key] = value; if (Object.keys(this.memtable).length >= 3) this.flush(); }\\n    get(key) { if (key in this.memtable) return this.memtable[key]; for (let i = this.sstables.length - 1; i >= 0; i--) { if (key in this.sstables[i]) return this.sstables[i][key]; } return null; }\\n    flush() { const sorted = Object.keys(this.memtable).sort().reduce((acc, k) => { acc[k] = this.memtable[k]; return acc; }, {}); this.sstables.push(sorted); this.memtable = {}; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"LSM (Log-Structured Merge-Tree) agaci yapisini uygulayan basit sinif yaz\",\"response\":\"type LSMTree struct { memtable map[string]string; sstables []map[string]string; mu sync.Mutex }\\nfunc NewLSMTree() *LSMTree { return &LSMTree{memtable: make(map[string]string)} }\\nfunc (lsm *LSMTree) Put(key, value string) { lsm.mu.Lock(); defer lsm.mu.Unlock(); lsm.memtable[key] = value; if len(lsm.memtable) >= 3 { lsm.flush() } }\\nfunc (lsm *LSMTree) Get(key string) string {\\n    lsm.mu.Lock(); defer lsm.mu.Unlock()\\n    if v, ok := lsm.memtable[key]; ok { return v }\\n    for i := len(lsm.sstables) - 1; i >= 0; i-- { if v, ok := lsm.sstables[i][key]; ok { return v } }\\n    return \\\"\\\"\\n}\\nfunc (lsm *LSMTree) flush() {\\n    keys := make([]string, 0, len(lsm.memtable)); for k := range lsm.memtable { keys = append(keys, k) }; sort.Strings(keys)\\n    sorted := make(map[string]string); for _, k := range keys { sorted[k] = lsm.memtable[k] }\\n    lsm.sstables = append(lsm.sstables, sorted); lsm.memtable = make(map[string]string)\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"B-agaci (B-tree) veri yapisini uygulayan basit sinif yaz\",\"response\":\"class BTreeNode:\\n    def __init__(self, leaf=True): self.leaf = leaf; self.keys = []; self.children = []\\nclass BTree:\\n    def __init__(self, t): self.root = BTreeNode(); self.t = t\\n    def search(self, key, node=None):\\n        if node is None: node = self.root\\n        i = 0\\n        while i < len(node.keys) and key > node.keys[i]: i += 1\\n        if i < len(node.keys) and key == node.keys[i]: return (node, i)\\n        if node.leaf: return None\\n        return self.search(key, node.children[i])\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"B-agaci (B-tree) veri yapisini uygulayan basit sinif yaz\",\"response\":\"class BTreeNode { constructor(leaf = true) { this.leaf = leaf; this.keys = []; this.children = []; } }\\nclass BTree {\\n    constructor(t) { this.root = new BTreeNode(); this.t = t; }\\n    search(key, node = this.root) { let i = 0; while (i < node.keys.length && key > node.keys[i]) i++; if (i < node.keys.length && key === node.keys[i]) return { node, i }; if (node.leaf) return null; return this.search(key, node.children[i]); }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"B-agaci (B-tree) veri yapisini uygulayan basit sinif yaz\",\"response\":\"type BTreeNode struct { leaf bool; keys []int; children []*BTreeNode }\\ntype BTree struct { root *BTreeNode; t int }\\nfunc NewBTree(t int) *BTree { return &BTree{root: &BTreeNode{leaf: true}, t: t} }\\nfunc (bt *BTree) Search(key int, nodes ...*BTreeNode) (*BTreeNode, int) {\\n    n := bt.root; if len(nodes) > 0 { n = nodes[0] }\\n    i := 0; for i < len(n.keys) && key > n.keys[i] { i++ }\\n    if i < len(n.keys) && key == n.keys[i] { return n, i }\\n    if n.leaf { return nil, -1 }; return bt.Search(key, n.children[i])\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Segment agaci (segment tree) veri yapisini uygulayan sinif yaz\",\"response\":\"class SegmentTree:\\n    def __init__(self, arr):\\n        self.n = len(arr); self.tree = [0] * (4 * self.n)\\n        self._build(arr, 0, 0, self.n - 1)\\n    def _build(self, arr, node, l, r):\\n        if l == r: self.tree[node] = arr[l]; return\\n        mid = (l + r) // 2\\n        self._build(arr, 2*node+1, l, mid); self._build(arr, 2*node+2, mid+1, r)\\n        self.tree[node] = self.tree[2*node+1] + self.tree[2*node+2]\\n    def query(self, ql, qr, node=0, l=0, r=None):\\n        if r is None: r = self.n - 1\\n        if ql > r or qr < l: return 0\\n        if ql <= l and r <= qr: return self.tree[node]\\n        mid = (l + r) // 2\\n        return self.query(ql, qr, 2*node+1, l, mid) + self.query(ql, qr, 2*node+2, mid+1, r)\\n    def update(self, idx, val, node=0, l=0, r=None):\\n        if r is None: r = self.n - 1\\n        if l == r: self.tree[node] = val; return\\n        mid = (l + r) // 2\\n        if idx <= mid: self.update(idx, val, 2*node+1, l, mid)\\n        else: self.update(idx, val, 2*node+2, mid+1, r)\\n        self.tree[node] = self.tree[2*node+1] + self.tree[2*node+2]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Segment agaci (segment tree) veri yapisini uygulayan sinif yaz\",\"response\":\"class SegmentTree {\\n    constructor(arr) { this.n = arr.length; this.tree = new Array(4 * this.n).fill(0); this.build(arr, 0, 0, this.n - 1); }\\n    build(arr, node, l, r) {\\n        if (l === r) { this.tree[node] = arr[l]; return; }\\n        const mid = Math.floor((l + r) / 2);\\n        this.build(arr, 2*node+1, l, mid); this.build(arr, 2*node+2, mid+1, r);\\n        this.tree[node] = this.tree[2*node+1] + this.tree[2*node+2];\\n    }\\n    query(ql, qr, node = 0, l = 0, r = null) {\\n        if (r === null) r = this.n - 1;\\n        if (ql > r || qr < l) return 0;\\n        if (ql <= l && r <= qr) return this.tree[node];\\n        const mid = Math.floor((l + r) / 2);\\n        return this.query(ql, qr, 2*node+1, l, mid) + this.query(ql, qr, 2*node+2, mid+1, r);\\n    }\\n    update(idx, val, node = 0, l = 0, r = null) {\\n        if (r === null) r = this.n - 1;\\n        if (l === r) { this.tree[node] = val; return; }\\n        const mid = Math.floor((l + r) / 2);\\n        if (idx <= mid) this.update(idx, val, 2*node+1, l, mid);\\n        else this.update(idx, val, 2*node+2, mid+1, r);\\n        this.tree[node] = this.tree[2*node+1] + this.tree[2*node+2];\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Segment agaci (segment tree) veri yapisini uygulayan sinif yaz\",\"response\":\"public class SegmentTree {\\n    private int[] tree; private int n;\\n    public SegmentTree(int[] arr) { this.n = arr.length; this.tree = new int[4 * n]; build(arr, 0, 0, n - 1); }\\n    private void build(int[] arr, int node, int l, int r) {\\n        if (l == r) { tree[node] = arr[l]; return; }\\n        int mid = l + (r - l) / 2;\\n        build(arr, 2*node+1, l, mid); build(arr, 2*node+2, mid+1, r);\\n        tree[node] = tree[2*node+1] + tree[2*node+2];\\n    }\\n    public int query(int ql, int qr) { return query(ql, qr, 0, 0, n - 1); }\\n    private int query(int ql, int qr, int node, int l, int r) {\\n        if (ql > r || qr < l) return 0;\\n        if (ql <= l && r <= qr) return tree[node];\\n        int mid = l + (r - l) / 2;\\n        return query(ql, qr, 2*node+1, l, mid) + query(ql, qr, 2*node+2, mid+1, r);\\n    }\\n    public void update(int idx, int val) { update(idx, val, 0, 0, n - 1); }\\n    private void update(int idx, int val, int node, int l, int r) {\\n        if (l == r) { tree[node] = val; return; }\\n        int mid = l + (r - l) / 2;\\n        if (idx <= mid) update(idx, val, 2*node+1, l, mid);\\n        else update(idx, val, 2*node+2, mid+1, r);\\n        tree[node] = tree[2*node+1] + tree[2*node+2];\\n    }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Fenwick agaci (binary indexed tree) veri yapisini uygulayan sinif yaz\",\"response\":\"class FenwickTree:\\n    def __init__(self, n): self.n = n; self.bit = [0] * (n + 1)\\n    def update(self, idx, delta):\\n        i = idx\\n        while i <= self.n: self.bit[i] += delta; i += i & -i\\n    def query(self, idx):\\n        result = 0; i = idx\\n        while i > 0: result += self.bit[i]; i -= i & -i\\n        return result\\n    def range_query(self, l, r): return self.query(r) - self.query(l - 1)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Fenwick agaci (binary indexed tree) veri yapisini uygulayan sinif yaz\",\"response\":\"class FenwickTree {\\n    constructor(n) { this.n = n; this.bit = new Array(n + 1).fill(0); }\\n    update(idx, delta) { let i = idx; while (i <= this.n) { this.bit[i] += delta; i += i & -i; } }\\n    query(idx) { let result = 0, i = idx; while (i > 0) { result += this.bit[i]; i -= i & -i; } return result; }\\n    rangeQuery(l, r) { return this.query(r) - this.query(l - 1); }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Fenwick agaci (binary indexed tree) veri yapisini uygulayan sinif yaz\",\"response\":\"type FenwickTree struct { n int; bit []int }\\nfunc NewFenwickTree(n int) *FenwickTree { return &FenwickTree{n: n, bit: make([]int, n+1)} }\\nfunc (ft *FenwickTree) Update(idx, delta int) { for i := idx; i <= ft.n; i += i & -i { ft.bit[i] += delta } }\\nfunc (ft *FenwickTree) Query(idx int) int { r := 0; for i := idx; i > 0; i -= i & -i { r += ft.bit[i] }; return r }\\nfunc (ft *FenwickTree) RangeQuery(l, r int) int { return ft.Query(r) - ft.Query(l-1) }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rabin-Karp string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def rabin_karp(text, pattern):\\n    n, m = len(text), len(pattern)\\n    if m > n: return -1\\n    base, mod = 256, 101\\n    hpat = sum(ord(pattern[i]) * (base ** (m - 1 - i)) for i in range(m)) % mod\\n    htxt = sum(ord(text[i]) * (base ** (m - 1 - i)) for i in range(m)) % mod\\n    for i in range(n - m + 1):\\n        if htxt == hpat and text[i:i+m] == pattern: return i\\n        if i < n - m:\\n            htxt = (base * (htxt - ord(text[i]) * (base ** (m - 1))) + ord(text[i + m])) % mod\\n    return -1\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rabin-Karp string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function rabinKarp(text, pattern) {\\n    const n = text.length, m = pattern.length;\\n    if (m > n) return -1;\\n    const base = 256, mod = 101;\\n    let hpat = 0, htxt = 0, h = 1;\\n    for (let i = 0; i < m - 1; i++) h = (h * base) % mod;\\n    for (let i = 0; i < m; i++) { hpat = (base * hpat + pattern.charCodeAt(i)) % mod; htxt = (base * htxt + text.charCodeAt(i)) % mod; }\\n    for (let i = 0; i <= n - m; i++) {\\n        if (htxt === hpat) { if (text.substring(i, i + m) === pattern) return i; }\\n        if (i < n - m) { htxt = (base * (htxt - text.charCodeAt(i) * h) + text.charCodeAt(i + m)) % mod; if (htxt < 0) htxt += mod; }\\n    }\\n    return -1;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rabin-Karp string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static int rabinKarp(String text, String pattern) {\\n    int n = text.length(), m = pattern.length();\\n    if (m > n) return -1;\\n    int base = 256, mod = 101, h = 1;\\n    for (int i = 0; i < m - 1; i++) h = (h * base) % mod;\\n    int hpat = 0, htxt = 0;\\n    for (int i = 0; i < m; i++) { hpat = (base * hpat + pattern.charAt(i)) % mod; htxt = (base * htxt + text.charAt(i)) % mod; }\\n    for (int i = 0; i <= n - m; i++) {\\n        if (htxt == hpat && text.substring(i, i + m).equals(pattern)) return i;\\n        if (i < n - m) { htxt = (base * (htxt - text.charAt(i) * h) + text.charAt(i + m)) % mod; if (htxt < 0) htxt += mod; }\\n    }\\n    return -1;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"KMP (Knuth-Morris-Pratt) string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def kmp(text, pattern):\\n    m, n = len(pattern), len(text)\\n    lps = [0] * m; j = 0\\n    for i in range(1, m):\\n        while j > 0 and pattern[i] != pattern[j]: j = lps[j - 1]\\n        if pattern[i] == pattern[j]: j += 1; lps[i] = j\\n    j = 0\\n    for i in range(n):\\n        while j > 0 and text[i] != pattern[j]: j = lps[j - 1]\\n        if text[i] == pattern[j]: j += 1\\n        if j == m: return i - m + 1\\n    return -1\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"KMP (Knuth-Morris-Pratt) string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function kmp(text, pattern) {\\n    const m = pattern.length, n = text.length;\\n    const lps = new Array(m).fill(0); let j = 0;\\n    for (let i = 1; i < m; i++) {\\n        while (j > 0 && pattern[i] !== pattern[j]) j = lps[j - 1];\\n        if (pattern[i] === pattern[j]) { j++; lps[i] = j; }\\n    }\\n    j = 0;\\n    for (let i = 0; i < n; i++) {\\n        while (j > 0 && text[i] !== pattern[j]) j = lps[j - 1];\\n        if (text[i] === pattern[j]) j++;\\n        if (j === m) return i - m + 1;\\n    }\\n    return -1;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"KMP (Knuth-Morris-Pratt) string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func KMP(text, pattern string) int {\\n    m, n := len(pattern), len(text)\\n    lps := make([]int, m); j := 0\\n    for i := 1; i < m; i++ {\\n        for j > 0 && pattern[i] != pattern[j] { j = lps[j-1] }\\n        if pattern[i] == pattern[j] { j++; lps[i] = j }\\n    }\\n    j = 0\\n    for i := 0; i < n; i++ {\\n        for j > 0 && text[i] != pattern[j] { j = lps[j-1] }\\n        if text[i] == pattern[j] { j++ }\\n        if j == m { return i - m + 1 }\\n    }\\n    return -1\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Z-algoritmasi string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def z_algorithm(s):\\n    n = len(s); z = [0] * n; l = r = 0\\n    for i in range(1, n):\\n        if i <= r: z[i] = min(r - i + 1, z[i - l])\\n        while i + z[i] < n and s[z[i]] == s[i + z[i]]: z[i] += 1\\n        if i + z[i] - 1 > r: l, r = i, i + z[i] - 1\\n    return z\\ndef z_search(text, pattern):\\n    concat = pattern + '$' + text\\n    z = z_algorithm(concat)\\n    for i in range(len(pattern) + 1, len(concat)):\\n        if z[i] == len(pattern): return i - len(pattern) - 1\\n    return -1\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Z-algoritmasi string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function zAlgorithm(s) {\\n    const n = s.length; const z = new Array(n).fill(0); let l = 0, r = 0;\\n    for (let i = 1; i < n; i++) {\\n        if (i <= r) z[i] = Math.min(r - i + 1, z[i - l]);\\n        while (i + z[i] < n && s[z[i]] === s[i + z[i]]) z[i]++;\\n        if (i + z[i] - 1 > r) { l = i; r = i + z[i] - 1; }\\n    }\\n    return z;\\n}\\nfunction zSearch(text, pattern) {\\n    const concat = pattern + '$' + text;\\n    const z = zAlgorithm(concat);\\n    for (let i = pattern.length + 1; i < concat.length; i++) { if (z[i] === pattern.length) return i - pattern.length - 1; }\\n    return -1;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Z-algoritmasi string eslestirme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func ZAlgorithm(s string) []int {\\n    n := len(s); z := make([]int, n); l, r := 0, 0\\n    for i := 1; i < n; i++ {\\n        if i <= r { z[i] = min(r-i+1, z[i-l]) }\\n        for i+z[i] < n && s[z[i]] == s[i+z[i]] { z[i]++ }\\n        if i+z[i]-1 > r { l, r = i, i+z[i]-1 }\\n    }\\n    return z\\n}\\nfunc ZSearch(text, pattern string) int {\\n    concat := pattern + \\\"$\\\" + text\\n    z := ZAlgorithm(concat)\\n    for i := len(pattern) + 1; i < len(concat); i++ { if z[i] == len(pattern) { return i - len(pattern) - 1 } }\\n    return -1\\n}\\nfunc min(a, b int) int { if a < b { return a }; return b }\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Manacher algoritmasi ile en uzun palindromik alt stringi bulan fonksiyon yaz\",\"response\":\"def manacher(s):\\n    t = '#' + '#'.join(s) + '#'\\n    n = len(t); p = [0] * n; center = right = 0\\n    for i in range(n):\\n        if i < right: p[i] = min(right - i, p[2 * center - i])\\n        while i - p[i] - 1 >= 0 and i + p[i] + 1 < n and t[i - p[i] - 1] == t[i + p[i] + 1]: p[i] += 1\\n        if i + p[i] > right: center, right = i, i + p[i]\\n    max_len = max(p); ci = p.index(max_len)\\n    start = (ci - max_len) // 2\\n    return s[start:start + max_len]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Manacher algoritmasi ile en uzun palindromik alt stringi bulan fonksiyon yaz\",\"response\":\"function manacher(s) {\\n    const t = '#' + s.split('').join('#') + '#';\\n    const n = t.length; const p = new Array(n).fill(0); let center = 0, right = 0;\\n    for (let i = 0; i < n; i++) {\\n        if (i < right) p[i] = Math.min(right - i, p[2 * center - i]);\\n        while (i - p[i] - 1 >= 0 && i + p[i] + 1 < n && t[i - p[i] - 1] === t[i + p[i] + 1]) p[i]++;\\n        if (i + p[i] > right) { center = i; right = i + p[i]; }\\n    }\\n    const maxLen = Math.max(...p); const ci = p.indexOf(maxLen);\\n    const start = Math.floor((ci - maxLen) / 2);\\n    return s.substring(start, start + maxLen);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Manacher algoritmasi ile en uzun palindromik alt stringi bulan fonksiyon yaz\",\"response\":\"public static String manacher(String s) {\\n    StringBuilder sb = new StringBuilder(\\\"#\\\");\\n    for (char c : s.toCharArray()) sb.append(c).append('#');\\n    String t = sb.toString(); int n = t.length();\\n    int[] p = new int[n]; int center = 0, right = 0;\\n    for (int i = 0; i < n; i++) {\\n        if (i < right) p[i] = Math.min(right - i, p[2 * center - i]);\\n        while (i - p[i] - 1 >= 0 && i + p[i] + 1 < n && t.charAt(i - p[i] - 1) == t.charAt(i + p[i] + 1)) p[i]++;\\n        if (i + p[i] > right) { center = i; right = i + p[i]; }\\n    }\\n    int maxLen = 0, ci = 0;\\n    for (int i = 0; i < n; i++) { if (p[i] > maxLen) { maxLen = p[i]; ci = i; } }\\n    int start = (ci - maxLen) / 2;\\n    return s.substring(start, start + maxLen);\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"A* (A-yildiz) arama algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import heapq\\ndef a_star(start, goal, h, neighbors):\\n    open_set = [(0, start)]; g_score = {start: 0}; came_from = {}\\n    while open_set:\\n        _, current = heapq.heappop(open_set)\\n        if current == goal:\\n            path = []\\n            while current in came_from: path.append(current); current = came_from[current]\\n            path.append(start); return path[::-1]\\n        for neighbor, cost in neighbors(current):\\n            tg = g_score[current] + cost\\n            if neighbor not in g_score or tg < g_score[neighbor]:\\n                g_score[neighbor] = tg\\n                heapq.heappush(open_set, (tg + h(neighbor, goal), neighbor))\\n                came_from[neighbor] = current\\n    return None\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"A* (A-yildiz) arama algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function aStar(start, goal, h, neighbors) {\\n    const openSet = [{ f: 0, node: start }]; const gScore = new Map([[start, 0]]); const cameFrom = new Map();\\n    while (openSet.length) {\\n        openSet.sort((a, b) => a.f - b.f);\\n        const current = openSet.shift().node;\\n        if (current === goal) { const path = []; let c = current; while (cameFrom.has(c)) { path.push(c); c = cameFrom.get(c); } path.push(start); return path.reverse(); }\\n        for (const [neighbor, cost] of neighbors(current)) {\\n            const tg = gScore.get(current) + cost;\\n            if (!gScore.has(neighbor) || tg < gScore.get(neighbor)) { gScore.set(neighbor, tg); cameFrom.set(neighbor, current); openSet.push({ f: tg + h(neighbor, goal), node: neighbor }); }\\n        }\\n    }\\n    return null;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"A* (A-yildiz) arama algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static List<String> aStar(String start, String goal, BiFunction<String, String, Double> h, Function<String, List<AbstractMap.SimpleEntry<String, Double>>> neighbors) {\\n    PriorityQueue<AbstractMap.SimpleEntry<Double, String>> openSet = new PriorityQueue<>(Comparator.comparingDouble(Map.Entry::getKey));\\n    openSet.offer(new AbstractMap.SimpleEntry<>(0.0, start));\\n    Map<String, Double> gScore = new HashMap<>(); gScore.put(start, 0.0);\\n    Map<String, String> cameFrom = new HashMap<>();\\n    while (!openSet.isEmpty()) {\\n        String current = openSet.poll().getValue();\\n        if (current.equals(goal)) { LinkedList<String> path = new LinkedList<>(); for (String c = current; c != null; c = cameFrom.get(c)) path.addFirst(c); return path; }\\n        for (var entry : neighbors.apply(current)) {\\n            String neighbor = entry.getKey(); double cost = entry.getValue();\\n            double tg = gScore.get(current) + cost;\\n            if (!gScore.containsKey(neighbor) || tg < gScore.get(neighbor)) { gScore.put(neighbor, tg); cameFrom.put(neighbor, current); openSet.offer(new AbstractMap.SimpleEntry<>(tg + h.apply(neighbor, goal), neighbor)); }\\n        }\\n    }\\n    return null;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Minimax algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def minimax(board, depth, is_maximizing):\\n    score = evaluate(board)\\n    if score is not None: return score\\n    if is_maximizing:\\n        best = float('-inf')\\n        for move in get_moves(board):\\n            board[move] = 'X'\\n            best = max(best, minimax(board, depth+1, False))\\n            board[move] = None\\n        return best\\n    else:\\n        best = float('inf')\\n        for move in get_moves(board):\\n            board[move] = 'O'\\n            best = min(best, minimax(board, depth+1, True))\\n            board[move] = None\\n        return best\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Minimax algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function minimax(board, depth, isMaximizing) {\\n    const score = evaluate(board);\\n    if (score !== null) return score;\\n    if (isMaximizing) {\\n        let best = -Infinity;\\n        for (const move of getMoves(board)) { board[move] = 'X'; best = Math.max(best, minimax(board, depth + 1, false)); board[move] = null; }\\n        return best;\\n    } else {\\n        let best = Infinity;\\n        for (const move of getMoves(board)) { board[move] = 'O'; best = Math.min(best, minimax(board, depth + 1, true)); board[move] = null; }\\n        return best;\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Minimax algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func Minimax(board []string, depth int, isMaximizing bool) int {\\n    score := evaluate(board)\\n    if score != nil { return *score }\\n    if isMaximizing {\\n        best := -1 << 31\\n        for _, move := range getMoves(board) { board[move] = \\\"X\\\"; val := Minimax(board, depth+1, false); board[move] = \\\"\\\"; if val > best { best = val } }\\n        return best\\n    } else {\\n        best := 1 << 31\\n        for _, move := range getMoves(board) { board[move] = \\\"O\\\"; val := Minimax(board, depth+1, true); board[move] = \\\"\\\"; if val < best { best = val } }\\n        return best\\n    }\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Alfa-beta budamasi (alpha-beta pruning) ile minimax algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def alpha_beta(board, depth, alpha, beta, is_maximizing):\\n    score = evaluate(board)\\n    if score is not None: return score\\n    if is_maximizing:\\n        best = float('-inf')\\n        for move in get_moves(board):\\n            board[move] = 'X'\\n            best = max(best, alpha_beta(board, depth+1, alpha, beta, False))\\n            board[move] = None\\n            alpha = max(alpha, best)\\n            if beta <= alpha: break\\n        return best\\n    else:\\n        best = float('inf')\\n        for move in get_moves(board):\\n            board[move] = 'O'\\n            best = min(best, alpha_beta(board, depth+1, alpha, beta, True))\\n            board[move] = None\\n            beta = min(beta, best)\\n            if beta <= alpha: break\\n        return best\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Alfa-beta budamasi (alpha-beta pruning) ile minimax algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function alphaBeta(board, depth, alpha, beta, isMaximizing) {\\n    const score = evaluate(board);\\n    if (score !== null) return score;\\n    if (isMaximizing) {\\n        let best = -Infinity;\\n        for (const move of getMoves(board)) { board[move] = 'X'; best = Math.max(best, alphaBeta(board, depth + 1, alpha, beta, false)); board[move] = null; alpha = Math.max(alpha, best); if (beta <= alpha) break; }\\n        return best;\\n    } else {\\n        let best = Infinity;\\n        for (const move of getMoves(board)) { board[move] = 'O'; best = Math.min(best, alphaBeta(board, depth + 1, alpha, beta, true)); board[move] = null; beta = Math.min(beta, best); if (beta <= alpha) break; }\\n        return best;\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Alfa-beta budamasi (alpha-beta pruning) ile minimax algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func AlphaBeta(board []string, depth int, alpha, beta float64, isMaximizing bool) float64 {\\n    score := evaluate(board)\\n    if score != nil { return *score }\\n    if isMaximizing {\\n        best := -math.MaxFloat64\\n        for _, move := range getMoves(board) { board[move] = \\\"X\\\"; val := AlphaBeta(board, depth+1, alpha, beta, false); board[move] = \\\"\\\"; if val > best { best = val }; if best > alpha { alpha = best }; if beta <= alpha { break } }\\n        return best\\n    } else {\\n        best := math.MaxFloat64\\n        for _, move := range getMoves(board) { board[move] = \\\"O\\\"; val := AlphaBeta(board, depth+1, alpha, beta, true); board[move] = \\\"\\\"; if val < best { best = val }; if best < beta { beta = best }; if beta <= alpha { break } }\\n        return best\\n    }\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tavlama benzetimi (simulated annealing) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import math, random\\ndef simulated_annealing(initial, cost_func, neighbor_func, temp, cooling_rate):\\n    current = initial; current_cost = cost_func(current)\\n    best = current; best_cost = current_cost\\n    while temp > 0.01:\\n        neighbor = neighbor_func(current); nc = cost_func(neighbor)\\n        delta = nc - current_cost\\n        if delta < 0 or random.random() < math.exp(-delta / temp):\\n            current = neighbor; current_cost = nc\\n            if current_cost < best_cost: best = current; best_cost = current_cost\\n        temp *= cooling_rate\\n    return best, best_cost\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tavlama benzetimi (simulated annealing) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function simulatedAnnealing(initial, costFunc, neighborFunc, temp, coolingRate) {\\n    let current = initial, currentCost = costFunc(current);\\n    let best = current, bestCost = currentCost;\\n    while (temp > 0.01) {\\n        const neighbor = neighborFunc(current); const nc = costFunc(neighbor);\\n        const delta = nc - currentCost;\\n        if (delta < 0 || Math.random() < Math.exp(-delta / temp)) { current = neighbor; currentCost = nc; if (currentCost < bestCost) { best = current; bestCost = currentCost; } }\\n        temp *= coolingRate;\\n    }\\n    return [best, bestCost];\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tavlama benzetimi (simulated annealing) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static double[] simulatedAnnealing(double[] initial, Function<double[], Double> costFunc, UnaryOperator<double[]> neighborFunc, double temp, double coolingRate) {\\n    double[] current = initial.clone(); double currentCost = costFunc.apply(current);\\n    double[] best = current.clone(); double bestCost = currentCost; Random rand = new Random();\\n    while (temp > 0.01) {\\n        double[] neighbor = neighborFunc.apply(current); double nc = costFunc.apply(neighbor);\\n        double delta = nc - currentCost;\\n        if (delta < 0 || rand.nextDouble() < Math.exp(-delta / temp)) { current = neighbor; currentCost = nc; if (currentCost < bestCost) { best = current.clone(); bestCost = currentCost; } }\\n        temp *= coolingRate;\\n    }\\n    return new double[]{best[0], bestCost};\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Genetik algoritmayi uygulayan fonksiyon yaz\",\"response\":\"import random\\ndef genetic_algorithm(population, fitness_func, mutate_func, crossover_func, generations):\\n    for _ in range(generations):\\n        scored = [(fitness_func(ind), ind) for ind in population]\\n        scored.sort(key=lambda x: x[0], reverse=True)\\n        new_pop = [ind for _, ind in scored[:2]]\\n        while len(new_pop) < len(population):\\n            p1 = random.choice(population); p2 = random.choice(population)\\n            child = crossover_func(p1, p2)\\n            if random.random() < 0.1: child = mutate_func(child)\\n            new_pop.append(child)\\n        population = new_pop\\n    return max(population, key=fitness_func)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Genetik algoritmayi uygulayan fonksiyon yaz\",\"response\":\"function geneticAlgorithm(population, fitnessFunc, mutateFunc, crossoverFunc, generations) {\\n    for (let gen = 0; gen < generations; gen++) {\\n        const scored = population.map(ind => ({ fitness: fitnessFunc(ind), ind }));\\n        scored.sort((a, b) => b.fitness - a.fitness);\\n        const newPop = scored.slice(0, 2).map(s => s.ind);\\n        while (newPop.length < population.length) {\\n            const p1 = population[Math.floor(Math.random() * population.length)];\\n            const p2 = population[Math.floor(Math.random() * population.length)];\\n            let child = crossoverFunc(p1, p2);\\n            if (Math.random() < 0.1) child = mutateFunc(child);\\n            newPop.push(child);\\n        }\\n        population = newPop;\\n    }\\n    return population.reduce((best, ind) => fitnessFunc(ind) > fitnessFunc(best) ? ind : best);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Genetik algoritmayi uygulayan fonksiyon yaz\",\"response\":\"func GeneticAlgorithm(population []string, fitness func(string) int, mutate func(string) string, crossover func(string, string) string, generations int) string {\\n    for gen := 0; gen < generations; gen++ {\\n        sort.Slice(population, func(i, j int) bool { return fitness(population[i]) > fitness(population[j]) })\\n        newPop := []string{population[0], population[1]}\\n        for len(newPop) < len(population) {\\n            p1 := population[rand.Intn(len(population))]; p2 := population[rand.Intn(len(population))]\\n            child := crossover(p1, p2)\\n            if rand.Float64() < 0.1 { child = mutate(child) }\\n            newPop = append(newPop, child)\\n        }\\n        population = newPop\\n    }\\n    best := population[0]\\n    for _, ind := range population { if fitness(ind) > fitness(best) { best = ind } }\\n    return best\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"K-means kumeleme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import random\\ndef k_means(data, k, max_iter=100):\\n    centroids = random.sample(data, k)\\n    for _ in range(max_iter):\\n        clusters = [[] for _ in range(k)]\\n        for point in data:\\n            distances = [sum((point[i] - c[i])**2 for i in range(len(point))) for c in centroids]\\n            clusters[distances.index(min(distances))].append(point)\\n        new_centroids = []\\n        for cluster in clusters:\\n            if cluster: new_centroids.append([sum(p[i] for p in cluster)/len(cluster) for i in range(len(cluster[0]))])\\n            else: new_centroids.append(random.sample(data, 1)[0])\\n        if new_centroids == centroids: break\\n        centroids = new_centroids\\n    return centroids, clusters\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"K-means kumeleme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function kMeans(data, k, maxIter = 100) {\\n    let centroids = data.slice(0, k);\\n    for (let iter = 0; iter < maxIter; iter++) {\\n        const clusters = Array.from({length: k}, () => []);\\n        for (const point of data) {\\n            const dists = centroids.map(c => Math.sqrt(c.reduce((s, v, i) => s + (v - point[i]) ** 2, 0)));\\n            clusters[dists.indexOf(Math.min(...dists))].push(point);\\n        }\\n        const newCentroids = clusters.map(c => { if (!c.length) return data[Math.floor(Math.random() * data.length)]; return c[0].map((_, i) => c.reduce((s, p) => s + p[i], 0) / c.length); });\\n        if (JSON.stringify(newCentroids) === JSON.stringify(centroids)) break;\\n        centroids = newCentroids;\\n    }\\n    return centroids;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"K-means kumeleme algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static double[][] kMeans(double[][] data, int k, int maxIter) {\\n    Random rand = new Random(); double[][] centroids = Arrays.copyOf(data, k);\\n    for (int iter = 0; iter < maxIter; iter++) {\\n        List<List<double[]>> clusters = new ArrayList<>(); for (int i = 0; i < k; i++) clusters.add(new ArrayList<>());\\n        for (double[] point : data) {\\n            int nearest = 0; double minDist = Double.MAX_VALUE;\\n            for (int j = 0; j < k; j++) { double dist = 0; for (int d = 0; d < point.length; d++) dist += Math.pow(point[d] - centroids[j][d], 2); if (dist < minDist) { minDist = dist; nearest = j; } }\\n            clusters.get(nearest).add(point);\\n        }\\n        double[][] newCentroids = new double[k][data[0].length];\\n        for (int j = 0; j < k; j++) {\\n            if (clusters.get(j).isEmpty()) { newCentroids[j] = data[rand.nextInt(data.length)]; continue; }\\n            for (int d = 0; d < data[0].length; d++) { final int dim = d; newCentroids[j][d] = clusters.get(j).stream().mapToDouble(p -> p[dim]).average().orElse(0); }\\n        }\\n        if (Arrays.deepEquals(newCentroids, centroids)) break;\\n        centroids = newCentroids;\\n    }\\n    return centroids;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"K-en yakin komsu (KNN) siniflandirma algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import math, collections\\ndef knn(train_data, train_labels, test_point, k):\\n    distances = [(math.sqrt(sum((train_point[i] - test_point[i])**2 for i in range(len(train_point)))), train_labels[j]) for j, train_point in enumerate(train_data)]\\n    distances.sort(key=lambda x: x[0])\\n    k_nearest = [label for _, label in distances[:k]]\\n    return collections.Counter(k_nearest).most_common(1)[0][0]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"K-en yakin komsu (KNN) siniflandirma algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function knn(trainData, trainLabels, testPoint, k) {\\n    const distances = trainData.map((point, i) => ({ dist: Math.sqrt(point.reduce((s, v, j) => s + (v - testPoint[j]) ** 2, 0)), label: trainLabels[i] }));\\n    distances.sort((a, b) => a.dist - b.dist);\\n    const nearest = distances.slice(0, k);\\n    const counts = {};\\n    nearest.forEach(n => { counts[n.label] = (counts[n.label] || 0) + 1; });\\n    return Object.keys(counts).reduce((a, b) => counts[a] > counts[b] ? a : b);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"K-en yakin komsu (KNN) siniflandirma algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static String knn(double[][] trainData, String[] trainLabels, double[] testPoint, int k) {\\n    PriorityQueue<AbstractMap.SimpleEntry<Double, String>> pq = new PriorityQueue<>(Comparator.comparingDouble(Map.Entry::getKey));\\n    for (int i = 0; i < trainData.length; i++) {\\n        double dist = 0; for (int j = 0; j < trainData[i].length; j++) dist += Math.pow(trainData[i][j] - testPoint[j], 2);\\n        pq.offer(new AbstractMap.SimpleEntry<>(Math.sqrt(dist), trainLabels[i]));\\n        if (pq.size() > k) pq.poll();\\n    }\\n    Map<String, Integer> counts = new HashMap<>();\\n    while (!pq.isEmpty()) { String label = pq.poll().getValue(); counts.put(label, counts.getOrDefault(label, 0) + 1); }\\n    return counts.entrySet().stream().max(Map.Entry.comparingByValue()).get().getKey();\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Naive Bayes siniflandirma algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import math\\ndef naive_bayes(X, y, x_test):\\n    classes = set(y); n = len(y); probs = {}\\n    for c in classes:\\n        X_c = [X[i] for i in range(n) if y[i] == c]\\n        probs[c] = math.log(len(X_c) / n)\\n        for j in range(len(x_test)):\\n            mean = sum(row[j] for row in X_c) / len(X_c)\\n            var = sum((row[j] - mean)**2 for row in X_c) / len(X_c)\\n            prob = (1 / math.sqrt(2 * math.pi * var)) * math.exp(-(x_test[j] - mean)**2 / (2 * var)) if var > 0 else 1e-10\\n            probs[c] += math.log(prob)\\n    return max(probs, key=probs.get)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Naive Bayes siniflandirma algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function naiveBayes(X, y, xTest) {\\n    const classes = [...new Set(y)]; const n = y.length; const probs = {};\\n    for (const c of classes) {\\n        const Xc = X.filter((_, i) => y[i] === c);\\n        probs[c] = Math.log(Xc.length / n);\\n        for (let j = 0; j < xTest.length; j++) {\\n            const mean = Xc.reduce((s, row) => s + row[j], 0) / Xc.length;\\n            const variance = Xc.reduce((s, row) => s + (row[j] - mean) ** 2, 0) / Xc.length;\\n            const varCorr = variance || 1e-10;\\n            probs[c] += Math.log((1 / Math.sqrt(2 * Math.PI * varCorr)) * Math.exp(-(xTest[j] - mean) ** 2 / (2 * varCorr)));\\n        }\\n    }\\n    return Object.keys(probs).reduce((a, b) => probs[a] > probs[b] ? a : b);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Naive Bayes siniflandirma algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static String naiveBayes(double[][] X, String[] y, double[] xTest) {\\n    Set<String> classes = new HashSet<>(Arrays.asList(y));\\n    Map<String, Double> probs = new HashMap<>(); int n = y.length;\\n    for (String c : classes) {\\n        List<double[]> Xc = new ArrayList<>();\\n        for (int i = 0; i < n; i++) { if (y[i].equals(c)) Xc.add(X[i]); }\\n        double logProb = Math.log((double) Xc.size() / n);\\n        for (int j = 0; j < xTest.length; j++) {\\n            final int dim = j;\\n            double mean = Xc.stream().mapToDouble(row -> row[dim]).average().orElse(0);\\n            double var = Xc.stream().mapToDouble(row -> Math.pow(row[dim] - mean, 2)).average().orElse(1e-10);\\n            if (var == 0) var = 1e-10;\\n            logProb += Math.log((1 / Math.sqrt(2 * Math.PI * var)) * Math.exp(-Math.pow(xTest[j] - mean, 2) / (2 * var)));\\n        }\\n        probs.put(c, logProb);\\n    }\\n    return probs.entrySet().stream().max(Map.Entry.comparingByValue()).get().getKey();\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Karar agaci (decision tree) siniflandirma algoritmasini uygulayan basit sinif yaz\",\"response\":\"import math, collections\\ndef decision_tree_train(X, y, features):\\n    if len(set(y)) == 1: return y[0]\\n    if not features: return collections.Counter(y).most_common(1)[0][0]\\n    best_feat = min(features, key=lambda f: entropy_split(X, y, f))\\n    tree = {best_feat: {}}\\n    for val in set(X[i][best_feat] for i in range(len(X))):\\n        sub_X = [X[i] for i in range(len(X)) if X[i][best_feat] == val]\\n        sub_y = [y[i] for i in range(len(X)) if X[i][best_feat] == val]\\n        tree[best_feat][val] = decision_tree_train(sub_X, sub_y, [f for f in features if f != best_feat])\\n    return tree\\ndef entropy_split(X, y, feat):\\n    total = len(y); result = 0\\n    for val in set(X[i][feat] for i in range(total)):\\n        sub_y = [y[i] for i in range(total) if X[i][feat] == val]\\n        p = len(sub_y) / total\\n        e = 0\\n        for c in set(sub_y):\\n            pc = sub_y.count(c) / len(sub_y)\\n            if pc > 0: e -= pc * math.log2(pc)\\n        result += p * e\\n    return result\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Karar agaci (decision tree) siniflandirma algoritmasini uygulayan basit sinif yaz\",\"response\":\"function decisionTreeTrain(X, y, features) {\\n    if (new Set(y).size === 1) return y[0];\\n    if (features.length === 0) return y.reduce((a, b) => y.filter(v => v === a).length >= y.filter(v => v === b).length ? a : b);\\n    const bestFeat = features.reduce((a, b) => entropySplit(X, y, a) <= entropySplit(X, y, b) ? a : b);\\n    const tree = { [bestFeat]: {} };\\n    const vals = [...new Set(X.map(row => row[bestFeat]))];\\n    for (const val of vals) {\\n        const indices = X.map((row, i) => row[bestFeat] === val ? i : -1).filter(i => i !== -1);\\n        const subX = indices.map(i => X[i]); const subY = indices.map(i => y[i]);\\n        tree[bestFeat][val] = decisionTreeTrain(subX, subY, features.filter(f => f !== bestFeat));\\n    }\\n    return tree;\\n}\\nfunction entropySplit(X, y, feat) {\\n    let result = 0; const total = y.length;\\n    const vals = [...new Set(X.map(row => row[feat]))];\\n    for (const val of vals) {\\n        const subY = y.filter((_, i) => X[i][feat] === val);\\n        const p = subY.length / total;\\n        let e = 0; const classes = [...new Set(subY)];\\n        for (const c of classes) { const pc = subY.filter(v => v === c).length / subY.length; if (pc > 0) e -= pc * Math.log2(pc); }\\n        result += p * e;\\n    }\\n    return result;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Karar agaci (decision tree) siniflandirma algoritmasini uygulayan basit sinif yaz\",\"response\":\"public static Object decisionTreeTrain(double[][] X, String[] y, List<Integer> features) {\\n    Set<String> uniqueY = new HashSet<>(Arrays.asList(y));\\n    if (uniqueY.size() == 1) return y[0];\\n    if (features.isEmpty()) { Map<String, Long> count = Arrays.stream(y).collect(Collectors.groupingBy(Function.identity(), Collectors.counting())); return count.entrySet().stream().max(Map.Entry.comparingByValue()).get().getKey(); }\\n    int bestFeat = features.get(0); double bestEnt = Double.MAX_VALUE;\\n    for (int f : features) { double e = entropySplit(X, y, f); if (e < bestEnt) { bestEnt = e; bestFeat = f; } }\\n    Map<Double, Object> tree = new HashMap<>();\\n    Set<Double> vals = new HashSet<>(); for (double[] row : X) vals.add(row[bestFeat]);\\n    for (double val : vals) {\\n        List<Integer> indices = new ArrayList<>();\\n        for (int i = 0; i < X.length; i++) { if (X[i][bestFeat] == val) indices.add(i); }\\n        double[][] subX = new double[indices.size()][]; String[] subY = new String[indices.size()];\\n        for (int i = 0; i < indices.size(); i++) { subX[i] = X[indices.get(i)]; subY[i] = y[indices.get(i)]; }\\n        List<Integer> remaining = features.stream().filter(f -> f != bestFeat).collect(Collectors.toList());\\n        tree.put(val, decisionTreeTrain(subX, subY, remaining));\\n    }\\n    Map<Object, Object> result = new HashMap<>(); result.put(bestFeat, tree); return result;\\n}\\nprivate static double entropySplit(double[][] X, String[] y, int feat) {\\n    double result = 0; int total = y.length;\\n    Map<Double, List<Integer>> splits = new HashMap<>();\\n    for (int i = 0; i < total; i++) { splits.computeIfAbsent(X[i][feat], k -> new ArrayList<>()).add(i); }\\n    for (var entry : splits.entrySet()) {\\n        List<String> subY = entry.getValue().stream().map(i -> y[i]).collect(Collectors.toList());\\n        double p = (double) subY.size() / total;\\n        double e = 0; Map<String, Long> counts = subY.stream().collect(Collectors.groupingBy(Function.identity(), Collectors.counting()));\\n        for (long c : counts.values()) { double pc = (double) c / subY.size(); if (pc > 0) e -= pc * (Math.log(pc) / Math.log(2)); }\\n        result += p * e;\\n    }\\n    return result;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rastgele orman (random forest) siniflandirma algoritmasini uygulayan basit sinif yaz\",\"response\":\"import random, math, collections\\ndef random_forest(X, y, n_trees=10, max_depth=5):\\n    trees = []\\n    for _ in range(n_trees):\\n        indices = [random.randint(0, len(X) - 1) for _ in range(len(X))]\\n        bx = [X[i] for i in indices]; by = [y[i] for i in indices]\\n        tree = simple_tree(bx, by, max_depth)\\n        trees.append(tree)\\n    return trees\\ndef simple_tree(X, y, max_depth, depth=0):\\n    if len(set(y)) == 1 or depth >= max_depth:\\n        return collections.Counter(y).most_common(1)[0][0]\\n    feat = random.randint(0, len(X[0]) - 1)\\n    tree = {feat: {}}\\n    for val in set(X[i][feat] for i in range(len(X))):\\n        sub_y = [y[i] for i in range(len(X)) if X[i][feat] == val]\\n        sub_x = [X[i] for i in range(len(X)) if X[i][feat] == val]\\n        tree[feat][val] = simple_tree(sub_x, sub_y, max_depth, depth + 1)\\n    return tree\\ndef forest_predict(trees, x):\\n    votes = []\\n    for tree in trees:\\n        node = tree\\n        while isinstance(node, dict):\\n            feat = list(node.keys())[0]\\n            val = x[feat]\\n            node = node[feat].get(val, list(node[feat].values())[0])\\n        votes.append(node)\\n    return collections.Counter(votes).most_common(1)[0][0]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rastgele orman (random forest) siniflandirma algoritmasini uygulayan basit sinif yaz\",\"response\":\"function randomForest(X, y, nTrees = 10, maxDepth = 5) {\\n    const trees = [];\\n    for (let t = 0; t < nTrees; t++) {\\n        const indices = Array.from({length: X.length}, () => Math.floor(Math.random() * X.length));\\n        const bx = indices.map(i => X[i]); const by = indices.map(i => y[i]);\\n        trees.push(simpleTree(bx, by, maxDepth));\\n    }\\n    return trees;\\n}\\nfunction simpleTree(X, y, maxDepth, depth = 0) {\\n    if (new Set(y).size === 1 || depth >= maxDepth) return y.reduce((a, b) => y.filter(v => v === a).length >= y.filter(v => v === b).length ? a : b);\\n    const feat = Math.floor(Math.random() * X[0].length);\\n    const tree = { [feat]: {} };\\n    const vals = [...new Set(X.map(row => row[feat]))];\\n    for (const val of vals) {\\n        const indices = X.map((row, i) => row[feat] === val ? i : -1).filter(i => i !== -1);\\n        tree[feat][val] = simpleTree(indices.map(i => X[i]), indices.map(i => y[i]), maxDepth, depth + 1);\\n    }\\n    return tree;\\n}\\nfunction forestPredict(trees, x) {\\n    const votes = trees.map(tree => {\\n        let node = tree;\\n        while (typeof node === 'object') { const feat = parseInt(Object.keys(node)[0]); node = node[feat][x[feat]] || Object.values(node[feat])[0]; }\\n        return node;\\n    });\\n    return votes.reduce((a, b) => votes.filter(v => v === a).length >= votes.filter(v => v === b).length ? a : b);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Rastgele orman (random forest) siniflandirma algoritmasini uygulayan basit sinif yaz\",\"response\":\"public static List<Object> randomForest(double[][] X, String[] y, int nTrees, int maxDepth) {\\n    List<Object> trees = new ArrayList<>(); Random rand = new Random();\\n    for (int t = 0; t < nTrees; t++) {\\n        double[][] bx = new double[X.length][]; String[] by = new String[y.length];\\n        for (int i = 0; i < X.length; i++) { int idx = rand.nextInt(X.length); bx[i] = X[idx]; by[i] = y[idx]; }\\n        trees.add(simpleTree(bx, by, maxDepth, 0));\\n    }\\n    return trees;\\n}\\nprivate static Object simpleTree(double[][] X, String[] y, int maxDepth, int depth) {\\n    Set<String> unique = new HashSet<>(Arrays.asList(y));\\n    if (unique.size() == 1 || depth >= maxDepth) {\\n        Map<String, Long> count = Arrays.stream(y).collect(Collectors.groupingBy(Function.identity(), Collectors.counting()));\\n        return count.entrySet().stream().max(Map.Entry.comparingByValue()).get().getKey();\\n    }\\n    int feat = new Random().nextInt(X[0].length);\\n    Map<Object, Object> tree = new HashMap<>();\\n    Set<Double> vals = new HashSet<>(); for (double[] row : X) vals.add(row[feat]);\\n    for (double val : vals) {\\n        List<Integer> indices = new ArrayList<>();\\n        for (int i = 0; i < X.length; i++) { if (X[i][feat] == val) indices.add(i); }\\n        double[][] subX = new double[indices.size()][]; String[] subY = new String[indices.size()];\\n        for (int i = 0; i < indices.size(); i++) { subX[i] = X[indices.get(i)]; subY[i] = y[indices.get(i)]; }\\n        tree.put(val, simpleTree(subX, subY, maxDepth, depth + 1));\\n    }\\n    Map<Object, Object> result = new HashMap<>(); result.put(feat, tree); return result;\\n}\\npublic static String forestPredict(List<Object> trees, double[] x) {\\n    List<String> votes = new ArrayList<>();\\n    for (Object tree : trees) {\\n        Object node = tree;\\n        while (node instanceof Map) { Map<Object, Object> m = (Map<Object, Object>) node; int feat = (int) m.keySet().iterator().next(); Map<Object, Object> branches = (Map<Object, Object>) m.get(feat); node = branches.getOrDefault(x[feat], branches.values().iterator().next()); }\\n        votes.add((String) node);\\n    }\\n    Map<String, Long> count = votes.stream().collect(Collectors.groupingBy(Function.identity(), Collectors.counting()));\\n    return count.entrySet().stream().max(Map.Entry.comparingByValue()).get().getKey();\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dogrusal regresyon (linear regression) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def linear_regression(X, y):\\n    n = len(X); mx = sum(X) / n; my = sum(y) / n\\n    num = sum((X[i] - mx) * (y[i] - my) for i in range(n))\\n    den = sum((X[i] - mx)**2 for i in range(n))\\n    slope = num / den; intercept = my - slope * mx\\n    return slope, intercept\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dogrusal regresyon (linear regression) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function linearRegression(X, y) {\\n    const n = X.length; const mx = X.reduce((a, b) => a + b, 0) / n; const my = y.reduce((a, b) => a + b, 0) / n;\\n    let num = 0, den = 0;\\n    for (let i = 0; i < n; i++) { num += (X[i] - mx) * (y[i] - my); den += (X[i] - mx) ** 2; }\\n    const slope = num / den; const intercept = my - slope * mx;\\n    return { slope, intercept };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dogrusal regresyon (linear regression) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static double[] linearRegression(double[] X, double[] y) {\\n    int n = X.length; double mx = Arrays.stream(X).average().orElse(0); double my = Arrays.stream(y).average().orElse(0);\\n    double num = 0, den = 0;\\n    for (int i = 0; i < n; i++) { num += (X[i] - mx) * (y[i] - my); den += (X[i] - mx) * (X[i] - mx); }\\n    double slope = num / den; double intercept = my - slope * mx;\\n    return new double[]{slope, intercept};\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Dogrusal regresyon (linear regression) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func LinearRegression(X, y []float64) (float64, float64) {\\n    n := len(X); mx, my := 0.0, 0.0\\n    for i := 0; i < n; i++ { mx += X[i]; my += y[i] }\\n    mx /= float64(n); my /= float64(n)\\n    var num, den float64\\n    for i := 0; i < n; i++ { num += (X[i] - mx) * (y[i] - my); den += (X[i] - mx) * (X[i] - mx) }\\n    slope := num / den; intercept := my - slope*mx\\n    return slope, intercept\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"PCA (Principal Component Analysis) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import numpy as np\\ndef pca(X, n_components):\\n    X_std = (X - np.mean(X, axis=0)) / np.std(X, axis=0)\\n    cov = np.cov(X_std.T)\\n    eig_vals, eig_vecs = np.linalg.eig(cov)\\n    idx = np.argsort(eig_vals)[::-1][:n_components]\\n    return eig_vecs[:, idx], eig_vals[idx]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"PCA (Principal Component Analysis) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function pca(X, nComponents) {\\n    const n = X.length, dims = X[0].length;\\n    const means = Array.from({length: dims}, (_, j) => X.reduce((s, row) => s + row[j], 0) / n);\\n    const stds = Array.from({length: dims}, (_, j) => Math.sqrt(X.reduce((s, row) => s + (row[j] - means[j]) ** 2, 0) / n));\\n    const Xstd = X.map(row => row.map((v, j) => (v - means[j]) / (stds[j] || 1)));\\n    const cov = Array.from({length: dims}, (_, i) => Array.from({length: dims}, (_, j) => Xstd.reduce((s, row) => s + row[i] * row[j], 0) / (n - 1)));\\n    const { vectors, values } = eigenDecomposition(cov);\\n    const indices = values.map((v, i) => i).sort((a, b) => values[b] - values[a]).slice(0, nComponents);\\n    return { components: indices.map(i => vectors[i]), values: indices.map(i => values[i]) };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"PCA (Principal Component Analysis) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static double[][] pca(double[][] X, int nComponents) {\\n    int n = X.length, dims = X[0].length;\\n    double[] means = new double[dims]; double[] stds = new double[dims];\\n    for (int j = 0; j < dims; j++) { final int d = j; means[j] = Arrays.stream(X).mapToDouble(row -> row[d]).average().orElse(0); }\\n    for (int j = 0; j < dims; j++) { final int d = j; double m = means[j]; stds[j] = Math.sqrt(Arrays.stream(X).mapToDouble(row -> Math.pow(row[d] - m, 2)).average().orElse(0)); }\\n    double[][] Xstd = new double[n][dims];\\n    for (int i = 0; i < n; i++) for (int j = 0; j < dims; j++) Xstd[i][j] = (X[i][j] - means[j]) / (stds[j] == 0 ? 1 : stds[j]);\\n    double[][] cov = new double[dims][dims];\\n    for (int i = 0; i < dims; i++) for (int j = 0; j < dims; j++) { final int a = i, b = j; cov[i][j] = Arrays.stream(Xstd).mapToDouble(row -> row[a] * row[b]).average().orElse(0); }\\n    Jama.EigenvalueDecomposition eig = new Jama.EigenvalueDecomposition(new Jama.Matrix(cov));\\n    double[] eigVals = eig.getRealEigenvalues();\\n    double[][] eigVecs = eig.getV().getArray();\\n    Integer[] idx = new Integer[dims]; for (int i = 0; i < dims; i++) idx[i] = i;\\n    Arrays.sort(idx, (a, b) -> Double.compare(eigVals[b], eigVals[a]));\\n    double[][] result = new double[dims][nComponents];\\n    for (int i = 0; i < nComponents; i++) for (int j = 0; j < dims; j++) result[j][i] = eigVecs[j][idx[i]];\\n    return result;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Lojistik regresyon (logistic regression) algoritmasini uygulayan sinif yaz\",\"response\":\"import math\\nclass LogisticRegression:\\n    def __init__(self, lr=0.01, epochs=1000):\\n        self.lr = lr; self.epochs = epochs; self.weights = None; self.bias = None\\n    def sigmoid(self, z): return 1 / (1 + math.exp(-z))\\n    def fit(self, X, y):\\n        n, m = len(X), len(X[0])\\n        self.weights = [0.0] * m; self.bias = 0.0\\n        for _ in range(self.epochs):\\n            for i in range(n):\\n                z = sum(self.weights[j] * X[i][j] for j in range(m)) + self.bias\\n                pred = self.sigmoid(z)\\n                error = pred - y[i]\\n                for j in range(m): self.weights[j] -= self.lr * error * X[i][j]\\n                self.bias -= self.lr * error\\n    def predict(self, X):\\n        z = sum(self.weights[j] * X[j] for j in range(len(X))) + self.bias\\n        return 1 if self.sigmoid(z) >= 0.5 else 0\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Lojistik regresyon (logistic regression) algoritmasini uygulayan sinif yaz\",\"response\":\"class LogisticRegression {\\n    constructor(lr = 0.01, epochs = 1000) { this.lr = lr; this.epochs = epochs; this.weights = null; this.bias = 0; }\\n    sigmoid(z) { return 1 / (1 + Math.exp(-z)); }\\n    fit(X, y) {\\n        const n = X.length, m = X[0].length;\\n        this.weights = new Array(m).fill(0); this.bias = 0;\\n        for (let ep = 0; ep < this.epochs; ep++) {\\n            for (let i = 0; i < n; i++) {\\n                let z = this.bias; for (let j = 0; j < m; j++) z += this.weights[j] * X[i][j];\\n                const pred = this.sigmoid(z); const error = pred - y[i];\\n                for (let j = 0; j < m; j++) this.weights[j] -= this.lr * error * X[i][j];\\n                this.bias -= this.lr * error;\\n            }\\n        }\\n    }\\n    predict(X) { let z = this.bias; for (let j = 0; j < X.length; j++) z += this.weights[j] * X[j]; return this.sigmoid(z) >= 0.5 ? 1 : 0; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Lojistik regresyon (logistic regression) algoritmasini uygulayan sinif yaz\",\"response\":\"type LogisticRegression struct { lr float64; epochs int; weights []float64; bias float64 }\\nfunc NewLogisticRegression(lr float64, epochs int) *LogisticRegression { return &LogisticRegression{lr: lr, epochs: epochs} }\\nfunc (lr *LogisticRegression) sigmoid(z float64) float64 { return 1.0 / (1.0 + math.Exp(-z)) }\\nfunc (lr *LogisticRegression) Fit(X [][]float64, y []int) {\\n    n, m := len(X), len(X[0])\\n    lr.weights = make([]float64, m); lr.bias = 0\\n    for ep := 0; ep < lr.epochs; ep++ {\\n        for i := 0; i < n; i++ {\\n            z := lr.bias\\n            for j := 0; j < m; j++ { z += lr.weights[j] * X[i][j] }\\n            pred := lr.sigmoid(z); err := pred - float64(y[i])\\n            for j := 0; j < m; j++ { lr.weights[j] -= lr.lr * err * X[i][j] }\\n            lr.bias -= lr.lr * err\\n        }\\n    }\\n}\\nfunc (lr *LogisticRegression) Predict(X []float64) int {\\n    z := lr.bias\\n    for j := 0; j < len(X); j++ { z += lr.weights[j] * X[j] }\\n    if lr.sigmoid(z) >= 0.5 { return 1 }; return 0\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Destek vektor makineleri (SVM) algoritmasini uygulayan basit sinif yaz\",\"response\":\"class SVM:\\n    def __init__(self, lr=0.001, lambda_param=0.01, epochs=1000):\\n        self.lr = lr; self.lambda_param = lambda_param; self.epochs = epochs\\n        self.w = None; self.b = None\\n    def fit(self, X, y):\\n        n, m = len(X), len(X[0])\\n        self.w = [0.0] * m; self.b = 0\\n        y = [-1 if yi == 0 else 1 for yi in y]\\n        for _ in range(self.epochs):\\n            for i in range(n):\\n                cond = y[i] * (sum(self.w[j] * X[i][j] for j in range(m)) + self.b)\\n                if cond >= 1:\\n                    for j in range(m): self.w[j] -= self.lr * self.lambda_param * self.w[j]\\n                else:\\n                    for j in range(m): self.w[j] -= self.lr * (self.lambda_param * self.w[j] - y[i] * X[i][j])\\n                    self.b -= self.lr * y[i]\\n    def predict(self, X):\\n        z = sum(self.w[j] * X[j] for j in range(len(X))) + self.b\\n        return 1 if z >= 0 else 0\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Destek vektor makineleri (SVM) algoritmasini uygulayan basit sinif yaz\",\"response\":\"class SVM {\\n    constructor(lr = 0.001, lambdaParam = 0.01, epochs = 1000) { this.lr = lr; this.lambdaParam = lambdaParam; this.epochs = epochs; this.w = null; this.b = 0; }\\n    fit(X, y) {\\n        const n = X.length, m = X[0].length;\\n        this.w = new Array(m).fill(0); this.b = 0;\\n        const yb = y.map(v => v === 0 ? -1 : 1);\\n        for (let ep = 0; ep < this.epochs; ep++) {\\n            for (let i = 0; i < n; i++) {\\n                let z = this.b; for (let j = 0; j < m; j++) z += this.w[j] * X[i][j];\\n                const cond = yb[i] * z;\\n                if (cond >= 1) { for (let j = 0; j < m; j++) this.w[j] -= this.lr * this.lambdaParam * this.w[j]; }\\n                else { for (let j = 0; j < m; j++) this.w[j] -= this.lr * (this.lambdaParam * this.w[j] - yb[i] * X[i][j]); this.b -= this.lr * yb[i]; }\\n            }\\n        }\\n    }\\n    predict(X) { let z = this.b; for (let j = 0; j < X.length; j++) z += this.w[j] * X[j]; return z >= 0 ? 1 : 0; }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Destek vektor makineleri (SVM) algoritmasini uygulayan basit sinif yaz\",\"response\":\"public class SVM {\\n    private double[] w; private double b; private double lr, lambdaParam; private int epochs;\\n    public SVM(double lr, double lambdaParam, int epochs) { this.lr = lr; this.lambdaParam = lambdaParam; this.epochs = epochs; }\\n    public void fit(double[][] X, int[] y) {\\n        int n = X.length, m = X[0].length;\\n        w = new double[m]; b = 0; int[] yb = new int[n]; for (int i = 0; i < n; i++) yb[i] = y[i] == 0 ? -1 : 1;\\n        for (int ep = 0; ep < epochs; ep++) {\\n            for (int i = 0; i < n; i++) {\\n                double z = b; for (int j = 0; j < m; j++) z += w[j] * X[i][j];\\n                double cond = yb[i] * z;\\n                if (cond >= 1) { for (int j = 0; j < m; j++) w[j] -= lr * lambdaParam * w[j]; }\\n                else { for (int j = 0; j < m; j++) w[j] -= lr * (lambdaParam * w[j] - yb[i] * X[i][j]); b -= lr * yb[i]; }\\n            }\\n        }\\n    }\\n    public int predict(double[] X) { double z = b; for (int j = 0; j < X.length; j++) z += w[j] * X[j]; return z >= 0 ? 1 : 0; }\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Gradyan ini?i (gradient descent) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def gradient_descent(gradient, start, learn_rate, n_iter):\\n    vector = start\\n    for _ in range(n_iter):\\n        vector -= learn_rate * gradient(vector)\\n    return vector\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Gradyan ini?i (gradient descent) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function gradientDescent(gradient, start, learnRate, nIter) {\\n    let vector = start;\\n    for (let i = 0; i < nIter; i++) { for (let j = 0; j < vector.length; j++) vector[j] -= learnRate * gradient(vector)[j]; }\\n    return vector;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Gradyan ini?i (gradient descent) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func GradientDescent(gradient func([]float64) []float64, start []float64, learnRate float64, nIter int) []float64 {\\n    vector := make([]float64, len(start)); copy(vector, start)\\n    for i := 0; i < nIter; i++ {\\n        grad := gradient(vector)\\n        for j := range vector { vector[j] -= learnRate * grad[j] }\\n    }\\n    return vector\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cok katmanli algilayici (MLP) sinir agi uygulayan basit sinif yaz\",\"response\":\"import math, random\\nclass MLP:\\n    def __init__(self, layers):\\n        self.layers = layers; self.weights = []; self.biases = []\\n        for i in range(len(layers) - 1):\\n            self.weights.append([[random.uniform(-1, 1) for _ in range(layers[i])] for _ in range(layers[i+1])])\\n            self.biases.append([0.0] * layers[i+1])\\n    def sigmoid(self, x): return 1 / (1 + math.exp(-x))\\n    def forward(self, x):\\n        for l in range(len(self.weights)):\\n            x = [self.sigmoid(sum(self.weights[l][j][k] * x[k] for k in range(len(x))) + self.biases[l][j]) for j in range(len(self.weights[l]))]\\n        return x\\n    def train(self, X, y, epochs=100, lr=0.1):\\n        for _ in range(epochs):\\n            for xi, yi in zip(X, y):\\n                activations = [xi]; a = xi\\n                for l in range(len(self.weights)):\\n                    a = [self.sigmoid(sum(self.weights[l][j][k] * a[k] for k in range(len(a))) + self.biases[l][j]) for j in range(len(self.weights[l]))]\\n                    activations.append(a)\\n                errors = [yi[j] - a[j] for j in range(len(yi))]\\n                for l in reversed(range(len(self.weights))):\\n                    new_errors = [0] * len(self.weights[l-1]) if l > 0 else []\\n                    for j in range(len(self.weights[l])):\\n                        out = activations[l+1][j]\\n                        delta = errors[j] * out * (1 - out)\\n                        for k in range(len(self.weights[l][j])): self.weights[l][j][k] += lr * delta * activations[l][k]\\n                        self.biases[l][j] += lr * delta\\n                        if l > 0: new_errors[k] += delta * self.weights[l][j][k]\\n                    errors = new_errors\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cok katmanli algilayici (MLP) sinir agi uygulayan basit sinif yaz\",\"response\":\"class MLP {\\n    constructor(layers) {\\n        this.layers = layers; this.weights = []; this.biases = [];\\n        for (let i = 0; i < layers.length - 1; i++) {\\n            this.weights.push(Array.from({length: layers[i+1]}, () => Array.from({length: layers[i]}, () => Math.random() * 2 - 1)));\\n            this.biases.push(new Array(layers[i+1]).fill(0));\\n        }\\n    }\\n    sigmoid(x) { return 1 / (1 + Math.exp(-x)); }\\n    forward(x) {\\n        let a = x;\\n        for (let l = 0; l < this.weights.length; l++) { a = this.weights[l].map((w, j) => this.sigmoid(w.reduce((s, v, k) => s + v * a[k], 0) + this.biases[l][j])); }\\n        return a;\\n    }\\n    train(X, y, epochs = 100, lr = 0.1) {\\n        for (let ep = 0; ep < epochs; ep++) {\\n            for (let i = 0; i < X.length; i++) {\\n                const activations = [X[i]]; let a = X[i];\\n                for (let l = 0; l < this.weights.length; l++) { a = this.weights[l].map((w, j) => this.sigmoid(w.reduce((s, v, k) => s + v * a[k], 0) + this.biases[l][j])); activations.push(a); }\\n                let errors = y[i].map((t, j) => t - a[j]);\\n                for (let l = this.weights.length - 1; l >= 0; l--) {\\n                    const newErrors = l > 0 ? new Array(this.weights[l-1].length).fill(0) : [];\\n                    for (let j = 0; j < this.weights[l].length; j++) {\\n                        const out = activations[l+1][j]; const delta = errors[j] * out * (1 - out);\\n                        for (let k = 0; k < this.weights[l][j].length; k++) { this.weights[l][j][k] += lr * delta * activations[l][k]; if (l > 0) newErrors[k] += delta * this.weights[l][j][k]; }\\n                        this.biases[l][j] += lr * delta;\\n                    }\\n                    errors = newErrors;\\n                }\\n            }\\n        }\\n    }\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Cok katmanli algilayici (MLP) sinir agi uygulayan basit sinif yaz\",\"response\":\"type MLP struct { layers []int; weights [][][]float64; biases [][]float64 }\\nfunc NewMLP(layers []int) *MLP {\\n    mlp := &MLP{layers: layers}\\n    for i := 0; i < len(layers)-1; i++ {\\n        w := make([][]float64, layers[i+1])\\n        for j := range w { w[j] = make([]float64, layers[i]); for k := range w[j] { w[j][k] = rand.Float64()*2 - 1 } }\\n        mlp.weights = append(mlp.weights, w)\\n        mlp.biases = append(mlp.biases, make([]float64, layers[i+1]))\\n    }\\n    return mlp\\n}\\nfunc (mlp *MLP) sigmoid(x float64) float64 { return 1.0 / (1.0 + math.Exp(-x)) }\\nfunc (mlp *MLP) Forward(x []float64) []float64 {\\n    a := make([]float64, len(x)); copy(a, x)\\n    for l := range mlp.weights {\\n        next := make([]float64, len(mlp.weights[l]))\\n        for j := range mlp.weights[l] {\\n            s := mlp.biases[l][j]\\n            for k := range mlp.weights[l][j] { s += mlp.weights[l][j][k] * a[k] }\\n            next[j] = mlp.sigmoid(s)\\n        }\\n        a = next\\n    }\\n    return a\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Oneri sistemi - isbirlikci filtreleme (collaborative filtering) uygulayan fonksiyon yaz\",\"response\":\"import math\\ndef collaborative_filtering(ratings, user, k=3):\\n    n_users = len(ratings); n_items = len(ratings[0])\\n    def cosine_sim(a, b):\\n        common = [(ratings[a][i], ratings[b][i]) for i in range(n_items) if ratings[a][i] > 0 and ratings[b][i] > 0]\\n        if not common: return 0\\n        dot = sum(x * y for x, y in common)\\n        na = math.sqrt(sum(x**2 for x, y in common))\\n        nb = math.sqrt(sum(y**2 for x, y in common))\\n        return dot / (na * nb) if na * nb > 0 else 0\\n    sims = [(cosine_sim(user, i), i) for i in range(n_users) if i != user]\\n    sims.sort(reverse=True)\\n    neighbors = sims[:k]\\n    scores = []\\n    for item in range(n_items):\\n        if ratings[user][item] == 0:\\n            num = sum(s * ratings[i][item] for s, i in neighbors if ratings[i][item] > 0)\\n            den = sum(s for s, i in neighbors if ratings[i][item] > 0)\\n            if den > 0: scores.append((item, num / den))\\n    return sorted(scores, key=lambda x: x[1], reverse=True)\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Oneri sistemi - isbirlikci filtreleme (collaborative filtering) uygulayan fonksiyon yaz\",\"response\":\"function collaborativeFiltering(ratings, user, k = 3) {\\n    const nUsers = ratings.length, nItems = ratings[0].length;\\n    function cosineSim(a, b) {\\n        let dot = 0, na = 0, nb = 0;\\n        for (let i = 0; i < nItems; i++) { if (ratings[a][i] > 0 && ratings[b][i] > 0) { dot += ratings[a][i] * ratings[b][i]; na += ratings[a][i] ** 2; nb += ratings[b][i] ** 2; } }\\n        return na && nb ? dot / (Math.sqrt(na) * Math.sqrt(nb)) : 0;\\n    }\\n    const sims = [];\\n    for (let i = 0; i < nUsers; i++) { if (i !== user) sims.push({ sim: cosineSim(user, i), idx: i }); }\\n    sims.sort((a, b) => b.sim - a.sim);\\n    const neighbors = sims.slice(0, k);\\n    const scores = [];\\n    for (let item = 0; item < nItems; item++) {\\n        if (ratings[user][item] === 0) {\\n            let num = 0, den = 0;\\n            for (const n of neighbors) { if (ratings[n.idx][item] > 0) { num += n.sim * ratings[n.idx][item]; den += n.sim; } }\\n            if (den > 0) scores.push({ item, score: num / den });\\n        }\\n    }\\n    return scores.sort((a, b) => b.score - a.score);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Oneri sistemi - isbirlikci filtreleme (collaborative filtering) uygulayan fonksiyon yaz\",\"response\":\"func CollaborativeFiltering(ratings [][]float64, user, k int) []struct{ Item int; Score float64 } {\\n    nUsers, nItems := len(ratings), len(ratings[0])\\n    cosineSim := func(a, b int) float64 {\\n        var dot, na, nb float64\\n        for i := 0; i < nItems; i++ { if ratings[a][i] > 0 && ratings[b][i] > 0 { dot += ratings[a][i] * ratings[b][i]; na += ratings[a][i] * ratings[a][i]; nb += ratings[b][i] * ratings[b][i] } }\\n        if na == 0 || nb == 0 { return 0 }; return dot / (math.Sqrt(na) * math.Sqrt(nb))\\n    }\\n    type simT struct { s float64; idx int }\\n    var sims []simT\\n    for i := 0; i < nUsers; i++ { if i != user { sims = append(sims, simT{cosineSim(user, i), i}) } }\\n    sort.Slice(sims, func(i, j int) bool { return sims[i].s > sims[j].s })\\n    if k > len(sims) { k = len(sims) }\\n    neighbors := sims[:k]\\n    var scores []struct{ Item int; Score float64 }\\n    for item := 0; item < nItems; item++ {\\n        if ratings[user][item] == 0 {\\n            var num, den float64\\n            for _, n := range neighbors { if ratings[n.idx][item] > 0 { num += n.s * ratings[n.idx][item]; den += n.s } }\\n            if den > 0 { scores = append(scores, struct{ Item int; Score float64 }{item, num / den}) }\\n        }\\n    }\\n    sort.Slice(scores, func(i, j int) bool { return scores[i].Score > scores[j].Score })\\n    return scores\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Icerik tabanli filtreleme (content-based filtering) oneri sistemi uygulayan fonksiyon yaz\",\"response\":\"import math\\ndef content_based_filtering(user_profile, items, item_features, k=3):\\n    scores = []\\n    for i, item in enumerate(items):\\n        dot = sum(user_profile[j] * item_features[i][j] for j in range(len(user_profile)))\\n        nu = math.sqrt(sum(user_profile[j]**2 for j in range(len(user_profile))))\\n        ni = math.sqrt(sum(item_features[i][j]**2 for j in range(len(item_features[i]))))\\n        sim = dot / (nu * ni) if nu * ni > 0 else 0\\n        scores.append((item, sim))\\n    return sorted(scores, key=lambda x: x[1], reverse=True)[:k]\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Icerik tabanli filtreleme (content-based filtering) oneri sistemi uygulayan fonksiyon yaz\",\"response\":\"function contentBasedFiltering(userProfile, items, itemFeatures, k = 3) {\\n    const scores = items.map((item, i) => {\\n        let dot = 0, nu = 0, ni = 0;\\n        for (let j = 0; j < userProfile.length; j++) { dot += userProfile[j] * itemFeatures[i][j]; nu += userProfile[j] ** 2; ni += itemFeatures[i][j] ** 2; }\\n        return { item, score: nu && ni ? dot / (Math.sqrt(nu) * Math.sqrt(ni)) : 0 };\\n    });\\n    return scores.sort((a, b) => b.score - a.score).slice(0, k);\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Icerik tabanli filtreleme (content-based filtering) oneri sistemi uygulayan fonksiyon yaz\",\"response\":\"public static List<AbstractMap.SimpleEntry<String, Double>> contentBasedFiltering(double[] userProfile, String[] items, double[][] itemFeatures, int k) {\\n    List<AbstractMap.SimpleEntry<String, Double>> scores = new ArrayList<>();\\n    for (int i = 0; i < items.length; i++) {\\n        double dot = 0, nu = 0, ni = 0;\\n        for (int j = 0; j < userProfile.length; j++) { dot += userProfile[j] * itemFeatures[i][j]; nu += userProfile[j] * userProfile[j]; ni += itemFeatures[i][j] * itemFeatures[i][j]; }\\n        double sim = nu > 0 && ni > 0 ? dot / (Math.sqrt(nu) * Math.sqrt(ni)) : 0;\\n        scores.add(new AbstractMap.SimpleEntry<>(items[i], sim));\\n    }\\n    scores.sort((a, b) -> Double.compare(b.getValue(), a.getValue()));\\n    return scores.subList(0, Math.min(k, scores.size()));\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Matrix faktorizasyonu (SVD tabanli) oneri sistemi uygulayan fonksiyon yaz\",\"response\":\"import math, random\\ndef matrix_factorization(R, K, steps=5000, alpha=0.0002, beta=0.02):\\n    N = len(R); M = len(R[0])\\n    P = [[random.uniform(0, 0.1) for _ in range(K)] for _ in range(N)]\\n    Q = [[random.uniform(0, 0.1) for _ in range(K)] for _ in range(M)]\\n    for step in range(steps):\\n        for i in range(N):\\n            for j in range(M):\\n                if R[i][j] > 0:\\n                    eij = R[i][j] - sum(P[i][k] * Q[j][k] for k in range(K))\\n                    for k in range(K):\\n                        P[i][k] += alpha * (2 * eij * Q[j][k] - beta * P[i][k])\\n                        Q[j][k] += alpha * (2 * eij * P[i][k] - beta * Q[j][k])\\n    return P, Q\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Matrix faktorizasyonu (SVD tabanli) oneri sistemi uygulayan fonksiyon yaz\",\"response\":\"function matrixFactorization(R, K, steps = 5000, alpha = 0.0002, beta = 0.02) {\\n    const N = R.length, M = R[0].length;\\n    let P = Array.from({length: N}, () => Array.from({length: K}, () => Math.random() * 0.1));\\n    let Q = Array.from({length: M}, () => Array.from({length: K}, () => Math.random() * 0.1));\\n    for (let step = 0; step < steps; step++) {\\n        for (let i = 0; i < N; i++) {\\n            for (let j = 0; j < M; j++) {\\n                if (R[i][j] > 0) {\\n                    let eij = R[i][j];\\n                    for (let k = 0; k < K; k++) eij -= P[i][k] * Q[j][k];\\n                    for (let k = 0; k < K; k++) { P[i][k] += alpha * (2 * eij * Q[j][k] - beta * P[i][k]); Q[j][k] += alpha * (2 * eij * P[i][k] - beta * Q[j][k]); }\\n                }\\n            }\\n        }\\n    }\\n    return { P, Q };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Matrix faktorizasyonu (SVD tabanli) oneri sistemi uygulayan fonksiyon yaz\",\"response\":\"func MatrixFactorization(R [][]float64, K int, steps int, alpha, beta float64) ([][]float64, [][]float64) {\\n    N, M := len(R), len(R[0])\\n    P := make([][]float64, N); Q := make([][]float64, M)\\n    for i := range P { P[i] = make([]float64, K); for k := range P[i] { P[i][k] = rand.Float64() * 0.1 } }\\n    for j := range Q { Q[j] = make([]float64, K); for k := range Q[j] { Q[j][k] = rand.Float64() * 0.1 } }\\n    for step := 0; step < steps; step++ {\\n        for i := 0; i < N; i++ {\\n            for j := 0; j < M; j++ {\\n                if R[i][j] > 0 {\\n                    eij := R[i][j]\\n                    for k := 0; k < K; k++ { eij -= P[i][k] * Q[j][k] }\\n                    for k := 0; k < K; k++ { P[i][k] += alpha * (2*eij*Q[j][k] - beta*P[i][k]); Q[j][k] += alpha * (2*eij*P[i][k] - beta*Q[j][k]) }\\n                }\\n            }\\n        }\\n    }\\n    return P, Q\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Birliktelik kurallari (association rules) - Apriori algoritmasini uygulayan fonksiyon yaz\",\"response\":\"from collections import defaultdict\\ndef apriori(transactions, min_support, min_confidence):\\n    item_counts = defaultdict(int)\\n    for trans in transactions:\\n        for item in trans: item_counts[item] += 1\\n    L1 = {item for item, count in item_counts.items() if count / len(transactions) >= min_support}\\n    freq_sets = [L1]; k = 2\\n    while freq_sets[-1]:\\n        candidates = set()\\n        prev = freq_sets[-1]\\n        prev_list = [set(s) if isinstance(s, frozenset) else {s} for s in prev]\\n        for i in range(len(prev_list)):\\n            for j in range(i + 1, len(prev_list)):\\n                union = prev_list[i] | prev_list[j]\\n                if len(union) == k: candidates.add(frozenset(union))\\n        freq = set()\\n        for cand in candidates:\\n            count = sum(1 for t in transactions if cand.issubset(t))\\n            if count / len(transactions) >= min_support: freq.add(cand)\\n        freq_sets.append(freq); k += 1\\n    rules = []\\n    for freq_set in [item for sublist in freq_sets for item in sublist]:\\n        if isinstance(freq_set, frozenset) and len(freq_set) > 1:\\n            for item in freq_set:\\n                antecedent = freq_set - {item}\\n                supp = sum(1 for t in transactions if freq_set.issubset(t)) / len(transactions)\\n                conf = sum(1 for t in transactions if freq_set.issubset(t)) / max(sum(1 for t in transactions if antecedent.issubset(t)), 1)\\n                if conf >= min_confidence: rules.append((antecedent, {item}, supp, conf))\\n    return rules\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Birliktelik kurallari (association rules) - Apriori algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function apriori(transactions, minSupport, minConfidence) {\\n    const n = transactions.length;\\n    const itemCounts = {}; transactions.forEach(t => t.forEach(item => { itemCounts[item] = (itemCounts[item] || 0) + 1; }));\\n    let freqSets = [new Set(Object.keys(itemCounts).filter(item => itemCounts[item] / n >= minSupport))];\\n    let k = 2;\\n    while (freqSets[freqSets.length - 1].size > 0) {\\n        const prev = [...freqSets[freqSets.length - 1]];\\n        const candidates = new Set();\\n        for (let i = 0; i < prev.length; i++) {\\n            for (let j = i + 1; j < prev.length; j++) {\\n                const union = new Set([...prev[i]].concat([...prev[j]]));\\n                if (union.size === k) candidates.add(union);\\n            }\\n        }\\n        const freq = new Set();\\n        for (const cand of candidates) {\\n            const count = transactions.filter(t => [...cand].every(item => t.includes(item))).length;\\n            if (count / n >= minSupport) freq.add(cand);\\n        }\\n        freqSets.push(freq); k++;\\n    }\\n    const rules = [];\\n    for (const fs of freqSets.flat()) {\\n        if (fs instanceof Set && fs.size > 1) {\\n            for (const item of fs) {\\n                const antecedent = new Set([...fs].filter(x => x !== item));\\n                const supp = transactions.filter(t => [...fs].every(x => t.includes(x))).length / n;\\n                const antCount = transactions.filter(t => [...antecedent].every(x => t.includes(x))).length;\\n                const conf = antCount > 0 ? transactions.filter(t => [...fs].every(x => t.includes(x))).length / antCount : 0;\\n                if (conf >= minConfidence) rules.push({ antecedent, consequent: new Set([item]), support: supp, confidence: conf });\\n            }\\n        }\\n    }\\n    return rules;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Birliktelik kurallari (association rules) - Apriori algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static List<String> apriori(List<Set<String>> transactions, double minSupport, double minConfidence) {\\n    int n = transactions.size();\\n    Map<String, Integer> itemCounts = new HashMap<>();\\n    for (Set<String> t : transactions) { for (String item : t) itemCounts.put(item, itemCounts.getOrDefault(item, 0) + 1); }\\n    Set<Set<String>> freqSets = new HashSet<>();\\n    Set<String> L1 = itemCounts.keySet().stream().filter(item -> itemCounts.get(item) / (double) n >= minSupport).collect(Collectors.toSet());\\n    freqSets.add(L1); int k = 2;\\n    while (!L1.isEmpty()) {\\n        int finalK = k;\\n        List<String> prevList = new ArrayList<>(L1);\\n        Set<Set<String>> candidates = new HashSet<>();\\n        for (int i = 0; i < prevList.size(); i++) {\\n            for (int j = i + 1; j < prevList.size(); j++) {\\n                Set<String> union = new HashSet<>(); union.add(prevList.get(i)); union.add(prevList.get(j));\\n                if (union.size() == finalK) candidates.add(union);\\n            }\\n        }\\n        Set<Set<String>> freq = new HashSet<>();\\n        for (Set<String> cand : candidates) {\\n            long count = transactions.stream().filter(t -> t.containsAll(cand)).count();\\n            if (count / (double) n >= minSupport) freq.add(cand);\\n        }\\n        freqSets.addAll(freq); L1 = freq.stream().flatMap(Set::stream).collect(Collectors.toSet()); k++;\\n    }\\n    return freqSets.stream().flatMap(Set::stream).collect(Collectors.toList());\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"PageRank algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def pagerank(graph, damping=0.85, max_iter=100, tol=1e-6):\\n    n = len(graph)\\n    rank = [1.0 / n] * n\\n    for _ in range(max_iter):\\n        new_rank = [(1 - damping) / n] * n\\n        for i in range(n):\\n            if graph[i]:\\n                share = rank[i] / len(graph[i])\\n                for j in graph[i]: new_rank[j] += damping * share\\n        diff = sum(abs(new_rank[i] - rank[i]) for i in range(n))\\n        rank = new_rank\\n        if diff < tol: break\\n    return rank\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"PageRank algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function pagerank(graph, damping = 0.85, maxIter = 100, tol = 1e-6) {\\n    const n = graph.length; let rank = new Array(n).fill(1 / n);\\n    for (let iter = 0; iter < maxIter; iter++) {\\n        const newRank = new Array(n).fill((1 - damping) / n);\\n        for (let i = 0; i < n; i++) {\\n            if (graph[i].length) { const share = rank[i] / graph[i].length; for (const j of graph[i]) newRank[j] += damping * share; }\\n        }\\n        const diff = rank.reduce((s, v, i) => s + Math.abs(v - newRank[i]), 0);\\n        rank = newRank;\\n        if (diff < tol) break;\\n    }\\n    return rank;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"PageRank algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static double[] pagerank(List<List<Integer>> graph, double damping, int maxIter, double tol) {\\n    int n = graph.size(); double[] rank = new double[n]; Arrays.fill(rank, 1.0 / n);\\n    for (int iter = 0; iter < maxIter; iter++) {\\n        double[] newRank = new double[n]; Arrays.fill(newRank, (1 - damping) / n);\\n        for (int i = 0; i < n; i++) {\\n            List<Integer> out = graph.get(i);\\n            if (!out.isEmpty()) { double share = rank[i] / out.size(); for (int j : out) newRank[j] += damping * share; }\\n        }\\n        double diff = 0; for (int i = 0; i < n; i++) diff += Math.abs(newRank[i] - rank[i]);\\n        rank = newRank;\\n        if (diff < tol) break;\\n    }\\n    return rank;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"PageRank algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func PageRank(graph [][]int, damping float64, maxIter int, tol float64) []float64 {\\n    n := len(graph); rank := make([]float64, n)\\n    for i := range rank { rank[i] = 1.0 / float64(n) }\\n    for iter := 0; iter < maxIter; iter++ {\\n        newRank := make([]float64, n)\\n        for i := range newRank { newRank[i] = (1 - damping) / float64(n) }\\n        for i := 0; i < n; i++ {\\n            if len(graph[i]) > 0 {\\n                share := rank[i] / float64(len(graph[i]))\\n                for _, j := range graph[i] { newRank[j] += damping * share }\\n            }\\n        }\\n        diff := 0.0\\n        for i := 0; i < n; i++ { diff += math.Abs(newRank[i] - rank[i]) }\\n        copy(rank, newRank)\\n        if diff < tol { break }\\n    }\\n    return rank\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Yankipli engelleme (beam search) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"def beam_search(start, goal, expand, beam_width=3, max_depth=10):\\n    beams = [(0, [start])]\\n    for _ in range(max_depth):\\n        candidates = []\\n        for score, path in beams:\\n            for neighbor, cost in expand(path[-1]):\\n                new_path = path + [neighbor]\\n                new_score = score + cost\\n                if neighbor == goal: return new_path\\n                candidates.append((new_score, new_path))\\n        if not candidates: break\\n        candidates.sort(key=lambda x: x[0])  # minimize score\\n        beams = candidates[:beam_width]\\n    return min(beams, key=lambda x: x[0])[1] if beams else None\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Yankipli engelleme (beam search) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function beamSearch(start, goal, expand, beamWidth = 3, maxDepth = 10) {\\n    let beams = [{ score: 0, path: [start] }];\\n    for (let d = 0; d < maxDepth; d++) {\\n        const candidates = [];\\n        for (const { score, path } of beams) {\\n            for (const [neighbor, cost] of expand(path[path.length - 1])) {\\n                const newPath = [...path, neighbor]; const newScore = score + cost;\\n                if (neighbor === goal) return newPath;\\n                candidates.push({ score: newScore, path: newPath });\\n            }\\n        }\\n        if (!candidates.length) break;\\n        candidates.sort((a, b) => a.score - b.score);\\n        beams = candidates.slice(0, beamWidth);\\n    }\\n    return beams.length ? beams.reduce((a, b) => a.score < b.score ? a : b).path : null;\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Yankipli engelleme (beam search) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func BeamSearch(start, goal string, expand func(string) []struct{ Neighbor string; Cost float64 }, beamWidth int, maxDepth int) []string {\\n    type beamT struct { score float64; path []string }\\n    beams := []beamT{{0, []string{start}}}\\n    for d := 0; d < maxDepth; d++ {\\n        var candidates []beamT\\n        for _, b := range beams {\\n            for _, n := range expand(b.path[len(b.path)-1]) {\\n                newPath := append([]string{}, b.path...); newPath = append(newPath, n.Neighbor)\\n                newScore := b.score + n.Cost\\n                if n.Neighbor == goal { return newPath }\\n                candidates = append(candidates, beamT{newScore, newPath})\\n            }\\n        }\\n        if len(candidates) == 0 { break }\\n        sort.Slice(candidates, func(i, j int) bool { return candidates[i].score < candidates[j].score })\\n        if beamWidth > len(candidates) { beamWidth = len(candidates) }\\n        beams = candidates[:beamWidth]\\n    }\\n    if len(beams) == 0 { return nil }\\n    best := beams[0]\\n    for _, b := range beams { if b.score < best.score { best = b } }\\n    return best.path\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ustel geri cekilme (exponential backoff) stratejisi uygulayan fonksiyon yaz\",\"response\":\"import time, random\\ndef exponential_backoff(attempt, base_delay=1, max_delay=60):\\n    delay = min(base_delay * (2 ** attempt), max_delay)\\n    jitter = random.uniform(0, delay * 0.5)\\n    time.sleep(delay + jitter)\\n    return delay + jitter\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ustel geri cekilme (exponential backoff) stratejisi uygulayan fonksiyon yaz\",\"response\":\"function exponentialBackoff(attempt, baseDelay = 1000, maxDelay = 60000) {\\n    const delay = Math.min(baseDelay * Math.pow(2, attempt), maxDelay);\\n    const jitter = Math.random() * delay * 0.5;\\n    return new Promise(resolve => setTimeout(resolve, delay + jitter));\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Ustel geri cekilme (exponential backoff) stratejisi uygulayan fonksiyon yaz\",\"response\":\"func ExponentialBackoff(attempt int, baseDelay, maxDelay time.Duration) time.Duration {\\n    delay := baseDelay * (1 << attempt)\\n    if delay > maxDelay { delay = maxDelay }\\n    jitter := time.Duration(rand.Float64() * float64(delay) * 0.5)\\n    time.Sleep(delay + jitter)\\n    return delay + jitter\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Paracik surusu optimizasyonu (particle swarm) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import random, math\\ndef particle_swarm(cost_func, dim, n_particles=30, max_iter=100):\\n    particles = [{'pos': [random.uniform(-10, 10) for _ in range(dim)], 'vel': [random.uniform(-1, 1) for _ in range(dim)], 'best': None, 'best_cost': float('inf')} for _ in range(n_particles)]\\n    gbest = None; gbest_cost = float('inf')\\n    for p in particles:\\n        cost = cost_func(p['pos'])\\n        p['best'] = p['pos'][:]; p['best_cost'] = cost\\n        if cost < gbest_cost: gbest = p['pos'][:]; gbest_cost = cost\\n    w, c1, c2 = 0.7, 1.5, 1.5\\n    for _ in range(max_iter):\\n        for p in particles:\\n            for d in range(dim):\\n                r1, r2 = random.random(), random.random()\\n                p['vel'][d] = w * p['vel'][d] + c1 * r1 * (p['best'][d] - p['pos'][d]) + c2 * r2 * (gbest[d] - p['pos'][d])\\n                p['pos'][d] += p['vel'][d]\\n            cost = cost_func(p['pos'])\\n            if cost < p['best_cost']: p['best'] = p['pos'][:]; p['best_cost'] = cost\\n            if cost < gbest_cost: gbest = p['pos'][:]; gbest_cost = cost\\n    return gbest, gbest_cost\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Paracik surusu optimizasyonu (particle swarm) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function particleSwarm(costFunc, dim, nParticles = 30, maxIter = 100) {\\n    const particles = Array.from({length: nParticles}, () => ({ pos: Array.from({length: dim}, () => Math.random() * 20 - 10), vel: Array.from({length: dim}, () => Math.random() * 2 - 1), best: null, bestCost: Infinity }));\\n    let gbest = null, gbestCost = Infinity;\\n    for (const p of particles) { const cost = costFunc(p.pos); p.best = [...p.pos]; p.bestCost = cost; if (cost < gbestCost) { gbest = [...p.pos]; gbestCost = cost; } }\\n    const [w, c1, c2] = [0.7, 1.5, 1.5];\\n    for (let iter = 0; iter < maxIter; iter++) {\\n        for (const p of particles) {\\n            for (let d = 0; d < dim; d++) { const r1 = Math.random(), r2 = Math.random(); p.vel[d] = w * p.vel[d] + c1 * r1 * (p.best[d] - p.pos[d]) + c2 * r2 * (gbest[d] - p.pos[d]); p.pos[d] += p.vel[d]; }\\n            const cost = costFunc(p.pos);\\n            if (cost < p.bestCost) { p.best = [...p.pos]; p.bestCost = cost; }\\n            if (cost < gbestCost) { gbest = [...p.pos]; gbestCost = cost; }\\n        }\\n    }\\n    return { gbest, gbestCost };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Paracik surusu optimizasyonu (particle swarm) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func ParticleSwarm(costFunc func([]float64) float64, dim, nParticles, maxIter int) ([]float64, float64) {\\n    type particle struct { pos, vel, best []float64; bestCost float64 }\\n    particles := make([]particle, nParticles); gbest := make([]float64, dim); gbestCost := math.MaxFloat64\\n    for i := range particles {\\n        p := &particles[i]; p.pos = make([]float64, dim); p.vel = make([]float64, dim); p.best = make([]float64, dim)\\n        for d := range p.pos { p.pos[d] = rand.Float64()*20 - 10; p.vel[d] = rand.Float64()*2 - 1 }\\n        cost := costFunc(p.pos); copy(p.best, p.pos); p.bestCost = cost\\n        if cost < gbestCost { copy(gbest, p.pos); gbestCost = cost }\\n    }\\n    w, c1, c2 := 0.7, 1.5, 1.5\\n    for iter := 0; iter < maxIter; iter++ {\\n        for i := range particles {\\n            p := &particles[i]\\n            for d := 0; d < dim; d++ {\\n                r1, r2 := rand.Float64(), rand.Float64()\\n                p.vel[d] = w*p.vel[d] + c1*r1*(p.best[d]-p.pos[d]) + c2*r2*(gbest[d]-p.pos[d])\\n                p.pos[d] += p.vel[d]\\n            }\\n            cost := costFunc(p.pos)\\n            if cost < p.bestCost { copy(p.best, p.pos); p.bestCost = cost }\\n            if cost < gbestCost { copy(gbest, p.pos); gbestCost = cost }\\n        }\\n    }\\n    return gbest, gbestCost\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Karinca kolonisi optimizasyonu (ant colony) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import random\\ndef ant_colony(dist_matrix, n_ants=10, n_iter=100, alpha=1, beta=2, evaporation=0.5, q=100):\\n    n = len(dist_matrix)\\n    pheromone = [[1.0 / n] * n for _ in range(n)]\\n    best_path = None; best_cost = float('inf')\\n    for _ in range(n_iter):\\n        paths = []\\n        for _ in range(n_ants):\\n            visited = [False] * n; path = [0]; visited[0] = True\\n            for _ in range(n - 1):\\n                i = path[-1]\\n                probs = []\\n                for j in range(n):\\n                    if not visited[j]:\\n                        num = (pheromone[i][j] ** alpha) * ((1.0 / dist_matrix[i][j]) ** beta) if dist_matrix[i][j] > 0 else 0\\n                        den = sum((pheromone[i][k] ** alpha) * ((1.0 / dist_matrix[i][k]) ** beta) for k in range(n) if not visited[k] and dist_matrix[i][k] > 0)\\n                        probs.append((num / den if den > 0 else 0, j))\\n                r = random.random(); cum = 0\\n                for prob, j in probs: cum += prob; if r <= cum: path.append(j); visited[j] = True; break\\n            paths.append(path)\\n        for i in range(n):\\n            for j in range(n): pheromone[i][j] *= (1 - evaporation)\\n        for path in paths:\\n            cost = sum(dist_matrix[path[k]][path[k+1]] for k in range(n-1))\\n            if cost < best_cost: best_path = path; best_cost = cost\\n            for k in range(n-1): pheromone[path[k]][path[k+1]] += q / cost\\n    return best_path, best_cost\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Karinca kolonisi optimizasyonu (ant colony) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function antColony(distMatrix, nAnts = 10, nIter = 100, alpha = 1, beta = 2, evaporation = 0.5, q = 100) {\\n    const n = distMatrix.length;\\n    let pheromone = Array.from({length: n}, () => new Array(n).fill(1 / n));\\n    let bestPath = null; let bestCost = Infinity;\\n    for (let iter = 0; iter < nIter; iter++) {\\n        const paths = [];\\n        for (let ant = 0; ant < nAnts; ant++) {\\n            const visited = new Array(n).fill(false); const path = [0]; visited[0] = true;\\n            for (let step = 0; step < n - 1; step++) {\\n                const i = path[path.length - 1];\\n                const candidates = []; let total = 0;\\n                for (let j = 0; j < n; j++) {\\n                    if (!visited[j] && distMatrix[i][j] > 0) { const prob = Math.pow(pheromone[i][j], alpha) * Math.pow(1 / distMatrix[i][j], beta); candidates.push({ prob, j }); total += prob; }\\n                }\\n                let r = Math.random() * total;\\n                for (const c of candidates) { r -= c.prob; if (r <= 0) { path.push(c.j); visited[c.j] = true; break; } }\\n            }\\n            paths.push(path);\\n        }\\n        for (let i = 0; i < n; i++) for (let j = 0; j < n; j++) pheromone[i][j] *= (1 - evaporation);\\n        for (const path of paths) {\\n            let cost = 0; for (let k = 0; k < n - 1; k++) cost += distMatrix[path[k]][path[k+1]];\\n            if (cost < bestCost) { bestPath = path; bestCost = cost; }\\n            for (let k = 0; k < n - 1; k++) pheromone[path[k]][path[k+1]] += q / cost;\\n        }\\n    }\\n    return { bestPath, bestCost };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Karinca kolonisi optimizasyonu (ant colony) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"public static List<Integer> antColony(double[][] distMatrix, int nAnts, int nIter, double alpha, double beta, double evaporation, double q) {\\n    int n = distMatrix.length; double[][] pheromone = new double[n][n];\\n    for (int i = 0; i < n; i++) Arrays.fill(pheromone[i], 1.0 / n);\\n    List<Integer> bestPath = null; double bestCost = Double.MAX_VALUE; Random rand = new Random();\\n    for (int iter = 0; iter < nIter; iter++) {\\n        List<List<Integer>> paths = new ArrayList<>();\\n        for (int ant = 0; ant < nAnts; ant++) {\\n            boolean[] visited = new boolean[n]; List<Integer> path = new ArrayList<>(); path.add(0); visited[0] = true;\\n            for (int step = 0; step < n - 1; step++) {\\n                int i = path.get(path.size() - 1); double total = 0;\\n                List<AbstractMap.SimpleEntry<Double, Integer>> candidates = new ArrayList<>();\\n                for (int j = 0; j < n; j++) { if (!visited[j] && distMatrix[i][j] > 0) { double p = Math.pow(pheromone[i][j], alpha) * Math.pow(1.0 / distMatrix[i][j], beta); candidates.add(new AbstractMap.SimpleEntry<>(p, j)); total += p; } }\\n                double r = rand.nextDouble() * total;\\n                for (var c : candidates) { r -= c.getKey(); if (r <= 0) { path.add(c.getValue()); visited[c.getValue()] = true; break; } }\\n            }\\n            paths.add(path);\\n        }\\n        for (int i = 0; i < n; i++) for (int j = 0; j < n; j++) pheromone[i][j] *= (1 - evaporation);\\n        for (var path : paths) {\\n            double cost = 0; for (int k = 0; k < n - 1; k++) cost += distMatrix[path.get(k)][path.get(k + 1)];\\n            if (cost < bestCost) { bestPath = new ArrayList<>(path); bestCost = cost; }\\n            for (int k = 0; k < n - 1; k++) pheromone[path.get(k)][path.get(k + 1)] += q / cost;\\n        }\\n    }\\n    return bestPath;\\n}\",\"language\":\"java\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tepe tirmanma (hill climbing) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"import random, math\\ndef hill_climbing(cost_func, neighbor_func, start, max_iter=1000):\\n    current = start; current_cost = cost_func(current)\\n    for _ in range(max_iter):\\n        neighbor = neighbor_func(current)\\n        neighbor_cost = cost_func(neighbor)\\n        if neighbor_cost < current_cost:\\n            current = neighbor; current_cost = neighbor_cost\\n        else: break\\n    return current, current_cost\",\"language\":\"python\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tepe tirmanma (hill climbing) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"function hillClimbing(costFunc, neighborFunc, start, maxIter = 1000) {\\n    let current = start; let currentCost = costFunc(current);\\n    for (let i = 0; i < maxIter; i++) {\\n        const neighbor = neighborFunc(current); const neighborCost = costFunc(neighbor);\\n        if (neighborCost < currentCost) { current = neighbor; currentCost = neighborCost; } else break;\\n    }\\n    return { current, currentCost };\\n}\",\"language\":\"javascript\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
"{\"instruction\":\"Tepe tirmanma (hill climbing) algoritmasini uygulayan fonksiyon yaz\",\"response\":\"func HillClimbing(costFunc func([]float64) float64, neighborFunc func([]float64) []float64, start []float64, maxIter int) ([]float64, float64) {\\n    current := make([]float64, len(start)); copy(current, start)\\n    currentCost := costFunc(current)\\n    for i := 0; i < maxIter; i++ {\\n        neighbor := neighborFunc(current); neighborCost := costFunc(neighbor)\\n        if neighborCost < currentCost { current = neighbor; currentCost = neighborCost } else { break }\\n    }\\n    return current, currentCost\\n}\",\"language\":\"go\",\"category\":\"cross_lang\",\"type\":\"manual\",\"format\":\"cross_lang\"}"
