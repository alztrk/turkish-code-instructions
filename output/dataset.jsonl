"{\"instruction\":\"Bu JavaScript kodundaki hatayi bul ve duzelt:\\n```javascript\\nfunction birlestir(hedef, kaynak) {\\n    for (const anahtar in kaynak) {\\n        hedef[anahtar] = kaynak[anahtar];\\n    }\\n    return hedef;\\n}\\n\\nconst kullanici = {};\\nbirlestir(kullanici, JSON.parse('{\\\"__proto__\\\": {\\\"admin\\\": true}}'));\\nconsole.log({}.admin);  // true\\n```\",\"response\":\"function birlestir(hedef, kaynak) {\\n    for (const anahtar of Object.keys(kaynak)) {\\n        if (anahtar === '__proto__' || anahtar === 'constructor') continue;\\n        hedef[anahtar] = kaynak[anahtar];\\n    }\\n    return hedef;\\n}\\n\\nconst kullanici = {};\\nbirlestir(kullanici, JSON.parse('{\\\"__proto__\\\": {\\\"admin\\\": true}}'));\\nconsole.log({}.admin);  // undefined\",\"language\":\"javascript\",\"category\":\"bug_fix\",\"type\":\"manual\",\"format\":\"bug_fix\"}"
