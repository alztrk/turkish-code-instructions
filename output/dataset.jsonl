"{\"instruction\":\"@property ile hesaplanan ozellik.\",\"response\":\"class D:\\n  def __init__(self,g,y): self._g=g; self._y=y\\n  @property\\n  def a(self): return self._g*self._y\\n  @property\\n  def g(self): return self._g\\n  @g.setter\\n  def g(self,d):\\n    if d>0: self._g=d\\nprint(D(5,10).a)\",\"language\":\"python\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
"{\"instruction\":\"@classmethod ve @staticmethod kullanimi.\",\"response\":\"class T:\\n  @classmethod\\n  def b(cls):\\n    from datetime import date\\n    return cls(date.today().year,date.today().month,date.today().day)\\n  @staticmethod\\n  def a(y): return y%4==0 and y%100!=0 or y%400==0\\n  def __init__(self,y,a,g): self.t=(y,a,g)\\nt=T.b()\\nprint(t.t,T.a(2024))\",\"language\":\"python\",\"category\":\"standard\",\"type\":\"manual\",\"format\":\"standard\"}"
