{
  "name": "turkish-code-instructions",
  "version": "1.0.0",
  "description": "Turkish code instruction dataset for LLM fine-tuning. 1003 examples across 8 formats and 11 languages.",
  "license": "mit",
  "language": ["tr"],
  "task_categories": ["text-generation", "code-generation"],
  "tags": ["turkish", "code", "instruction-tuning", "code-review", "bug-fix"],
  "pretty_name": "Turkish Code Instructions",
  "size_categories": "1K<n<10K",
  "source_datasets": ["original"],
  "multilinguality": ["monolingual"],
  "modality": ["text"],
  "format": "jsonl",
  "splits": [
    {
      "name": "train",
      "num_examples": 1003
    }
  ],
  "configs": [
    {
      "name": "default",
      "description": "Full dataset: 8 formats, 11 languages"
    },
    {
      "name": "code_only",
      "description": "Standard instruction-to-code pairs only"
    },
    {
      "name": "code_review",
      "description": "Code review format pairs only"
    }
  ]
}
